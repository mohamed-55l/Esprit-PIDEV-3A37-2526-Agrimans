<!DOCTYPE html>
<html lang="fr">
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1.0">
        <title>{% block title %}Agrimans - Hub{% endblock %}</title>
        
        <link rel="preconnect" href="https://fonts.googleapis.com">
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
        <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700&display=swap" rel="stylesheet">
        
        <!-- Icons (utilisation d'une librairie simple pour les futurs liens) -->
        <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
        <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
        
        <link rel="stylesheet" href="{{ asset('css/style.css') }}?v={{ random() }}">
        
        {% block stylesheets %}{% endblock %}
        {% block javascripts %}{% endblock %}
        <script>
            document.addEventListener('DOMContentLoaded', function() {
                const navbar = document.querySelector('.navbar');
                if (!navbar) return;
                const shrinkThreshold = 60;
                window.addEventListener('scroll', function() {
                    if (window.scrollY > shrinkThreshold) {
                        navbar.classList.add('shrink');
                    } else {
                        navbar.classList.remove('shrink');
                    }
                }, { passive: true });
            });
        </script>
    </head>
    <body{% if app.user and not is_granted('ROLE_ADMIN') %} data-animal-notif-poll="{{ path('waad_animal_notifications_poll') }}"{% endif %}>
        
            <nav class="navbar">
                <a href="{{ path('app_home') }}" class="logo">
                    <img src="{{ asset('images/logo.png') }}" alt="Agrimans Logo" style="height: 55px; width: auto; transition: height 0.3s ease;">
                </a>
                
                <div class="nav-links">
                    {% if not app.user %}
                        <a href="#"><i class="fa-solid fa-circle-info"></i> À propos</a>
                        <a href="#"><i class="fa-solid fa-envelope"></i> Contact</a>
                        <a href="{{ path('app_marketplace_index') }}" class="nav-link-professional"><i class="fa-solid fa-store"></i> Boutique</a>
                    {% elseif is_granted('ROLE_ADMIN') %}
                        <!-- Admin sees no navigation menu, only dashboard access -->
                    {% else %}
                        <div class="dropdown">
                            <a href="{{ path('app_home') }}"><i class="fa-solid fa-gauge-high"></i> Tableau de bord</a>
                            <div class="dropdown-content">
                                <a href="#"><i class="fa-solid fa-chart-line"></i> Statistiques du domaine</a>
                                <a href="#"><i class="fa-solid fa-cloud-sun"></i> Météo en temps réel</a>
                                <a href="#"><i class="fa-solid fa-robot"></i> Smart Assistant</a>
                            </div>
                        </div>

                        <div class="dropdown">
                            <a href="#" style="cursor:default;"><i class="fa-solid fa-tractor"></i> Ressources agro</a>
                            <div class="dropdown-content">
                                <a href="{{ path('app_equipement_index') }}"><i class="fa-solid fa-toolbox"></i> Stock équipements</a>
                                <a href="#"><i class="fa-solid fa-map-location-dot"></i> Suivi GPS & Garages</a>
                                <a href="#"><i class="fa-solid fa-tasks"></i> Demandes & Assignements</a>
                                <a href="{{ path('app_review_index') }}"><i class="fa-solid fa-star"></i> Avis & Évaluations</a>
                            </div>
                        </div>

                        <div class="dropdown">
                            <a href="#" style="cursor:default;"><i class="fa-solid fa-leaf"></i> Domaine & élevage</a>
                            <div class="dropdown-content">
                                <a href="{{ path('app_parcelle_index') }}"><i class="fa-solid fa-map"></i> Gestion des Parcelles</a>
                                <a href="{{ path('app_culture_index') }}"><i class="fa-solid fa-seedling"></i> Suivi des Cultures</a>
                                <a href="{{ path('waad_animal_index') }}"><i class="fa-solid fa-cow"></i> Gestion des Animaux</a>
                                <a href="{{ path('waad_animal_stats') }}"><i class="fa-solid fa-chart-pie"></i> Stats &amp; IA élevage</a>
                                <a href="{{ path('waad_animal_historique') }}"><i class="fa-solid fa-clock-rotate-left"></i> Historique élevage</a>
                                <a href="{{ path('waad_nourriture_index') }}"><i class="fa-solid fa-bowl-food"></i> Stocks Alimentaires</a>
                            </div>
                        </div>
                    {% endif %}
                </div>

                <div class="nav-actions">
                    <style>
                        .nav-link-professional {
                            display: inline-flex; align-items: center; gap: 6px;
                            padding: 0.6rem 1.2rem; margin: 0 4px;
                            font-weight: 600; font-size: 0.95rem; text-decoration: none;
                            color: rgba(255, 255, 255, 0.85);
                            border-radius: 12px;
                            transition: all 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);
                        }
                        .nav-link-professional:hover {
                            color: #ffffff;
                            background: rgba(255, 255, 255, 0.1);
                            transform: translateY(-2px);
                        }
                        .nav-cart-icon {
                            display: flex; align-items: center; justify-content: center;
                            width: 42px; height: 42px; border-radius: 50%;
                            background: rgba(255, 255, 255, 0.1); color: #fff;
                            transition: all 0.3s ease; text-decoration: none;
                            font-size: 1.1rem;
                        }
                        .nav-cart-icon:hover {
                            background: #198B61; color: #fff; transform: scale(1.1); box-shadow: 0 4px 10px rgba(25, 139, 97, 0.4);
                        }
                    </style>

                    {% if app.user %}
                        {% if is_granted('ROLE_ADMIN') %}
                            <!-- Admin has no action buttons in navbar -->
                        {% else %}
                            <button type="button" id="agrimans-desktop-notif-btn" class="nav-cart-icon" title="Activer les notifications Windows / du navigateur (hors onglet)" style="margin-right:4px; border:none; cursor:pointer; position:relative;" aria-label="Notifications bureau">
                                <i class="fa-solid fa-desktop"></i>
                            </button>
                            <a href="{{ path('waad_animal_notifications') }}" class="nav-cart-icon" title="Notifications élevage" style="margin-right:8px; text-decoration:none; position:relative;">
                                <i class="fa-solid fa-bell"></i>
                                {% if animal_notif_unread > 0 %}<span style="position:absolute; top:-4px; right:-4px; background:#e74c3c; font-size:10px; padding:2px 5px; border-radius:10px; line-height:1;">{{ animal_notif_unread }}</span>{% endif %}
                            </a>
                            <a href="{{ path('app_marketplace_index') }}" class="nav-link-professional" style="margin-right: 10px;"><i class="fa-solid fa-store"></i> Boutique</a>
                            <a href="{{ path('app_marketplace_cart') }}" class="nav-cart-icon" title="Panier"><i class="fa-solid fa-shopping-cart"></i></a>
                        {% endif %}
                        <div class="dropdown" style="margin-left: 1rem;">
                            <a href="#" class="top-btn btn-outline" style="background: rgba(255,255,255,0.1); border-radius:12px; padding: 0.6rem 1.2rem;"><i class="fa-solid fa-user"></i> {{ app.user.email }}</a>
                            <div class="dropdown-content" style="right: 0;">
                                <a href="#">Profil</a>
                                <a href="#">Paramètres</a>
                                <a href="{{ path('app_logout') }}" style="color: #e74c3c;"><i class="fa-solid fa-sign-out-alt"></i> Déconnexion</a>
                            </div>
                        </div>
                    {% else %}
                        <a href="{{ path('app_marketplace_cart') }}" class="nav-cart-icon" title="Panier" style="margin-right: 1rem;"><i class="fa-solid fa-shopping-cart"></i></a>
                        <a href="{{ path('app_login') }}" class="top-btn btn-outline" style="padding: 0.6rem 1.5rem; border-radius: 12px;"><i class="fa-solid fa-sign-in-alt"></i> Connexion</a>
                    {% endif %}
                </div>
            </nav>

        <div class="app-wrapper">
            <main>
                {% block body %}{% endblock %}
            </main>
        </div>

        {% if app.user and not is_granted('ROLE_ADMIN') %}
        <script src="{{ asset('js/animal-desktop-notifications.js') }}" defer></script>
        {% endif %}
    </body>
</html>
