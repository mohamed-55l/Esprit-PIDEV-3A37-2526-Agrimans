<!DOCTYPE html>
<html lang="fr">
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1.0">
        <title>{% block title %}Agrimans - Hub{% endblock %}</title>
        
        <link rel="preconnect" href="https://fonts.googleapis.com">
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
        <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700&display=swap" rel="stylesheet">
        
        <!-- Icons (utilisation d'une librairie simple pour les futurs liens) -->
        <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
        <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
        
        <link rel="stylesheet" href="{{ asset('css/style.css') }}?v={{ random() }}">
        
        {% block stylesheets %}{% endblock %}
        {% block javascripts %}{% endblock %}
        <script>
            document.addEventListener('DOMContentLoaded', function() {
                const navbar = document.querySelector('.navbar');
                if (!navbar) return;
                const shrinkThreshold = 60;
                window.addEventListener('scroll', function() {
                    if (window.scrollY > shrinkThreshold) {
                        navbar.classList.add('shrink');
                    } else {
                        navbar.classList.remove('shrink');
                    }
                }, { passive: true });
            });
        </script>
    </head>
    <body>
        
            <nav class="navbar">
                <a href="{{ path('app_home') }}" class="logo" style="text-transform: uppercase; color: #198B61;">
                    <img src="{{ asset('images/FullLogo_Transparent_NoBuffer (1).png') }}" alt="Agrimans Logo" style="height: 40px; width: auto; margin-right: 10px;">
                    Agrimans
                </a>
                
                <!-- Titres génériques de navigation avec Dropdowns (Menus déroulants) -->
                <div class="nav-links">
                    
                    <div class="dropdown">
                        <a href="{{ path('app_home') }}"><i class="fa-solid fa-gauge-high"></i> Tableau de bord</a>
                        <div class="dropdown-content">
                            <a href="#"><i class="fa-solid fa-chart-line"></i> Statistiques du domaine</a>
                            <a href="#"><i class="fa-solid fa-cloud-sun"></i> Météo en temps réel</a>
                            <a href="#"><i class="fa-solid fa-robot"></i> Smart Assistant (Chatbot)</a>
                        </div>
                    </div>

                    <div class="dropdown">
                        <a href="#" style="color: #7DBF6C; cursor:default;"><i class="fa-solid fa-tractor"></i> Ressources agro</a>
                        <div class="dropdown-content">
                            <a href="{{ path('app_equipement_index') }}"><i class="fa-solid fa-toolbox"></i> Stock équipements</a>
                            <a href="#"><i class="fa-solid fa-map-location-dot"></i> Suivi GPS & Garages</a>
                            <a href="#"><i class="fa-solid fa-tasks"></i> Demandes & Assignements</a>
                            <a href="{{ path('app_review_index') }}"><i class="fa-solid fa-star"></i> Avis & Évaluations</a>
                        </div>
                    </div>

                    <div class="dropdown">
                        <a href="#" style="cursor:default;"><i class="fa-solid fa-leaf"></i> Domaine & élevage</a>
                        <div class="dropdown-content">
                            <a href="{{ path('app_parcelle_index') }}"><i class="fa-solid fa-map"></i> Gestion des Parcelles</a>
                            <a href="{{ path('app_culture_index') }}"><i class="fa-solid fa-seedling"></i> Suivi des Cultures</a>
                            <a href="#"><i class="fa-solid fa-cow"></i> Gestion des Animaux</a>
                        </div>
                    </div>

                    <div class="dropdown">
                        <a href="{{ path('app_marketplace_index') }}" style="cursor:default;"><i class="fa-solid fa-store"></i> Marketplace</a>
                        <div class="dropdown-content">
                            <a href="{{ path('app_marketplace_index') }}"><i class="fa-solid fa-cart-shopping"></i> Explorer la Boutique</a>
                            <a href="{{ path('app_marketplace_cart') }}"><i class="fa-solid fa-bag-shopping"></i> Mon Panier & Commandes</a>
                            <a href="{{ path('app_marketplace_my_products') }}"><i class="fa-solid fa-box-open"></i> Gérer mes Produits</a>
                            <a href="{{ path('app_marketplace_stats') }}"><i class="fa-solid fa-chart-line"></i> Statistiques</a>
                        </div>
                    </div>
                </div>

                
                <div class="nav-actions">
                    <a href="#" class="top-btn btn-outline"><i class="fa-solid fa-user"></i> Espace profil</a>
                </div>
            </nav>

        <div class="app-wrapper">
            <main>
                {% block body %}{% endblock %}
            </main>
        </div>
        
    </body>
</html>
