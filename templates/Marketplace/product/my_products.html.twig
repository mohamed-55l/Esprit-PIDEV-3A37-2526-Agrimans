{% extends 'base.html.twig' %}

{% block title %}Mes Produits{% endblock %}

{% block body %}
    <section class="content-section" style="margin-top: 2rem;">
        <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 2rem;">
            <div>
                <h2 style="font-size: 2rem; margin-bottom: 0.5rem;"><i class="fa-solid fa-box-open"></i> Mes Produits</h2>
                <p style="color: rgba(255,255,255,0.7);">Gérez vos produits mis en vente sur le marketplace.</p>
            </div>
            <div style="display: flex; gap: 1rem;">
                <a href="{{ path('app_marketplace_index') }}" class="btn btn-secondary">
                    <i class="fa-solid fa-arrow-left"></i> Retour Boutique
                </a>
                <a href="{{ path('app_marketplace_product_new') }}" class="hero-btn-primary" style="font-size: 0.9rem;">
                    + Ajouter Produit
                </a>
            </div>
        </div>

        {# Flash messages #}
        {% for type, messages in app.flashes %}
            {% for message in messages %}
                <div style="padding: 1rem; margin-bottom: 1rem; border-radius: 8px; background: {{ type == 'success' ? 'rgba(125, 191, 108, 0.2)' : 'rgba(231, 76, 60, 0.2)' }}; border: 1px solid {{ type == 'success' ? '#7DBF6C' : '#e74c3c' }};">
                    <i class="fa-solid {{ type == 'success' ? 'fa-check-circle' : 'fa-exclamation-circle' }}"></i> {{ message }}
                </div>
            {% endfor %}
        {% endfor %}

        <div class="table-wrapper">
            <table class="styled-table">
                <thead>
                    <tr>
                        <th>ID</th>
                        <th>Produit</th>
                        <th>Catégorie</th>
                        <th>Prix/kg</th>
                        <th>Stock</th>
                        <th>Fournisseur</th>
                        <th>Expiration</th>
                        <th>Note</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                {% for product in products %}
                    <tr>
                        <td style="color: rgba(255,255,255,0.5);">#{{ product.id }}</td>
                        <td><strong>{{ product.name }}</strong></td>
                        <td>
                            <span class="badge {{ product.category == 'VEGETABLES' ? 'badge-success' : (product.category == 'FRUITS' ? 'badge-warning' : 'badge-primary') }}">
                                <i class="fa-solid {{ product.categoryIcon }}"></i> {{ product.category }}
                            </span>
                        </td>
                        <td style="font-weight: 600;">{{ product.price|number_format(2, ',', ' ') }} DT</td>
                        <td>
                            {% if product.quantity > 0 %}
                                <span class="badge badge-success">{{ product.quantity }} kg</span>
                            {% else %}
                                <span class="badge badge-danger">Rupture</span>
                            {% endif %}
                        </td>
                        <td>{{ product.supplier ?? '-' }}</td>
                        <td>{{ product.expiryDate ? product.expiryDate|date('d/m/Y') : '-' }}</td>
                        <td>
                            {% if product.averageRating > 0 %}
                                {% for i in 1..5 %}
                                    <i class="fa-{{ i <= product.averageRating ? 'solid' : 'regular' }} fa-star" style="color: #f1c40f; font-size: 0.8rem;"></i>
                                {% endfor %}
                            {% else %}
                                <span style="color: rgba(255,255,255,0.4);">-</span>
                            {% endif %}
                        </td>
                        <td>
                            <a href="{{ path('app_marketplace_product_show', {'id': product.id}) }}" class="btn btn-secondary"><i class="fa-solid fa-eye"></i></a>
                            <a href="{{ path('app_marketplace_product_edit', {'id': product.id}) }}" class="btn btn-primary" style="margin-left: 0.3rem;"><i class="fa-solid fa-pen"></i></a>
                            <form method="post" action="{{ path('app_marketplace_product_delete', {'id': product.id}) }}" style="display: inline;" onsubmit="return confirm('Supprimer ce produit ?');">
                                <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ product.id) }}">
                                <button class="btn" style="background: rgba(231,76,60,0.2); color: #e74c3c; border: 1px solid #e74c3c; margin-left: 0.3rem;"><i class="fa-solid fa-trash"></i></button>
                            </form>
                        </td>
                    </tr>
                {% else %}
                    <tr>
                        <td colspan="9" style="text-align: center; padding: 3rem; color: rgba(255,255,255,0.6);">
                            <i class="fa-solid fa-box-open" style="font-size: 3rem; margin-bottom: 1rem; opacity: 0.5;"></i><br>
                            Vous n'avez aucun produit en vente.
                        </td>
                    </tr>
                {% endfor %}
                </tbody>
            </table>
        </div>
    </section>
{% endblock %}
