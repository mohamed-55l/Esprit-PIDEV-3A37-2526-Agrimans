{% extends 'base.html.twig' %}

{% block title %}Modifier Équipement{% endblock %}

{% block body %}
    <section class="content-section" style="margin-top: 2rem;">
        <div style="max-width: 800px; margin: 0 auto; background: rgba(255,255,255,0.03); border: 1px solid rgba(255,255,255,0.08); border-radius: 16px; padding: 2.5rem;">
            
            <div style="display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 2rem;">
                <div>
                    <i class="fa-solid fa-pen-to-square" style="font-size: 2.5rem; color: #3498db; margin-bottom: 1rem;"></i>
                    <h1 style="font-size: 2rem; color: #fff;">Modifier l'Équipement</h1>
                    <p style="color: rgba(255,255,255,0.6);">Modification de : <strong style="color:#fff;">{{ equipement.nom }}</strong></p>
                </div>
                <div>
                    {{ include('equipement/_delete_form.html.twig') }}
                </div>
            </div>

            {{ include('equipement/_form.html.twig', {'button_label': 'Mettre à jour'}) }}

        </div>
    </section>
{% endblock %}
