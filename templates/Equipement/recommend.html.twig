{% extends 'base.html.twig' %}

{% block title %}Recommandations d'Équipement - {{ parcelle.nom }}{% endblock %}

{% block body %}
<section class="content-section" style="margin-top: 2rem;">

    <!-- Page Header -->
    <div style="display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 2.5rem;">
        <div>
            <div style="display: flex; align-items: center; gap: 0.8rem; margin-bottom: 0.5rem;">
                <i class="fa-solid fa-star" style="font-size: 2rem; color: #f1c40f;"></i>
                <h1 style="font-size: 2rem; color: #fff; margin: 0;">Recommandations Intelligentes</h1>
            </div>
            <p style="color: rgba(255,255,255,0.6); margin: 0;">Classement des équipements les plus adaptés à votre parcelle.</p>
        </div>
        <a href="{{ path('app_equipement_index') }}" class="btn btn-secondary" style="padding: 0.7rem 1.3rem;">
            <i class="fa-solid fa-arrow-left"></i> Retour à la liste
        </a>
    </div>

    <!-- Info Parcelle -->
    <div style="background: rgba(255,255,255,0.03); border: 1px solid rgba(255,255,255,0.08); border-radius: 16px; padding: 1.8rem; margin-bottom: 2rem;">
        <div style="display: flex; align-items: center; gap: 0.7rem; margin-bottom: 1.2rem; padding-bottom: 0.8rem; border-bottom: 1px solid rgba(255,255,255,0.07);">
            <i class="fa-solid fa-map-location-dot" style="color: #2ecc71; font-size: 1.3rem;"></i>
            <h2 style="font-size: 1.1rem; color: rgba(255,255,255,0.9); margin: 0; font-weight: 600;">Parcelle Analysée</h2>
        </div>
        <div style="display: grid; grid-template-columns: repeat(4, 1fr); gap: 1rem;">
            <div>
                <p style="color: rgba(255,255,255,0.5); font-size: 0.8rem; margin-bottom: 0.2rem; text-transform: uppercase; letter-spacing: 0.5px;">Nom</p>
                <p style="color: #fff; font-weight: 600; margin: 0;">{{ parcelle.nom }}</p>
            </div>
            <div>
                <p style="color: rgba(255,255,255,0.5); font-size: 0.8rem; margin-bottom: 0.2rem; text-transform: uppercase; letter-spacing: 0.5px;">Surface</p>
                <p style="color: #f1c40f; font-weight: 700; font-size: 1.2rem; margin: 0;">{{ parcelle.superficie }} Ha</p>
            </div>
            <div>
                <p style="color: rgba(255,255,255,0.5); font-size: 0.8rem; margin-bottom: 0.2rem; text-transform: uppercase; letter-spacing: 0.5px;">Localisation</p>
                <p style="color: rgba(255,255,255,0.85); margin: 0;">{{ parcelle.localisation }}</p>
            </div>
            <div>
                <p style="color: rgba(255,255,255,0.5); font-size: 0.8rem; margin-bottom: 0.2rem; text-transform: uppercase; letter-spacing: 0.5px;">Type de Sol</p>
                <p style="color: rgba(255,255,255,0.85); margin: 0;">{{ parcelle.type_sol }}</p>
            </div>
        </div>
    </div>

    <!-- Grille de Recommandations -->
    <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(340px, 1fr)); gap: 1.5rem; margin-bottom: 2rem;">
        {% for recommendation in recommendations %}
        <div style="
            background: rgba(255,255,255,0.03);
            border: 1px solid rgba({% if recommendation.badgeColor == 'green' %}46,204,113{% elseif recommendation.badgeColor == 'yellow' %}241,196,15{% else %}231,76,60{% endif %}, 0.35);
            border-radius: 16px;
            overflow: hidden;
            display: flex;
            flex-direction: column;
            transition: transform 0.3s ease, box-shadow 0.3s ease;
        " onmouseover="this.style.transform='translateY(-4px)'; this.style.boxShadow='0 12px 30px rgba(0,0,0,0.3)';" 
           onmouseout="this.style.transform='translateY(0)'; this.style.boxShadow='none';">

            <!-- Card Header avec Rang et Score -->
            <div style="
                background: rgba({% if recommendation.badgeColor == 'green' %}46,204,113{% elseif recommendation.badgeColor == 'yellow' %}241,196,15{% else %}231,76,60{% endif %}, 0.12);
                padding: 1.2rem 1.5rem;
                display: flex;
                justify-content: space-between;
                align-items: center;
                border-bottom: 1px solid rgba({% if recommendation.badgeColor == 'green' %}46,204,113{% elseif recommendation.badgeColor == 'yellow' %}241,196,15{% else %}231,76,60{% endif %}, 0.2);
            ">
                <div style="display: flex; align-items: center; gap: 0.7rem;">
                    <span style="font-size: 1.5rem;">
                        {% if loop.index == 1 %}🥇{% elseif loop.index == 2 %}🥈{% elseif loop.index == 3 %}🥉{% else %}#{{ loop.index }}{% endif %}
                    </span>
                    <div>
                        <p style="color: rgba(255,255,255,0.5); font-size: 0.75rem; margin: 0; text-transform: uppercase; letter-spacing: 0.5px;">
                            {% if loop.index == 1 %}1er Choix{% elseif loop.index == 2 %}2e Choix{% elseif loop.index == 3 %}3e Choix{% else %}Choix #{{ loop.index }}{% endif %}
                        </p>
                        <p style="color: #fff; font-weight: 700; font-size: 1rem; margin: 0;">{{ recommendation.equipement.nom }}</p>
                    </div>
                </div>
                <!-- Score circulaire -->
                <div style="
                    width: 60px; height: 60px; border-radius: 50%;
                    background: rgba({% if recommendation.badgeColor == 'green' %}46,204,113{% elseif recommendation.badgeColor == 'yellow' %}241,196,15{% else %}231,76,60{% endif %}, 0.15);
                    border: 2px solid rgba({% if recommendation.badgeColor == 'green' %}46,204,113{% elseif recommendation.badgeColor == 'yellow' %}241,196,15{% else %}231,76,60{% endif %}, 0.6);
                    display: flex; align-items: center; justify-content: center;
                    flex-shrink: 0;
                ">
                    <span style="font-size: 0.8rem; font-weight: 800; color: {% if recommendation.badgeColor == 'green' %}#2ecc71{% elseif recommendation.badgeColor == 'yellow' %}#f1c40f{% else %}#e74c3c{% endif %};">
                        {{ recommendation.matchScore|round(0) }}%
                    </span>
                </div>
            </div>

            <!-- Card Body -->
            <div style="padding: 1.5rem; flex-grow: 1; display: flex; flex-direction: column; gap: 1rem;">

                <!-- Type + Disponibilité -->
                <div style="display: flex; justify-content: space-between; align-items: center;">
                    <span style="color: rgba(255,255,255,0.6); font-size: 0.9rem;">{{ recommendation.equipement.type }}</span>
                    {% if recommendation.equipement.disponibilite == 'Disponible' %}
                        <span class="badge badge-success"><i class="fa-solid fa-check-circle"></i> {{ recommendation.equipement.disponibilite }}</span>
                    {% elseif recommendation.equipement.disponibilite == 'Indisponible' %}
                        <span class="badge badge-danger"><i class="fa-solid fa-times-circle"></i> {{ recommendation.equipement.disponibilite }}</span>
                    {% else %}
                        <span class="badge badge-warning"><i class="fa-solid fa-wrench"></i> {{ recommendation.equipement.disponibilite }}</span>
                    {% endif %}
                </div>

                <!-- Métriques -->
                <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 0.8rem;">
                    <div style="background: rgba(102,126,234,0.08); border: 1px solid rgba(102,126,234,0.2); border-radius: 10px; padding: 0.8rem; text-align: center;">
                        <p style="color: rgba(255,255,255,0.5); font-size: 0.75rem; margin-bottom: 0.2rem;">Capacité</p>
                        <p style="color: #667eea; font-weight: 700; margin: 0;">{{ recommendation.equipement.capaciteRendement }} Ha/h</p>
                    </div>
                    <div style="background: rgba(46,204,113,0.08); border: 1px solid rgba(46,204,113,0.2); border-radius: 10px; padding: 0.8rem; text-align: center;">
                        <p style="color: rgba(255,255,255,0.5); font-size: 0.75rem; margin-bottom: 0.2rem;">Prix</p>
                        <p style="color: #2ecc71; font-weight: 700; margin: 0;">{{ recommendation.equipement.prix }} DT</p>
                    </div>
                    <div style="background: rgba(255,255,255,0.04); border: 1px solid rgba(255,255,255,0.07); border-radius: 10px; padding: 0.8rem; text-align: center;">
                        <p style="color: rgba(255,255,255,0.5); font-size: 0.75rem; margin-bottom: 0.2rem;">Temps Estimé</p>
                        <p style="color: #fff; font-weight: 700; margin: 0;">{{ recommendation.estimatedTimeHours|round(2) }} h</p>
                    </div>
                    <div style="background: rgba(255,255,255,0.04); border: 1px solid rgba(255,255,255,0.07); border-radius: 10px; padding: 0.8rem; text-align: center;">
                        <p style="color: rgba(255,255,255,0.5); font-size: 0.75rem; margin-bottom: 0.2rem;">Statut</p>
                        {% if recommendation.recommendation == 'RECOMMENDED' %}
                            <span style="color: #2ecc71; font-weight: 700; font-size: 0.8rem;">✓ RECOMMANDÉ</span>
                        {% elseif recommendation.recommendation == 'ACCEPTABLE' %}
                            <span style="color: #f1c40f; font-weight: 700; font-size: 0.8rem;">⚠ ACCEPTABLE</span>
                        {% else %}
                            <span style="color: #e74c3c; font-weight: 700; font-size: 0.8rem;">✗ NON REC.</span>
                        {% endif %}
                    </div>
                </div>

                <!-- Raison -->
                <div style="background: rgba(102,126,234,0.07); border-left: 3px solid rgba(102,126,234,0.5); padding: 0.8rem; border-radius: 0 8px 8px 0;">
                    <p style="color: rgba(255,255,255,0.7); font-size: 0.85rem; margin: 0; line-height: 1.5;">{{ recommendation.reason }}</p>
                </div>

                <!-- Alerte -->
                {% if recommendation.alertMessage %}
                <div style="background: rgba(241,196,15,0.07); border-left: 3px solid rgba(241,196,15,0.5); padding: 0.8rem; border-radius: 0 8px 8px 0;">
                    <p style="color: rgba(255,255,255,0.7); font-size: 0.85rem; margin: 0; line-height: 1.5;">{{ recommendation.alertMessage }}</p>
                </div>
                {% endif %}
            </div>

            <!-- Card Footer - Actions -->
            <div style="padding: 1rem 1.5rem; border-top: 1px solid rgba(255,255,255,0.06); display: flex; gap: 0.8rem;">
                <a href="{{ path('app_equipement_show', {id: recommendation.equipement.id}) }}" class="btn btn-secondary" style="flex: 1; text-align: center; padding: 0.6rem;">
                    <i class="fa-solid fa-eye"></i> Détails
                </a>
                <a href="{{ path('app_equipement_match', {equipementId: recommendation.equipement.id, parcelleId: parcelle.id}) }}" class="hero-btn-primary" style="flex: 1; text-align: center; padding: 0.6rem; font-size: 0.9rem; border: none; cursor: pointer; font-family: inherit;">
                    <i class="fa-solid fa-magnifying-glass-chart"></i> Analyser
                </a>
            </div>
        </div>
        {% endfor %}
    </div>

    <!-- Démonstration Jury -->
    <div style="background: rgba(255,255,255,0.03); border: 1px solid rgba(255,255,255,0.08); border-radius: 16px; padding: 1.8rem;">
        <div style="display: flex; align-items: center; gap: 0.7rem; margin-bottom: 1.2rem; padding-bottom: 0.8rem; border-bottom: 1px solid rgba(255,255,255,0.07);">
            <i class="fa-solid fa-graduation-cap" style="color: #f1c40f; font-size: 1.3rem;"></i>
            <h2 style="font-size: 1.1rem; color: rgba(255,255,255,0.9); margin: 0; font-weight: 600;">Démonstration Métier Avancée</h2>
        </div>
        <p style="color: rgba(255,255,255,0.85); font-weight: 600; margin-bottom: 0.8rem;">Comment Fonctionne le Matching Intelligent ?</p>
        <ol style="color: rgba(255,255,255,0.75); line-height: 2; padding-left: 1.5rem;">
            <li><strong style="color:#fff;">Analyse de la Parcelle :</strong> Surface = {{ parcelle.superficie }} Ha</li>
            <li><strong style="color:#fff;">Évaluation de Chaque Équipement :</strong> Pour chacune des machines, on calcule : Temps = Surface / Capacité</li>
            <li><strong style="color:#fff;">Calcul du Score :</strong>
                <ul style="margin-top: 0.3rem;">
                    <li>Plage Optimale = 2 à 8 heures → Score 100%</li>
                    <li>Trop rapide (&#60; 2h) → Machine surpuissante, mauvaise rentabilité</li>
                    <li>Trop lent (&#62; 8h) → Machine sous-dimensionnée, faible productivité</li>
                </ul>
            </li>
            <li><strong style="color:#fff;">Recommandation :</strong> Les machines avec les meilleurs scores sont recommandées (vert), les acceptables en jaune, les mauvaises en rouge</li>
        </ol>
        <div style="margin-top: 1rem; background: rgba(125,191,108,0.08); border: 1px solid rgba(125,191,108,0.2); border-radius: 10px; padding: 1rem;">
            <p style="color: rgba(255,255,255,0.85); margin: 0;"><strong style="color:#7DBF6C;">Valeur Métier :</strong> L'agriculteur ne choisit pas à l'aveugle. Le système l'assiste dans sa prise de décision économique en l'alertant sur les mismatches.</p>
        </div>
    </div>

</section>
{% endblock %}
