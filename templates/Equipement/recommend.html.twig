{% extends 'base.html.twig' %}

{% block title %}Recommandations d'Équipement - {{ parcelle.nom }}{% endblock %}

{% block body %}
<div class="container mt-5">
    <h1 class="mb-4">⭐ Recommandations Intelligentes d'Équipement</h1>

    <!-- Info Parcelle -->
    <div class="card mb-4">
        <div class="card-header bg-light">
            <h5>📍 Parcelle Analysée</h5>
        </div>
        <div class="card-body">
            <div class="row">
                <div class="col-md-6">
                    <p><strong>Nom :</strong> {{ parcelle.nom }}</p>
                    <p><strong>Localisation :</strong> {{ parcelle.localisation }}</p>
                </div>
                <div class="col-md-6">
                    <p><strong>Surface :</strong> <strong style="font-size: 1.3em;">{{ parcelle.superficie }} Ha</strong></p>
                    <p><strong>Type de Sol :</strong> {{ parcelle.type_sol }}</p>
                </div>
            </div>
        </div>
    </div>

    <!-- Recommandations -->
    <div class="row">
        {% for recommendation in recommendations %}
        <div class="col-md-6 mb-4">
            <div class="card h-100 border-{% if recommendation.badgeColor == 'green' %}success{% elseif recommendation.badgeColor == 'yellow' %}warning{% else %}danger{% endif %}">
                <!-- En-tête avec Badge -->
                <div class="card-header" style="background-color: 
                    {% if recommendation.badgeColor == 'green' %}#28a745
                    {% elseif recommendation.badgeColor == 'yellow' %}#ffc107
                    {% elseif recommendation.badgeColor == 'red' %}#dc3545
                    {% else %}#6c757d{% endif %};
                    color: white;">
                    <div class="d-flex justify-content-between align-items-center">
                        <h5 class="mb-0">
                            {% if loop.index == 1 %}🥇 1er Choix{% elseif loop.index == 2 %}🥈 2e Choix{% else %}🥉 3e Choix{% endif %}
                        </h5>
                        <span class="badge bg-light text-dark" style="font-size: 1.1em;">{{ recommendation.matchScore|round(1) }}%</span>
                    </div>
                </div>

                <div class="card-body">
                    <!-- Nom et Type -->
                    <h6 class="card-title">{{ recommendation.equipement.nom }}</h6>
                    <p class="card-text text-muted">{{ recommendation.equipement.type }}</p>

                    <!-- Infos Techniques -->
                    <div class="mb-3">
                        <p class="mb-1"><strong>Capacité :</strong> {{ recommendation.equipement.capaciteRendement }} Ha/h</p>
                        <p class="mb-1"><strong>Prix :</strong> {{ recommendation.equipement.prix }} DT</p>
                        <p class="mb-1">
                            <strong>Disponibilité :</strong>
                            <span class="badge {% if recommendation.equipement.disponibilite == 'disponible' %}bg-success{% else %}bg-warning{% endif %}">
                                {{ recommendation.equipement.disponibilite }}
                            </span>
                        </p>
                    </div>

                    <!-- Résultat du Matching -->
                    <div class="mb-3 p-3" style="background-color: #f8f9fa; border-left: 4px solid 
                        {% if recommendation.badgeColor == 'green' %}#28a745
                        {% elseif recommendation.badgeColor == 'yellow' %}#ffc107
                        {% else %}#dc3545{% endif %};">
                        <p class="mb-1"><strong>⏱️ Temps Estimé :</strong> <strong>{{ recommendation.estimatedTimeHours|round(2) }} heures</strong></p>
                        <p class="mb-0"><strong>Statut :</strong>
                            {% if recommendation.recommendation == 'RECOMMENDED' %}
                            <span class="badge bg-success">✓ RECOMMANDÉ</span>
                            {% elseif recommendation.recommendation == 'ACCEPTABLE' %}
                            <span class="badge bg-warning text-dark">⚠ ACCEPTABLE</span>
                            {% else %}
                            <span class="badge bg-danger">✗ NON RECOMMANDÉ</span>
                            {% endif %}
                        </p>
                    </div>

                    <!-- Raison -->
                    <div class="alert alert-info mb-0">
                        <small>{{ recommendation.reason }}</small>
                    </div>

                    <!-- Alerte si applicable -->
                    {% if recommendation.alertMessage %}
                    <div class="alert alert-{% if recommendation.badgeColor == 'red' %}danger{% else %}warning{% endif %} mt-2 mb-0">
                        <small>{{ recommendation.alertMessage }}</small>
                    </div>
                    {% endif %}
                </div>

                <!-- Boutons d'Action -->
                <div class="card-footer bg-light">
                    <a href="{{ path('app_equipement_show', {id: recommendation.equipement.id}) }}" class="btn btn-sm btn-outline-primary">
                        👁️ Voir Détails
                    </a>
                    <a href="{{ path('app_equipement_match', {equipementId: recommendation.equipement.id, parcelleId: parcelle.id}) }}" class="btn btn-sm btn-outline-secondary">
                        🔍 Analyser
                    </a>
                </div>
            </div>
        </div>
        {% endfor %}
    </div>

    <!-- Explication pour le jury -->
    <div class="card mt-5 bg-light">
        <div class="card-header">
            <h5>🎓 Démonstration Métier Avancée</h5>
        </div>
        <div class="card-body">
            <h6>Comment Fonctionne le Matching Intelligent ?</h6>
            <ol>
                <li><strong>Analyse de la Parcelle :</strong> Surface = {{ parcelle.superficie }} Ha</li>
                <li><strong>Évaluation de Chaque Équipement :</strong> Pour chacune des machines, on calcule : Temps = Surface / Capacité</li>
                <li><strong>Calcul du Score :</strong>
                    <ul>
                        <li>Plage Optimale = 2 à 8 heures → Score 100%</li>
                        <li>Trop rapide (< 2h) → Machine surpuissante, mauvaise rentabilité</li>
                        <li>Trop lent (> 8h) → Machine sous-dimensionnée, faible productivité</li>
                    </ul>
                </li>
                <li><strong>Recommandation :</strong> Les machines avec les meilleurs scores sont recommandées (vert), les acceptables en jaune, les mauvaises en rouge</li>
            </ol>
            <p class="mt-3"><strong>Valeur Métier :</strong> L'agriculteur ne choisit pas à l'aveugle. Le système l'assiste dans sa prise de décision économique en l'alertant sur les mismatches.</p>
        </div>
    </div>

    <!-- Boutons de Navigation -->
    <div class="mt-4 mb-5">
        <a href="{{ path('app_equipement_index') }}" class="btn btn-secondary">
            ← Retour à la liste des équipements
        </a>
    </div>
</div>
{% endblock %}
