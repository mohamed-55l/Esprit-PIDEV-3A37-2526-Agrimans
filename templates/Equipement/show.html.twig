{% extends 'base.html.twig' %}

{% block title %}Détails de l'Équipement{% endblock %}

{% block body %}
    <section class="content-section" style="margin-top: 2rem;">
        <div style="max-width: 800px; margin: 0 auto; background: rgba(255,255,255,0.03); border: 1px solid rgba(255,255,255,0.08); border-radius: 16px; padding: 2.5rem;">
            
            <div style="display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 2rem;">
                <div>
                    <i class="fa-solid fa-info-circle" style="font-size: 2.5rem; color: #f1c40f; margin-bottom: 1rem;"></i>
                    <h1 style="font-size: 2rem; color: #fff;">Détails de l'Équipement</h1>
                    <p style="color: rgba(255,255,255,0.6);">Fiche technique de : <strong style="color:#fff;">{{ equipement.nom }}</strong></p>
                </div>
            </div>

            <table class="styled-table" style="margin-bottom: 2.5rem; background: rgba(255,255,255,0.02); border-radius: 12px; overflow: hidden;">
                <tbody>
                    <tr>
                        <th style="background: rgba(255,255,255,0.05); color: #fff; width: 30%;">Ref ID</th>
                        <td style="color: rgba(255,255,255,0.8);">#{{ equipement.id }}</td>
                    </tr>
                    <tr>
                        <th style="background: rgba(255,255,255,0.05); color: #fff;">Nom</th>
                        <td><strong style="color: #fff;">{{ equipement.nom }}</strong></td>
                    </tr>
                    <tr>
                        <th style="background: rgba(255,255,255,0.05); color: #fff;">Type / Catégorie</th>
                        <td style="color: rgba(255,255,255,0.8);">{{ equipement.type }}</td>
                    </tr>
                    <tr>
                        <th style="background: rgba(255,255,255,0.05); color: #fff;">Capacité</th>
                        <td style="color: rgba(255,255,255,0.8);">{{ equipement.capacite ? equipement.capacite ~ ' Ha/Heure' : 'Non définie' }}</td>
                    </tr>
                    <tr>
                        <th style="background: rgba(255,255,255,0.05); color: #fff;">Consommation</th>
                        <td style="color: rgba(255,255,255,0.8);">{{ equipement.consommation ? equipement.consommation ~ ' L/Heure' : 'Non définie' }}</td>
                    </tr>
                    <tr>
                        <th style="background: rgba(255,255,255,0.05); color: #fff;">Prix</th>
                        <td><span style="font-size:1.2rem; color: #2ecc71; font-weight: bold;">{{ equipement.prix|number_format(2, ',', ' ') }} DT</span></td>
                    </tr>
                    <tr>
                        <th style="background: rgba(255,255,255,0.05); color: #fff;">Disponibilité</th>
                        <td>
                            {% if equipement.disponibilite == 'Disponible' %}
                                <span class="badge badge-success" style="padding: 0.4rem 0.8rem; border-radius: 50px;"><i class="fa-solid fa-check-circle"></i> {{ equipement.disponibilite }}</span>
                            {% elseif equipement.disponibilite == 'Indisponible' %}
                                <span class="badge badge-danger" style="padding: 0.4rem 0.8rem; border-radius: 50px;"><i class="fa-solid fa-times-circle"></i> {{ equipement.disponibilite }}</span>
                            {% else %}
                                <span class="badge badge-warning" style="padding: 0.4rem 0.8rem; border-radius: 50px;"><i class="fa-solid fa-wrench"></i> {{ equipement.disponibilite }}</span>
                            {% endif %}
                        </td>
                    </tr>
                </tbody>
            </table>

            <div style="display: flex; gap: 1rem; align-items: center;">
                <a href="{{ path('app_equipement_index') }}" class="btn btn-secondary" style="padding: 0.8rem 1.5rem; border-radius: 8px;">Retour à la liste</a>
                <a href="{{ path('app_equipement_edit', {'id': equipement.id}) }}" class="hero-btn-primary" style="padding: 0.8rem 1.5rem; border-radius: 8px; text-decoration: none;">
                    <i class="fa-solid fa-pen"></i> Éditer
                </a>
                {{ include('equipement/_delete_form.html.twig') }}
            </div>
        </div>
    </section>
{% endblock %}
