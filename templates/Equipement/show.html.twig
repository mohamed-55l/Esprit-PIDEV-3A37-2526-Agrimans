{% extends 'base.html.twig' %}

{% block title %}Détails de l'Équipement{% endblock %}

{% block body %}
    <div style="max-width: 700px; margin: 0 auto;" class="glass-card">
        <h1>Détails : {{ equipement.nom }}</h1>

        <table class="styled-table" style="margin-bottom: 2rem;">
            <tbody>
                <tr>
                    <th>Ref ID</th>
                    <td>{{ equipement.id }}</td>
                </tr>
                <tr>
                    <th>Nom</th>
                    <td><strong>{{ equipement.nom }}</strong></td>
                </tr>
                <tr>
                    <th>Type / Catégorie</th>
                    <td>{{ equipement.type }}</td>
                </tr>
                <tr>
                    <th>Prix</th>
                    <td><span style="font-size:1.2rem; color: var(--primary-color); font-weight: bold;">{{ equipement.prix|number_format(2, ',', ' ') }} DT</span></td>
                </tr>
                <tr>
                    <th>Disponibilité</th>
                    <td>
                        {% if equipement.disponibilite == 'Disponible' %}
                            <span class="badge badge-success">{{ equipement.disponibilite }}</span>
                        {% elseif equipement.disponibilite == 'Indisponible' %}
                            <span class="badge badge-danger">{{ equipement.disponibilite }}</span>
                        {% else %}
                            <span class="badge badge-warning">{{ equipement.disponibilite }}</span>
                        {% endif %}
                    </td>
                </tr>
            </tbody>
        </table>

        <div style="display: flex; gap: 1rem;">
            <a href="{{ path('app_equipement_index') }}" class="btn btn-secondary">Retour à la liste</a>
            <a href="{{ path('app_equipement_edit', {'id': equipement.id}) }}" class="btn btn-primary">Éditer</a>
            {{ include('Equipement/_delete_form.html.twig') }}
        </div>
    </div>
{% endblock %}
