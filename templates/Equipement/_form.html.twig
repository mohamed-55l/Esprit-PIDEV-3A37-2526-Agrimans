{{ form_start(form, {'attr': {'class': 'custom-form'}}) }}

    <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1.5rem;">
        <div class="form-group">
            {{ form_label(form.nom, null, {'label_attr': {'style': 'color: rgba(255,255,255,0.7); font-weight: 500;'}}) }}
            {{ form_widget(form.nom, {'attr': {'class': 'form-control', 'style': 'background: rgba(255,255,255,0.08); border: 1px solid rgba(255,255,255,0.1); color: #fff;'}}) }}
            <div style="color: #e74c3c; font-size: 0.85rem; margin-top: 0.3rem;">{{ form_errors(form.nom) }}</div>
        </div>

        <div class="form-group">
            {{ form_label(form.type, null, {'label_attr': {'style': 'color: rgba(255,255,255,0.7); font-weight: 500;'}}) }}
            {{ form_widget(form.type, {'attr': {'class': 'form-control', 'style': 'background: rgba(255,255,255,0.08); border: 1px solid rgba(255,255,255,0.1); color: #fff;'}}) }}
            <div style="color: #e74c3c; font-size: 0.85rem; margin-top: 0.3rem;">{{ form_errors(form.type) }}</div>
        </div>

        <div class="form-group">
            {{ form_label(form.prix, null, {'label_attr': {'style': 'color: rgba(255,255,255,0.7); font-weight: 500;'}}) }}
            {{ form_widget(form.prix, {'attr': {'class': 'form-control', 'style': 'background: rgba(255,255,255,0.08); border: 1px solid rgba(255,255,255,0.1); color: #fff;'}}) }}
            <div style="color: #e74c3c; font-size: 0.85rem; margin-top: 0.3rem;">{{ form_errors(form.prix) }}</div>
        </div>

        <div class="form-group">
            {{ form_label(form.disponibilite, null, {'label_attr': {'style': 'color: rgba(255,255,255,0.7); font-weight: 500;'}}) }}
            {{ form_widget(form.disponibilite, {'attr': {'class': 'form-control', 'style': 'background: rgba(255,255,255,0.08); border: 1px solid rgba(255,255,255,0.1); color: #fff;'}}) }}
            <div style="color: #e74c3c; font-size: 0.85rem; margin-top: 0.3rem;">{{ form_errors(form.disponibilite) }}</div>
        </div>

        <div class="form-group">
            {{ form_label(form.capacite, null, {'label_attr': {'style': 'color: rgba(255,255,255,0.7); font-weight: 500;'}}) }}
            {{ form_widget(form.capacite, {'attr': {'class': 'form-control', 'style': 'background: rgba(255,255,255,0.08); border: 1px solid rgba(255,255,255,0.1); color: #fff;'}}) }}
            <small style="color: rgba(255,255,255,0.5); display: block; margin-top: 5px;">{{ form_help(form.capacite) }}</small>
            <div style="color: #e74c3c; font-size: 0.85rem; margin-top: 0.3rem;">{{ form_errors(form.capacite) }}</div>
        </div>

        <div class="form-group">
            {{ form_label(form.consommation, null, {'label_attr': {'style': 'color: rgba(255,255,255,0.7); font-weight: 500;'}}) }}
            {{ form_widget(form.consommation, {'attr': {'class': 'form-control', 'style': 'background: rgba(255,255,255,0.08); border: 1px solid rgba(255,255,255,0.1); color: #fff;'}}) }}
            <small style="color: rgba(255,255,255,0.5); display: block; margin-top: 5px;">{{ form_help(form.consommation) }}</small>
            <div style="color: #e74c3c; font-size: 0.85rem; margin-top: 0.3rem;">{{ form_errors(form.consommation) }}</div>
        </div>

        {# Champ Capacité de Rendement (Ha/Heure) - utilisé pour le Matching Intelligent #}
        <div class="form-group" style="grid-column: span 2;">
            {{ form_label(form.capaciteRendement, null, {'label_attr': {'style': 'color: rgba(255,255,255,0.7); font-weight: 500;'}}) }}
            {{ form_widget(form.capaciteRendement, {'attr': {'class': 'form-control', 'style': 'background: rgba(102,126,234,0.12); border: 1px solid rgba(102,126,234,0.35); color: #fff;'}}) }}
            <small style="color: rgba(102,126,234,0.9); display: flex; align-items: center; gap: 0.4rem; margin-top: 6px; font-size: 0.82rem;">
                <i class="fa-solid fa-star" style="color: #667eea;"></i>
                {{ form_help(form.capaciteRendement) }}
            </small>
            <div style="color: #e74c3c; font-size: 0.85rem; margin-top: 0.3rem;">{{ form_errors(form.capaciteRendement) }}</div>
        </div>
    </div>

    <div style="display: flex; justify-content: flex-end; gap: 1rem; margin-top: 2.5rem;">
        <a href="{{ path('app_equipement_index') }}" class="btn btn-secondary" style="padding: 0.8rem 1.5rem; border-radius: 8px;">Annuler</a>
        <button class="hero-btn-primary" style="border: none; font-family: inherit; font-size: 1rem; cursor: pointer; padding: 0.8rem 1.5rem; border-radius: 8px;">
            <i class="fa-solid fa-save"></i> {{ button_label|default('Enregistrer') }}
        </button>
    </div>
{{ form_end(form) }}
