{{ form_start(form, {'attr': {'class': 'form-wrapper'}}) }}

    <div class="form-group">
        {{ form_label(form.nom) }}
        {{ form_widget(form.nom, {'attr': {'class': 'form-control'}}) }}
        <div style="color: #e74c3c; font-size: 0.85rem; margin-top: 0.3rem;">{{ form_errors(form.nom) }}</div>
    </div>

    <div class="form-group">
        {{ form_label(form.type) }}
        {{ form_widget(form.type, {'attr': {'class': 'form-control'}}) }}
        <div style="color: #e74c3c; font-size: 0.85rem; margin-top: 0.3rem;">{{ form_errors(form.type) }}</div>
    </div>

    <div class="form-group">
        {{ form_label(form.prix) }}
        {{ form_widget(form.prix, {'attr': {'class': 'form-control'}}) }}
        <div style="color: #e74c3c; font-size: 0.85rem; margin-top: 0.3rem;">{{ form_errors(form.prix) }}</div>
    </div>

    <div class="form-group">
        {{ form_label(form.disponibilite) }}
        {{ form_widget(form.disponibilite, {'attr': {'class': 'form-control'}}) }}
        <div style="color: #e74c3c; font-size: 0.85rem; margin-top: 0.3rem;">{{ form_errors(form.disponibilite) }}</div>
    </div>

    <button class="btn btn-primary" style="width: 100%; margin-top: 1rem;">{{ button_label|default('Enregistrer') }}</button>
{{ form_end(form) }}
