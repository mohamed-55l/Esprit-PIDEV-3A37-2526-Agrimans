<form method="post" action="{{ path('app_equipement_delete', {'id': equipement.id}) }}" onsubmit="return confirm('Êtes-vous sûr de vouloir supprimer cet équipement ?');" style="margin: 0;">
    <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ equipement.id) }}">
    <button class="btn btn-danger" style="padding: 0.7rem 1.2rem; border-radius: 8px;">
        <i class="fa-solid fa-trash"></i> Supprimer
    </button>
</form>
