{% extends 'base.html.twig' %}

{% block title %}Gestion des Ã‰quipements{% endblock %}

{% block body %}
    
    <!-- Table Section Uniquement (Panel Admin) -->
    <section class="content-section" style="margin-top: 2rem;">
        <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 2rem;">
            <div>
                <h2 style="font-size: 2rem; margin-bottom: 0.5rem;">Panel des Ã‰quipements</h2>
                <p style="color: rgba(255,255,255,0.7);">GÃ©rez, assignez et surveillez l'Ã©tat de votre parc matÃ©riel.</p>
            </div>
            <a href="{{ path('app_equipement_new') }}" class="hero-btn-primary" style="font-size: 0.9rem;">
                + Ajouter Ã‰quipement
            </a>
        </div>

        <!-- Section de Statistiques Ã‰quipement -->
        <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 1.5rem; margin-bottom: 2rem;">
            <div style="background: rgba(125, 191, 108, 0.1); border: 1px solid rgba(125, 191, 108, 0.3); padding: 1.5rem; border-radius: 16px; text-align: center;">
                <h3 style="font-size: 1rem; color: rgba(255,255,255,0.7); margin-bottom: 0.5rem;">Total Ã‰quipements</h3>
                <div style="font-size: 2.5rem; font-weight: 800; color: var(--light-green);">{{ statistics.total|default(0) }}</div>
            </div>
            {% for dispo, count in statistics.repartition|default([]) %}
            <div style="background: rgba(255, 255, 255, 0.05); border: 1px solid rgba(255, 255, 255, 0.1); padding: 1.5rem; border-radius: 16px; text-align: center;">
                <h3 style="font-size: 1rem; color: rgba(255,255,255,0.7); margin-bottom: 0.5rem;">{{ dispo }}</h3>
                <div style="font-size: 2.5rem; font-weight: 800; color: var(--white);">{{ count }}</div>
            </div>
            {% endfor %}
        </div>

        <!-- Barre de Recherche et Tri -->
        <div style="background: rgba(255,255,255,0.03); border: 1px solid rgba(255,255,255,0.08); border-radius: 16px; padding: 1.5rem; margin-bottom: 2rem;">
            <form method="get" action="{{ path('app_equipement_index') }}" style="display: flex; gap: 1rem; flex-wrap: wrap; align-items: flex-end;">
                <div style="flex-grow: 1; min-width: 250px;">
                    <label style="display: block; font-size: 0.85rem; color: rgba(255,255,255,0.6); margin-bottom: 0.4rem;">Recherche (Nom ou Type)</label>
                    <input type="text" name="q" value="{{ currentQuery|default('') }}" class="form-control" placeholder="Tracteur, Moissonneuse..." style="width: 100%;">
                </div>
                <div>
                    <label style="display: block; font-size: 0.85rem; color: rgba(255,255,255,0.6); margin-bottom: 0.4rem;">Trier par</label>
                    <select name="sort" class="form-control">
                        <option value="nom" {% if currentSort|default('nom') == 'nom' %}selected{% endif %}>Nom</option>
                        <option value="prix" {% if currentSort|default('nom') == 'prix' %}selected{% endif %}>Prix</option>
                        <option value="type" {% if currentSort|default('nom') == 'type' %}selected{% endif %}>CatÃ©gorie</option>
                        <option value="disponibilite" {% if currentSort|default('nom') == 'disponibilite' %}selected{% endif %}>DisponibilitÃ©</option>
                    </select>
                </div>
                <div>
                    <label style="display: block; font-size: 0.85rem; color: rgba(255,255,255,0.6); margin-bottom: 0.4rem;">Ordre</label>
                    <select name="order" class="form-control">
                        <option value="ASC" {% if currentOrder|default('ASC') == 'ASC' %}selected{% endif %}>Ascendant</option>
                        <option value="DESC" {% if currentOrder|default('ASC') == 'DESC' %}selected{% endif %}>Descendant</option>
                    </select>
                </div>
                <div>
                    <button type="submit" class="hero-btn-primary" style="padding: 0.8rem 1.5rem; font-size: 0.95rem; display: flex; align-items: center; gap: 8px;">
                        <i class="fa-solid fa-search"></i> Appliquer
                    </button>
                </div>
                {% if currentQuery|default('') != '' or currentSort|default('nom') != 'nom' %}
                <div>
                    <a href="{{ path('app_equipement_index') }}" class="btn btn-danger" style="padding: 0.8rem 1.5rem;"><i class="fa-solid fa-times"></i> RÃ©initialiser</a>
                </div>
                {% endif %}
            </form>
        </div>        <div class="table-wrapper">
            <table class="styled-table">
                <thead>
                    <tr>
                        <th>Nom de la Machine</th>
                        <th>CatÃ©gorie</th>
                        <th>Valeur Dinar</th>
                        <th>Statut Logiciel</th>
                        <th>Actions Rapides</th>
                    </tr>
                </thead>
                <tbody>
                {% for equipement in equipements %}
                    <tr>
                        <td><strong>{{ equipement.nom }}</strong></td>
                        <td>{{ equipement.type }}</td>
                        <td style="font-weight: 600;">{{ equipement.prix|number_format(2, ',', ' ') }} DT</td>
                        <td>
                            {% if equipement.disponibilite == 'Disponible' %}
                                <span class="badge badge-success"><i class="fa-solid fa-check-circle"></i> {{ equipement.disponibilite }}</span>
                            {% elseif equipement.disponibilite == 'Indisponible' %}
                                <span class="badge badge-danger"><i class="fa-solid fa-times-circle"></i> {{ equipement.disponibilite }}</span>
                            {% else %}
                                <span class="badge badge-warning"><i class="fa-solid fa-wrench"></i> {{ equipement.disponibilite }}</span>
                            {% endif %}
                        </td>
                        <td style="display:flex; justify-content: flex-end;">
                            <a href="{{ path('app_equipement_show', {'id': equipement.id}) }}" class="btn btn-secondary" title="DÃ©tails"><i class="fa-solid fa-eye"></i></a>
                            <a href="{{ path('app_equipement_edit', {'id': equipement.id}) }}" class="btn btn-primary" style="margin-left: 0.5rem;" title="Ã‰diter"><i class="fa-solid fa-pen"></i></a>
                            <a href="{{ path('app_review_new', {'eq_id': equipement.id}) }}" class="btn" style="background-color: #f1c40f; color: #1C2D21; margin-left: 0.5rem;" title="Ajouter un avis"><i class="fa-solid fa-star"></i></a>
                        </td>
                    </tr>
                {% else %}
                    <tr>
                        <td colspan="6" style="text-align: center; padding: 3rem; color: rgba(255,255,255,0.6);">
                            <i class="fa-solid fa-box-open" style="font-size: 3rem; margin-bottom: 1rem; opacity: 0.5;"></i><br>
                            Aucun Ã©quipement enregistrÃ© pour le moment.
                        </td>
                    </tr>
                {% endfor %}
                </tbody>
            </table>
        </div>
    </section>
{% endblock %}
