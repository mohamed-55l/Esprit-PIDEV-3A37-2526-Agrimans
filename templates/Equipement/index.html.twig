{% extends 'base.html.twig' %}

{% block title %}Gestion des Équipements{% endblock %}

{% block body %}
    
    <!-- Table Section Uniquement (Panel Admin) -->
    <section class="content-section" style="margin-top: 2rem;">
        <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 2rem;">
            <div>
                <h2 style="font-size: 2rem; margin-bottom: 0.5rem;">Panel des Équipements</h2>
                <p style="color: rgba(255,255,255,0.7);">Gérez, assignez et surveillez l'état de votre parc matériel.</p>
            </div>
            <a href="{{ path('app_equipement_new') }}" class="hero-btn-primary" style="font-size: 0.9rem;">
                + Ajouter Équipement
            </a>
        </div>

        <div class="table-wrapper">
            <table class="styled-table">
                <thead>
                    <tr>
                        <th>ID / Réf</th>
                        <th>Nom de la Machine</th>
                        <th>Catégorie</th>
                        <th>Valeur Dinar</th>
                        <th>Statut Logiciel</th>
                        <th>Actions Rapides</th>
                    </tr>
                </thead>
                <tbody>
                {% for equipement in equipements %}
                    <tr>
                        <td style="color: rgba(255,255,255,0.5);">#{{ equipement.id }}</td>
                        <td><strong>{{ equipement.nom }}</strong></td>
                        <td>{{ equipement.type }}</td>
                        <td style="font-weight: 600;">{{ equipement.prix|number_format(2, ',', ' ') }} DT</td>
                        <td>
                            {% if equipement.disponibilite == 'Disponible' %}
                                <span class="badge badge-success"><i class="fa-solid fa-check-circle"></i> {{ equipement.disponibilite }}</span>
                            {% elseif equipement.disponibilite == 'Indisponible' %}
                                <span class="badge badge-danger"><i class="fa-solid fa-times-circle"></i> {{ equipement.disponibilite }}</span>
                            {% else %}
                                <span class="badge badge-warning"><i class="fa-solid fa-wrench"></i> {{ equipement.disponibilite }}</span>
                            {% endif %}
                        </td>
                        <td style="display:flex; justify-content: flex-end;">
                            <a href="{{ path('app_equipement_show', {'id': equipement.id}) }}" class="btn btn-secondary" title="Détails"><i class="fa-solid fa-eye"></i></a>
                            <a href="{{ path('app_equipement_edit', {'id': equipement.id}) }}" class="btn btn-primary" style="margin-left: 0.5rem;" title="Éditer"><i class="fa-solid fa-pen"></i></a>
                            <a href="{{ path('app_review_new', {'eq_id': equipement.id}) }}" class="btn" style="background-color: #f1c40f; color: #1C2D21; margin-left: 0.5rem;" title="Ajouter un avis"><i class="fa-solid fa-star"></i></a>
                        </td>
                    </tr>
                {% else %}
                    <tr>
                        <td colspan="6" style="text-align: center; padding: 3rem; color: rgba(255,255,255,0.6);">
                            <i class="fa-solid fa-box-open" style="font-size: 3rem; margin-bottom: 1rem; opacity: 0.5;"></i><br>
                            Aucun équipement enregistré pour le moment.
                        </td>
                    </tr>
                {% endfor %}
                </tbody>
            </table>
        </div>
    </section>
{% endblock %}
