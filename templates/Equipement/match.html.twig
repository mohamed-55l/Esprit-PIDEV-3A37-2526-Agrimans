{% extends 'base.html.twig' %}

{% block title %}Matching Équipement - {{ equipement.nom }}{% endblock %}

{% block body %}
<div class="container mt-5">
    <div class="row">
        <div class="col-md-8">
            <h1 class="mb-4">🔍 Analyse de Matching Intelligent</h1>

            <!-- Card Équipement -->
            <div class="card mb-4">
                <div class="card-header bg-light">
                    <h5>Équipement Sélectionné</h5>
                </div>
                <div class="card-body">
                    <div class="row">
                        <div class="col-md-6">
                            <p><strong>Nom :</strong> {{ equipement.nom }}</p>
                            <p><strong>Type :</strong> {{ equipement.type }}</p>
                            <p><strong>Prix :</strong> {{ equipement.prix }} DT</p>
                        </div>
                        <div class="col-md-6">
                            <p><strong>Disponibilité :</strong> 
                                <span class="badge {% if equipement.disponibilite == 'disponible' %}bg-success{% else %}bg-warning{% endif %}">
                                    {{ equipement.disponibilite }}
                                </span>
                            </p>
                            <p><strong>Capacité de Rendement :</strong> 
                                <strong>{{ equipement.capaciteRendement }} Ha/heure</strong>
                            </p>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Card Parcelle -->
            <div class="card mb-4">
                <div class="card-header bg-light">
                    <h5>Parcelle Cible</h5>
                </div>
                <div class="card-body">
                    <div class="row">
                        <div class="col-md-6">
                            <p><strong>Nom :</strong> {{ parcelle.nom }}</p>
                            <p><strong>Localisation :</strong> {{ parcelle.localisation }}</p>
                        </div>
                        <div class="col-md-6">
                            <p><strong>Surface :</strong> <strong>{{ parcelle.superficie }} Ha</strong></p>
                            <p><strong>Type de Sol :</strong> {{ parcelle.type_sol }}</p>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Résultat du Matching -->
            <div class="card mb-4">
                <div class="card-header bg-light">
                    <h5>📊 Résultat du Matching</h5>
                </div>
                <div class="card-body">
                    <!-- Badge de Score -->
                    <div class="mb-4 text-center">
                        <div class="badge rounded-pill" 
                             style="background-color: 
                                {% if matchResult.badgeColor == 'green' %}#28a745
                                {% elseif matchResult.badgeColor == 'yellow' %}#ffc107
                                {% elseif matchResult.badgeColor == 'red' %}#dc3545
                                {% else %}#6c757d{% endif %};
                                font-size: 2rem; padding: 20px;">
                            {{ matchResult.recommendation }}
                        </div>
                        <h2 class="mt-3">{{ matchResult.matchScore|round(1) }}%</h2>
                    </div>

                    <!-- Détails du Calcul -->
                    <div class="row mb-4">
                        <div class="col-md-6">
                            <p><strong>⏱️ Temps Estimé :</strong> <strong>{{ matchResult.estimatedTimeHours|round(2) }} heures</strong></p>
                        </div>
                        <div class="col-md-6">
                            <p><strong>📈 Score de Matching :</strong> <strong>{{ matchResult.matchScore|round(1) }}%</strong></p>
                        </div>
                    </div>

                    <!-- Raison du Matching -->
                    <div class="alert alert-info">
                        <strong>ℹ️ Explication :</strong>
                        {{ matchResult.reason }}
                    </div>

                    <!-- Alerte si applicable -->
                    {% if matchResult.alertMessage %}
                    <div class="alert alert-warning">
                        {{ matchResult.alertMessage }}
                    </div>
                    {% endif %}

                    <!-- Recommandation Finale -->
                    <div class="alert {% if matchResult.badgeColor == 'green' %}alert-success{% elseif matchResult.badgeColor == 'yellow' %}alert-warning{% else %}alert-danger{% endif %}">
                        <strong>
                            {% if matchResult.recommendation == 'RECOMMENDED' %}
                            ✓ Cet équipement est RECOMMANDÉ pour cette parcelle
                            {% elseif matchResult.recommendation == 'ACCEPTABLE' %}
                            ⚠ Cet équipement est ACCEPTABLE pour cette parcelle
                            {% else %}
                            ✗ Cet équipement n'est PAS RECOMMANDÉ pour cette parcelle
                            {% endif %}
                        </strong>
                    </div>
                </div>
            </div>

            <!-- Explication pour le jury -->
            <div class="card bg-light">
                <div class="card-header">
                    <h5>🎓 Démonstration Métier (Pour la Soutenance)</h5>
                </div>
                <div class="card-body">
                    <p><strong>Scénario :</strong></p>
                    <ul>
                        <li>Parcelle de <strong>{{ parcelle.superficie }} Ha</strong></li>
                        <li>Équipement : <strong>{{ equipement.nom }}</strong> ({{ equipement.capaciteRendement }} Ha/h)</li>
                    </ul>
                    <p><strong>Calcul :</strong></p>
                    <p>Temps = Surface / Capacité = {{ parcelle.superficie }} / {{ equipement.capaciteRendement }} = <strong>{{ matchResult.estimatedTimeHours|round(2) }} heures</strong></p>
                    <p><strong>Interprétation :</strong></p>
                    <p>{{ matchResult.reason }}</p>
                </div>
            </div>
        </div>

        <!-- Sidebar Actions -->
        <div class="col-md-4">
            <div class="card">
                <div class="card-header bg-primary text-white">
                    Actions
                </div>
                <div class="list-group list-group-flush">
                    <a href="{{ path('app_equipement_index') }}" class="list-group-item list-group-item-action">
                        ← Retour à la liste
                    </a>
                    <a href="{{ path('app_equipement_show', {id: equipement.id}) }}" class="list-group-item list-group-item-action">
                        👁️ Voir l'équipement
                    </a>
                    <a href="{{ path('app_equipement_recommend', {parcelleId: parcelle.id}) }}" class="list-group-item list-group-item-action">
                        ⭐ Voir les recommandations
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}
