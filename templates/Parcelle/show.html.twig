{% extends 'base.html.twig' %}

{% block title %}Détails de la Parcelle | Agrimans{% endblock %}

{% block body %}
<div class="content-section" style="max-width: 800px; margin: 2rem auto;">
    <div class="page-header" style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 2rem;">
        <div>
            <a href="{{ path('app_parcelle_index') }}" style="color: rgba(255,255,255,0.5); text-decoration: none; font-size: 0.9rem; margin-bottom: 10px; display: inline-block;">
                <i class="fa-solid fa-arrow-left"></i> Retour à la liste
            </a>
            <h1 style="font-size: 2.2rem; font-weight: 700; color: #fff; margin-bottom: 0.5rem;"><i class="fa-solid fa-map" style="color: var(--primary); margin-right: 10px;"></i> {{ parcelle.nom }}</h1>
        </div>
        <div class="page-actions" style="display: flex; gap: 1rem;">
            <a href="{{ path('app_parcelle_edit', {'id': parcelle.id}) }}" class="btn" style="background: rgba(52, 152, 219, 0.2); color: #3498db; padding: 0.6rem 1.2rem; border-radius: 8px; text-decoration: none; font-weight: 600;">
                <i class="fa-solid fa-pen"></i> Modifier
            </a>
        </div>
    </div>

    <div style="background: rgba(255,255,255,0.03); border: 1px solid rgba(255,255,255,0.08); border-radius: 12px; padding: 2rem; margin-bottom: 2rem;">
        <h3 style="color: var(--primary); margin-bottom: 1.5rem; font-size: 1.2rem;"><i class="fa-solid fa-circle-info"></i> Informations Générales</h3>
        
        <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 2rem;">
            <div>
                <p style="color: rgba(255,255,255,0.5); font-size: 0.85rem; text-transform: uppercase; margin-bottom: 0.2rem;">Nom de la parcelle</p>
                <p style="font-size: 1.1rem; font-weight: 500; color: #fff;">{{ parcelle.nom }}</p>
            </div>
            <div>
                <p style="color: rgba(255,255,255,0.5); font-size: 0.85rem; text-transform: uppercase; margin-bottom: 0.2rem;">Superficie</p>
                <p style="font-size: 1.1rem; font-weight: 500; color: #fff;">{{ parcelle.superficie }} hectares</p>
            </div>
            <div>
                <p style="color: rgba(255,255,255,0.5); font-size: 0.85rem; text-transform: uppercase; margin-bottom: 0.2rem;">Type de Sol</p>
                <p style="font-size: 1.1rem; font-weight: 500; color: #fff;">
                    <span style="background: rgba(255,255,255,0.1); padding: 4px 12px; border-radius: 20px; font-size: 0.9rem;">{{ parcelle.type_sol }}</span>
                </p>
            </div>
            <div>
                <p style="color: rgba(255,255,255,0.5); font-size: 0.85rem; text-transform: uppercase; margin-bottom: 0.2rem;">Localisation</p>
                <p style="font-size: 1.1rem; font-weight: 500; color: #fff;">
                    <i class="fa-solid fa-location-dot" style="color: var(--primary); margin-right: 5px;"></i> {{ parcelle.localisation }}
                </p>
            </div>
        </div>

        <div style="margin-top: 2rem; padding-top: 2rem; border-top: 1px solid rgba(255,255,255,0.1);">
            <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 2rem;">
                <div>
                    <p style="color: rgba(255,255,255,0.5); font-size: 0.85rem; text-transform: uppercase; margin-bottom: 0.2rem;">Coordonnées GPS</p>
                    <p style="font-size: 1.1rem; font-weight: 500; color: #fff; display: flex; align-items: center; gap: 10px;">
                        <i class="fa-solid fa-satellite" style="color: rgba(255,255,255,0.4);"></i>
                        {{ parcelle.latitude }}, {{ parcelle.longitude }}
                    </p>
                </div>
                <div>
                    <p style="color: rgba(255,255,255,0.5); font-size: 0.85rem; text-transform: uppercase; margin-bottom: 0.2rem;">Propriétaire / Utilisateur</p>
                    <p style="font-size: 1.1rem; font-weight: 500; color: #fff; display: flex; align-items: center; gap: 10px;">
                        <i class="fa-solid fa-user" style="color: var(--primary);"></i>
                        {{ parcelle.user ? parcelle.user.email : 'Non assigné' }}
                    </p>
                </div>
            </div>
            
            {# Carte Leaflet #}
            {% if parcelle.latitude and parcelle.longitude %}
                <div style="margin-top: 2rem;">
                    <p style="color: rgba(255,255,255,0.5); font-size: 0.85rem; text-transform: uppercase; margin-bottom: 0.5rem;">Visualisation sur la carte</p>
                    <div id="map" style="height: 300px; border-radius: 12px; border: 1px solid rgba(255,255,255,0.1); z-index: 1;"></div>
                </div>
            {% else %}
                <div style="margin-top: 2rem; background: rgba(255,255,255,0.05); padding: 1.5rem; border-radius: 12px; text-align: center; color: rgba(255,255,255,0.5);">
                    <i class="fa-solid fa-map-location-dot" style="font-size: 2rem; margin-bottom: 0.5rem; opacity: 0.5;"></i>
                    <p style="margin: 0;">Aucune coordonnée GPS renseignée pour cette parcelle.</p>
                </div>
            {% endif %}
        </div>
    </div>

    <div style="display: flex; justify-content: flex-end;">
        <div style="background: rgba(231, 76, 60, 0.1); border: 1px solid rgba(231, 76, 60, 0.2); border-radius: 12px; padding: 1.5rem; display: flex; align-items: center; justify-content: space-between; width: 100%;">
            <div>
                <h4 style="color: #e74c3c; margin: 0 0 0.5rem 0;">Zone de danger</h4>
                <p style="color: rgba(255,255,255,0.6); margin: 0; font-size: 0.9rem;">La suppression d'une parcelle est irréversible.</p>
            </div>
            {{ include('parcelle/_delete_form.html.twig') }}
        </div>
    </div>
</div>

{% block javascripts %}
    {% if parcelle.latitude and parcelle.longitude %}
        <script>
            function initMap() {
                var parcelleLocation = { lat: {{ parcelle.latitude }}, lng: {{ parcelle.longitude }} };
                
                var map = new google.maps.Map(document.getElementById('map'), {
                    zoom: 14,
                    center: parcelleLocation,
                    mapTypeId: 'satellite' // Affichage satellite stylé par défaut pour l'agriculture
                });

                var marker = new google.maps.Marker({
                    position: parcelleLocation,
                    map: map,
                    title: "{{ parcelle.nom }}"
                });

                var infowindow = new google.maps.InfoWindow({
                    content: "<b>{{ parcelle.nom }}</b><br>{{ parcelle.localisation }}"
                });

                marker.addListener('click', function() {
                    infowindow.open(map, marker);
                });
                // Ouvrir par défaut
                infowindow.open(map, marker);
            }
        </script>
        <script async defer src="https://maps.googleapis.com/maps/api/js?key=AIzaSyDnah4CRHAH0TZvd1OewUBULi3RMWlqL0w&callback=initMap"></script>
    {% endif %}
{% endblock %}
{% endblock %}
