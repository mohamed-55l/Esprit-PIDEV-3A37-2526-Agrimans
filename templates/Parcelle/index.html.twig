{% extends 'base.html.twig' %}

{% block title %}Parcelle index{% endblock %}

{% block body %}
    <div class="content-section">
        <div class="page-header">
            <h1>Liste des parcelles</h1>
            <div class="page-actions">
                <a href="{{ path('app_parcelle_new') }}" class="btn btn-primary">Ajouter parcelle</a>
            </div>
        </div>

        <div class="table-responsive">
            <table class="table">
                <thead>
                    <tr>
                <th>Id</th>
                <th>Nom</th>
                <th>Superficie</th>
                <th>Localisation</th>
                <th>Type_sol</th>
                <th>Latitude</th>
                <th>Longitude</th>
                <th>Utilisateur</th>
                <th>actions</th>
            </tr>
        </thead>
        <tbody>
        {% for parcelle in parcelles %}
            <tr>
                <td>{{ parcelle.id }}</td>
                <td>{{ parcelle.nom }}</td>
                <td>{{ parcelle.superficie }}</td>
                <td>{{ parcelle.localisation }}</td>
                <td>{{ parcelle.type_sol }}</td>
                <td>{{ parcelle.latitude }}</td>
                <td>{{ parcelle.longitude }}</td>
                <td>{{ parcelle.user ? parcelle.user.email : '' }}</td>
                <td>
                    <a href="{{ path('app_parcelle_show', {'id': parcelle.id}) }}" class="btn btn-secondary">Voir</a>
                    <a href="{{ path('app_parcelle_edit', {'id': parcelle.id}) }}" class="btn btn-primary">Modifier</a>
                    <form method="post" action="{{ path('app_parcelle_delete', {'id': parcelle.id}) }}" style="display:inline-block; margin:0;" onsubmit="return confirm('Supprimer cette parcelle ?');">
                        <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ parcelle.id) }}">
                        <button class="btn btn-danger">Supprimer</button>
                    </form>
                </td>
            </tr>
        {% else %}
            <tr>
                <td colspan="9">no records found</td>
            </tr>
        {% endfor %}
        </tbody>
    </table>
        </div>
    </div>
{% endblock %}