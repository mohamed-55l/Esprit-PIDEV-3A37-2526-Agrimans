{% extends 'base.html.twig' %}

{% block title %}Culture index{% endblock %}

{% block body %}
    <div class="content-section">
        <div class="page-header">
            <div>
                <h1>Liste des cultures</h1>
                {% if search is not empty %}
                    <p style="color: rgba(255,255,255,0.7); margin-top:0.5rem;">Résultats pour « {{ search }} »</p>
                {% endif %}
            </div>
            <div class="page-actions">
                <form method="get" action="{{ path('app_culture_index') }}" style="display:flex; gap:0.5rem; align-items:center;">
                    <input type="search" name="search" value="{{ search }}" placeholder="Recherche culture..." class="form-control" style="width:220px;" />
                    <button type="submit" class="btn btn-secondary">Rechercher</button>
                </form>
                <a href="{{ path('app_culture_new') }}" class="btn btn-primary">Ajouter culture</a>
            </div>
        </div>

        <div class="table-responsive">
            <table class="table">
                <thead>
            <tr>
                <th>Nom</th>
                <th>Type_culture</th>
                <th>Date_plantation</th>
                <th>Date_recolte_prevue</th>
                <th>Etat_culture</th>
                <th>Parcelle</th>
                <th>actions</th>
            </tr>
        </thead>
        <tbody>
        {% for culture in cultures %}
            <tr>
                <td>{{ culture.nom }}</td>
                <td>{{ culture.type_culture }}</td>
                <td>{{ culture.date_plantation ? culture.date_plantation|date('Y-m-d') : '' }}</td>
                <td>{{ culture.date_recolte_prevue ? culture.date_recolte_prevue|date('Y-m-d') : '' }}</td>
                <td>{{ culture.etat_culture }}</td>
                <td>{{ culture.parcelle ? culture.parcelle.nom : '' }}</td>
                <td>
                    <a href="{{ path('app_culture_show', {'id': culture.id}) }}" class="btn btn-secondary">Voir</a>
                    <a href="{{ path('app_culture_edit', {'id': culture.id}) }}" class="btn btn-primary">Modifier</a>
                    <form method="post" action="{{ path('app_culture_delete', {'id': culture.id}) }}" style="display:inline-block; margin:0;" onsubmit="return confirm('Supprimer cette culture ?');">
                        <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ culture.id) }}">
                        <button class="btn btn-danger">Supprimer</button>
                    </form>
                </td>
            </tr>
        {% else %}
            <tr>
                <td colspan="8">no records found</td>
            </tr>
        {% endfor %}
        </tbody>
    </table>
        </div>
    </div>
{% endblock %}