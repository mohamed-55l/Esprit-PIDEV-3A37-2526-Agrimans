{% extends 'base.html.twig' %}

{% block title %}Détails de l'Animal | Agrimans{% endblock %}

{% block body %}
<div class="content-section" style="max-width: 800px; margin: 2rem auto;">
    <div class="page-header" style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 2rem;">
        <div>
            <a href="{{ path('waad_animal_index') }}" style="color: rgba(255,255,255,0.5); text-decoration: none; font-size: 0.9rem; margin-bottom: 10px; display: inline-block;">
                <i class="fa-solid fa-arrow-left"></i> Retour à la liste
            </a>
            <h1 style="font-size: 2.2rem; font-weight: 700; color: #fff; margin-bottom: 0.5rem;"><i class="fa-solid fa-paw" style="color: #f39c12; margin-right: 10px;"></i> {{ animal.nom }}</h1>
        </div>
    </div>

    <div style="background: rgba(255,255,255,0.03); border: 1px solid rgba(255,255,255,0.08); border-radius: 12px; padding: 2rem; margin-bottom: 2rem;">
        <h3 style="color: #f39c12; margin-bottom: 1.5rem; font-size: 1.2rem;"><i class="fa-solid fa-circle-info"></i> Informations de l'Animal</h3>
        
        <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 2rem;">
            <div>
                <p style="color: rgba(255,255,255,0.5); font-size: 0.85rem; text-transform: uppercase; margin-bottom: 0.2rem;">Espèce</p>
                <p style="font-size: 1.1rem; font-weight: 500; color: #fff;">{{ animal.espece }}</p>
            </div>
            <div>
                <p style="color: rgba(255,255,255,0.5); font-size: 0.85rem; text-transform: uppercase; margin-bottom: 0.2rem;">Sexe</p>
                <p style="font-size: 1.1rem; font-weight: 500; color: #fff;">{{ animal.sexe }}</p>
            </div>
            <div>
                <p style="color: rgba(255,255,255,0.5); font-size: 0.85rem; text-transform: uppercase; margin-bottom: 0.2rem;">Etat de santé</p>
                <p style="font-size: 1.1rem; font-weight: 500; color: #fff;">{{ animal.etatSante }}</p>
            </div>
            <div>
                <p style="color: rgba(255,255,255,0.5); font-size: 0.85rem; text-transform: uppercase; margin-bottom: 0.2rem;">Poids</p>
                <p style="font-size: 1.1rem; font-weight: 500; color: #fff;">{{ animal.poids }} kg</p>
            </div>
            <div>
                <p style="color: rgba(255,255,255,0.5); font-size: 0.85rem; text-transform: uppercase; margin-bottom: 0.2rem;">Date de naissance</p>
                <p style="font-size: 1.1rem; font-weight: 500; color: #fff;">{{ animal.dateNaissance ? animal.dateNaissance|date('d/m/Y') : '' }}</p>
            </div>
        </div>
    </div>
    
    <div style="background: rgba(255,255,255,0.03); border: 1px solid rgba(255,255,255,0.08); border-radius: 12px; padding: 2rem; margin-bottom: 2rem;">
        <h3 style="color: #3498db; margin-bottom: 1.5rem; font-size: 1.2rem;"><i class="fa-solid fa-pen"></i> Editer les informations</h3>
        
        <style>
            .animal-form label { display: block; margin-bottom: 0.5rem; color: rgba(255,255,255,0.8); }
            .animal-form input, .animal-form select { width: 100%; margin-bottom: 1rem; background: rgba(255,255,255,0.05); border: 1px solid rgba(255,255,255,0.1); color: #fff; padding: 0.8rem; border-radius: 8px; }
            .animal-form button { margin-top: 1rem; width: 100%; }
        </style>
        <div class="animal-form">
            {{ form_start(editForm) }}
            {{ form_widget(editForm) }}
            <button class="btn btn-primary" type="submit" style="background-color: var(--primary); border: none; padding: 0.8rem; border-radius: 8px; color: #fff; cursor: pointer; font-weight: 600;">Mettre à jour l'animal</button>
            {{ form_end(editForm) }}
        </div>
    </div>
</div>
{% endblock %}
