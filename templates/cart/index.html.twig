{% extends 'base.html.twig' %}

{% block title %}Mon Panier{% endblock %}

{% block body %}
    <section class="content-section" style="margin-top: 2rem;">
        <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 2rem;">
            <div>
                <h2 style="font-size: 2rem; margin-bottom: 0.5rem;"><i class="fa-solid fa-cart-shopping"></i> Mon Panier</h2>
                <p style="color: rgba(255,255,255,0.7);">{{ items|length }} article(s) dans votre panier.</p>
            </div>
            <a href="{{ path('app_marketplace_index') }}" class="btn btn-secondary">
                <i class="fa-solid fa-arrow-left"></i> Continuer les achats
            </a>
        </div>

        {# Flash messages #}
        {% for type, messages in app.flashes %}
            {% for message in messages %}
                <div style="padding: 1rem; margin-bottom: 1rem; border-radius: 8px; background: {{ type == 'success' ? 'rgba(125, 191, 108, 0.2)' : 'rgba(231, 76, 60, 0.2)' }}; border: 1px solid {{ type == 'success' ? '#7DBF6C' : '#e74c3c' }};">
                    <i class="fa-solid {{ type == 'success' ? 'fa-check-circle' : 'fa-exclamation-circle' }}"></i> {{ message }}
                </div>
            {% endfor %}
        {% endfor %}

        {% if items|length > 0 %}
            <div class="table-wrapper">
                <table class="styled-table">
                    <thead>
                        <tr>
                            <th>Produit</th>
                            <th>CatÃ©gorie</th>
                            <th>Prix unitaire</th>
                            <th>QuantitÃ© (kg)</th>
                            <th>Sous-total</th>
                            <th>Action</th>
                        </tr>
                    </thead>
                    <tbody>
                    {% for item in items %}
                        <tr>
                            <td>
                                <strong>
                                    {% if item.isBundle %}
                                        <a href="{{ path('app_marketplace_bundle_show', {'id': item.bundle.id}) }}" style="color: inherit; text-decoration: none;">
                                            <i class="fa-solid fa-gift" style="color: #198B61; margin-right: 5px;"></i>
                                            {{ item.bundle.name }}
                                        </a>
                                    {% else %}
                                        <a href="{{ path('app_marketplace_product_show', {'id': item.product.id}) }}" style="color: inherit; text-decoration: none;">
                                            {{ item.product.name }}
                                        </a>
                                    {% endif %}
                                </strong>
                            </td>
                            <td>
                                {% if item.isBundle %}
                                    <span class="badge badge-success"><i class="fa-solid fa-box-open"></i> Pack Promo</span>
                                {% else %}
                                    <span class="badge {{ item.product.category == 'VEGETABLES' ? 'badge-success' : (item.product.category == 'FRUITS' ? 'badge-warning' : 'badge-primary') }}">
                                        <i class="fa-solid {{ item.product.categoryIcon }}"></i> {{ item.product.category }}
                                    </span>
                                {% endif %}
                            </td>
                            <td>{{ item.isBundle ? item.bundle.bundlePrice|number_format(2, ',', ' ') : item.product.price|number_format(2, ',', ' ') }} DT</td>
                            <td>{{ item.quantity }} {{ item.isBundle ? 'pack(s)' : 'kg' }}</td>
                            <td style="font-weight: 600; color: var(--primary-color);">{{ item.lineTotal|number_format(2, ',', ' ') }} DT</td>
                            <td>
                                <form method="post" action="{{ path('app_marketplace_cart_remove', {'id': item.id}) }}" style="display: inline;">
                                    <input type="hidden" name="_token" value="{{ csrf_token('remove' ~ item.id) }}">
                                    <button class="btn" style="background: rgba(231,76,60,0.2); color: #e74c3c; border: 1px solid #e74c3c;" title="Retirer">
                                        <i class="fa-solid fa-trash"></i>
                                    </button>
                                </form>
                            </td>
                        </tr>
                    {% endfor %}
                    </tbody>
                    <tfoot>
                        <tr>
                            <td colspan="4" style="text-align: right; font-size: 1.2rem; font-weight: bold;">TOTAL :</td>
                            <td colspan="2" style="font-size: 1.3rem; font-weight: bold; color: var(--primary-color);">{{ total|number_format(2, ',', ' ') }} DT</td>
                        </tr>
                    </tfoot>
                </table>
            </div>

            <div style="display: flex; justify-content: flex-end; gap: 1rem; margin-top: 1.5rem; flex-wrap: wrap;">
                <form method="post" action="{{ path('app_marketplace_cart_clear') }}" onsubmit="return confirm('Vider tout le panier ?');">
                    <button class="btn btn-secondary" style="border-color: #e74c3c; color: #e74c3c;">
                        <i class="fa-solid fa-trash-can"></i> Vider le panier
                    </button>
                </form>
                <a href="{{ path('app_marketplace_invoice_download') }}" class="btn btn-secondary" style="border-color: #3498db; color: #3498db;">
                    <i class="fa-solid fa-file-pdf"></i> Télécharger la facture
                </a>
                <form method="post" action="{{ path('app_marketplace_cart_checkout') }}">
                    <button class="hero-btn-primary" style="font-size: 1rem; padding: 0.8rem 2rem;">
                        <i class="fa-solid fa-credit-card"></i> Payer ({{ total|number_format(2, ',', ' ') }} DT)
                    </button>
                </form>
            </div>
        {% else %}
            <div class="glass-card" style="text-align: center; padding: 4rem;">
                <i class="fa-solid fa-cart-shopping" style="font-size: 4rem; opacity: 0.3; margin-bottom: 1rem;"></i>
                <h3 style="color: rgba(255,255,255,0.6);">Votre panier est vide</h3>
                <p style="color: rgba(255,255,255,0.4); margin-bottom: 1.5rem;">Explorez notre marketplace pour trouver des produits frais !</p>
                <a href="{{ path('app_marketplace_index') }}" class="hero-btn-primary">
                    <i class="fa-solid fa-store"></i> Explorer la Boutique
                </a>
            </div>
        {% endif %}
    </section>
{% endblock %}
