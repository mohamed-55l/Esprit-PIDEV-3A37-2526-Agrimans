{% extends 'base.html.twig' %}

{% block title %}Mes Équipements | Agrimans{% endblock %}

{% block body %}
<!-- Chart.js -->
<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

<!-- Leaflet CSS & JS -->
<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" integrity="sha256-p4NxAoJBhIIN+hmNHrzRCf9tD/miZyoHS5obTRR9BMY=" crossorigin=""/>
<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js" integrity="sha256-20nQCchB9co0qIjJZRGuk2/Z9VM+kNiyxNV1lvTlZBo=" crossorigin=""></script>

<section class="content-section" style="margin-top: 2rem;">

    <div style="display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 2.5rem; flex-wrap: wrap; gap: 1rem;">
        <div>
            <h1 style="font-size: 2rem; font-weight: 800; margin-bottom: 0.5rem;">
                <i class="fa-solid fa-tractor" style="color: var(--light-green); margin-right: 10px;"></i>Mes Équipements
            </h1>
            <p style="color: rgba(255,255,255,0.6);">
                Équipements qui vous ont été assignés. Vous pouvez laisser un avis sur chacun d'eux.
            </p>
        </div>
        <div style="display: flex; gap: 10px;">
            <a href="{{ path('user_equipement_request') }}" class="hero-btn-primary" style="font-size: 0.9rem; background: #3498db; border-color: #3498db; box-shadow: 0 4px 15px rgba(52, 152, 219, 0.4);">
                <i class="fa-solid fa-paper-plane"></i> Demander un équipement
            </a>
            <a href="{{ path('user_review_index') }}" class="hero-btn-primary" style="font-size: 0.9rem;">
                <i class="fa-solid fa-star"></i> Voir mes Avis
            </a>
        </div>
    </div>

    <!-- RECHERCHE ET STATISTIQUES -->
    <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 2rem; margin-bottom: 2.5rem;">
        <!-- Barre de recherche -->
        <div style="background: rgba(255,255,255,0.02); border: 1px solid rgba(255,255,255,0.08); border-radius: 15px; padding: 1.5rem;">
            <h3 style="margin-bottom: 1rem; font-size: 1.1rem;"><i class="fa-solid fa-search" style="color: var(--light-green);"></i> Rechercher un équipement</h3>
            <form action="{{ path('user_equipement_index') }}" method="get" style="display: flex; gap: 10px;">
                <input type="text" name="q" value="{{ currentQuery|default('') }}" placeholder="Ex: Tracteur, Drone..." style="flex: 1; padding: 10px 15px; background: rgba(0,0,0,0.2); border: 1px solid rgba(255,255,255,0.1); border-radius: 8px; color: white;">
                <button type="submit" class="hero-btn-primary" style="padding: 10px 20px;"><i class="fa-solid fa-filter"></i> Filtrer</button>
                {% if currentQuery is defined and currentQuery is not empty %}
                    <a href="{{ path('user_equipement_index') }}" class="hero-btn-secondary" style="padding: 10px 15px; text-decoration: none;"><i class="fa-solid fa-xmark"></i></a>
                {% endif %}
            </form>
        </div>

        <!-- Graphique -->
        <div style="background: rgba(255,255,255,0.02); border: 1px solid rgba(255,255,255,0.08); border-radius: 15px; padding: 1.5rem;">
            <h3 style="margin-bottom: 1rem; font-size: 1.1rem;"><i class="fa-solid fa-chart-pie" style="color: #f1c40f;"></i> Disponibilité de mes équipements</h3>
            <div style="height: 200px; display: flex; justify-content: center;">
                {% if equipements is not empty %}
                    <canvas id="userEquipChart"></canvas>
                {% else %}
                    <p style="color: rgba(255,255,255,0.5); align-self: center;">Aucune donnée à afficher</p>
                {% endif %}
            </div>
        </div>
    </div>

    <!-- CARTE DES GARAGES (LOCALISATION DES ÉQUIPEMENTS) -->
    <div style="background: rgba(255,255,255,0.02); border: 1px solid rgba(255,255,255,0.08); border-radius: 15px; padding: 1.5rem; margin-bottom: 2.5rem;">
        <h3 style="margin-bottom: 1rem; font-size: 1.2rem;">
            <i class="fa-solid fa-map-location-dot" style="color: #3498db; margin-right: 10px;"></i> Localisation des Garages d'Équipements
        </h3>
        <p style="color: rgba(255,255,255,0.6); margin-bottom: 1.5rem; font-size: 0.9rem;">Trouvez où se situent les garages pour récupérer ou déposer vos équipements.</p>
        <div id="garagesMap" style="height: 400px; width: 100%; border-radius: 12px; border: 1px solid rgba(255,255,255,0.1); z-index: 1;"></div>
    </div>

    {% for msg in app.flashes('success') %}
        <div style="padding: 0.9rem 1.2rem; background: rgba(46,204,113,0.1); border: 1px solid rgba(46,204,113,0.3); border-radius: 10px; margin-bottom: 1.5rem; color: #2ecc71; font-size: 0.9rem;">
            <i class="fa-solid fa-check-circle"></i> {{ msg }}
        </div>
    {% endfor %}

    {% if equipements is empty %}
        <div style="text-align: center; padding: 5rem 2rem; background: rgba(255,255,255,0.03); border: 1px solid rgba(255,255,255,0.08); border-radius: 20px;">
            <i class="fa-solid fa-tractor" style="font-size: 4rem; opacity: 0.2; margin-bottom: 1.5rem; display: block;"></i>
            <h3 style="font-size: 1.3rem; margin-bottom: 0.5rem;">Aucun équipement assigné</h3>
            <p style="color: rgba(255,255,255,0.5); font-size: 0.9rem;">Aucun équipement ne vous a encore été assigné par l'administration.</p>
        </div>
    {% else %}
        <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(320px, 1fr)); gap: 1.5rem;">
            {% for eq in equipements %}
            <div style="background: rgba(255,255,255,0.04); border: 1px solid rgba(255,255,255,0.1); border-radius: 18px; padding: 1.5rem; transition: transform 0.25s, border-color 0.25s; position: relative; overflow: hidden;">
                <!-- Status ribbon -->
                <div style="position: absolute; top: 0; right: 0;">
                    {% if eq.disponibilite == 'Disponible' %}
                        <div style="background: rgba(46,204,113,0.9); color: white; font-size: 0.72rem; font-weight: 700; padding: 4px 12px; border-bottom-left-radius: 10px;">DISPONIBLE</div>
                    {% elseif eq.disponibilite == 'Indisponible' %}
                        <div style="background: rgba(231,76,60,0.9); color: white; font-size: 0.72rem; font-weight: 700; padding: 4px 12px; border-bottom-left-radius: 10px;">INDISPONIBLE</div>
                    {% else %}
                        <div style="background: rgba(241,196,15,0.9); color: #1a1a1a; font-size: 0.72rem; font-weight: 700; padding: 4px 12px; border-bottom-left-radius: 10px;">{{ eq.disponibilite|upper }}</div>
                    {% endif %}
                </div>

                <!-- Icon -->
                <div style="width: 52px; height: 52px; background: rgba(125,191,108,0.12); border-radius: 14px; display: flex; align-items: center; justify-content: center; margin-bottom: 1rem;">
                    <i class="fa-solid fa-tractor" style="font-size: 1.4rem; color: var(--light-green);"></i>
                </div>

                <h3 style="font-size: 1.15rem; font-weight: 700; margin-bottom: 0.3rem;">{{ eq.nom }}</h3>
                <p style="font-size: 0.85rem; color: rgba(255,255,255,0.5); margin-bottom: 1rem;">{{ eq.type }}</p>

                <div style="display: flex; align-items: center; justify-content: space-between; border-top: 1px solid rgba(255,255,255,0.07); padding-top: 1rem; margin-top: 0.5rem;">
                    <div>
                        <div style="font-size: 0.75rem; color: rgba(255,255,255,0.4); margin-bottom: 2px;">Valeur</div>
                        <div style="font-size: 1.1rem; font-weight: 700; color: var(--light-green);">{{ eq.prix|number_format(2, ',', ' ') }} DT</div>
                    </div>
                    <a href="{{ path('user_review_new', {eq_id: eq.id}) }}"
                       style="display: inline-flex; align-items: center; gap: 6px; background: rgba(241,196,15,0.12); border: 1px solid rgba(241,196,15,0.3); color: #f1c40f; padding: 0.5rem 1rem; border-radius: 8px; text-decoration: none; font-size: 0.85rem; font-weight: 600; transition: all 0.2s;"
                       onmouseover="this.style.background='rgba(241,196,15,0.2)'" onmouseout="this.style.background='rgba(241,196,15,0.12)'">
                        <i class="fa-solid fa-star"></i> Laisser un Avis
                    </a>
                </div>
            </div>
            {% endfor %}
        </div>
    {% endif %}

</section>

<!-- CHATBOT UI -->
<style>
    /* Chatbot Bubble */
    #chatbot-bubble {
        position: fixed;
        bottom: 30px;
        right: 30px;
        width: 60px;
        height: 60px;
        background: var(--light-green, #2ecc71);
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        box-shadow: 0 5px 15px rgba(46, 204, 113, 0.4);
        cursor: pointer;
        z-index: 1000;
        transition: transform 0.3s;
    }
    #chatbot-bubble:hover {
        transform: scale(1.1);
    }
    #chatbot-bubble i {
        color: white;
        font-size: 1.8rem;
    }

    /* Chatbot Window */
    #chatbot-window {
        position: fixed;
        bottom: 100px;
        right: 30px;
        width: 350px;
        height: 450px;
        background: #1e2529;
        border: 1px solid rgba(255,255,255,0.1);
        border-radius: 15px;
        display: none;
        flex-direction: column;
        box-shadow: 0 10px 30px rgba(0,0,0,0.5);
        z-index: 1000;
        overflow: hidden;
        animation: slideUp 0.3s ease-out;
    }

    @keyframes slideUp {
        from { opacity: 0; transform: translateY(20px); }
        to { opacity: 1; transform: translateY(0); }
    }

    #chatbot-header {
        background: rgba(46, 204, 113, 0.15);
        padding: 15px;
        display: flex;
        justify-content: space-between;
        align-items: center;
        border-bottom: 1px solid rgba(255,255,255,0.05);
    }
    #chatbot-header h3 {
        margin: 0;
        font-size: 1.1rem;
        color: #2ecc71;
        display: flex;
        align-items: center;
        gap: 8px;
    }
    #close-chatbot {
        background: none;
        border: none;
        color: rgba(255,255,255,0.5);
        font-size: 1.2rem;
        cursor: pointer;
    }
    #close-chatbot:hover { color: white; }

    #chatbot-messages {
        flex: 1;
        padding: 15px;
        overflow-y: auto;
        display: flex;
        flex-direction: column;
        gap: 10px;
        background: rgba(0,0,0,0.2);
    }

    .msg { max-width: 85%; padding: 10px 14px; border-radius: 12px; font-size: 0.9rem; line-height: 1.4; }
    .msg-bot { background: rgba(255,255,255,0.05); color: #ddd; border-bottom-left-radius: 0; align-self: flex-start; }
    .msg-user { background: rgba(46, 204, 113, 0.2); color: white; border-bottom-right-radius: 0; align-self: flex-end; }
    .msg-bot strong { color: #2ecc71; }

    #chatbot-input-container {
        padding: 10px;
        display: flex;
        gap: 8px;
        background: #1e2529;
        border-top: 1px solid rgba(255,255,255,0.05);
    }
    #chatbot-input {
        flex: 1;
        padding: 10px 15px;
        background: rgba(0,0,0,0.3);
        border: 1px solid rgba(255,255,255,0.1);
        border-radius: 20px;
        color: white;
        outline: none;
        font-family: inherit;
    }
    #chatbot-send {
        background: #2ecc71;
        color: white;
        border: none;
        width: 40px;
        height: 40px;
        border-radius: 50%;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
    }
    #chatbot-send:hover { background: #27ae60; }
</style>

<div id="chatbot-bubble">
    <i class="fa-solid fa-robot"></i>
</div>

<div id="chatbot-window">
    <div id="chatbot-header">
        <h3><i class="fa-solid fa-seedling"></i> AgriBot</h3>
        <button id="close-chatbot"><i class="fa-solid fa-times"></i></button>
    </div>
    <div id="chatbot-messages">
        <div class="msg msg-bot">Bonjour ! Je suis AgriBot 🤖. Posez-moi vos questions sur les tracteurs, moissonneuses, capteurs ou l'irrigation !</div>
    </div>
    <div id="chatbot-input-container">
        <input type="text" id="chatbot-input" placeholder="Écrivez votre question..." autocomplete="off">
        <button id="chatbot-send"><i class="fa-solid fa-paper-plane"></i></button>
    </div>
</div>

<script>
    document.addEventListener("DOMContentLoaded", function() {
        const bubble = document.getElementById('chatbot-bubble');
        const windowChat = document.getElementById('chatbot-window');
        const closeBtn = document.getElementById('close-chatbot');
        const sendBtn = document.getElementById('chatbot-send');
        const input = document.getElementById('chatbot-input');
        const messages = document.getElementById('chatbot-messages');

        // Toggle window
        bubble.addEventListener('click', () => {
            windowChat.style.display = windowChat.style.display === 'flex' ? 'none' : 'flex';
            if (windowChat.style.display === 'flex') input.focus();
        });

        closeBtn.addEventListener('click', () => {
            windowChat.style.display = 'none';
        });

        // Add message to UI
        function addMessage(text, sender) {
            const div = document.createElement('div');
            div.className = `msg msg-${sender}`;
            // Simple markdown parser for bold text
            div.innerHTML = text.replace(/\*\*(.*?)\*\*/g, '<strong>$1</strong>');
            messages.appendChild(div);
            messages.scrollTop = messages.scrollHeight;
        }

        // Handle send
        function sendMessage() {
            const text = input.value.trim();
            if (!text) return;

            addMessage(text, 'user');
            input.value = '';

            // Loading indicator
            const loadingId = 'loading-' + Date.now();
            const loadingDiv = document.createElement('div');
            loadingDiv.className = 'msg msg-bot';
            loadingDiv.id = loadingId;
            loadingDiv.innerHTML = '<i class="fa-solid fa-ellipsis fa-fade"></i>';
            messages.appendChild(loadingDiv);
            messages.scrollTop = messages.scrollHeight;

            // AJAX Call to backend
            fetch('{{ path("user_chatbot_ask") }}', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ message: text })
            })
            .then(res => res.json())
            .then(data => {
                document.getElementById(loadingId).remove();
                addMessage(data.reply, 'bot');
            })
            .catch(err => {
                document.getElementById(loadingId).remove();
                addMessage("Erreur de connexion avec l'assistant.", 'bot');
            });
        }

        sendBtn.addEventListener('click', sendMessage);
        input.addEventListener('keypress', (e) => {
            if (e.key === 'Enter') sendMessage();
        });
    });

    // Chart.js Init for Equipements
    {% if equipements is not empty %}
    document.addEventListener("DOMContentLoaded", function() {
        const equipCtx = document.getElementById('userEquipChart');
        if (equipCtx) {
            new Chart(equipCtx.getContext('2d'), {
                type: 'pie',
                data: {{ chartEquipement.createView().data|json_encode|raw }},
                options: {{ chartEquipement.createView().options|json_encode|raw }}
            });
        }
    });
    {% endif %}

    // Leaflet Map Init
    document.addEventListener("DOMContentLoaded", function() {
        const mapContainer = document.getElementById('garagesMap');
        if (!mapContainer) return;

        // Centre par défaut (ex: Tunis)
        var map = L.map('garagesMap').setView([36.8065, 10.1815], 7);

        // Ajouter la couche de tuiles OpenStreetMap
        L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
            attribution: '&copy; <a href="https://www.openstreetmap.org/copyright">OpenStreetMap</a> contributors'
        }).addTo(map);

        // Ajouter les marqueurs pour chaque garage
        var garages = [
            {% for garage in garages %}
                {% if garage.latitude and garage.longitude %}
                    {% set mes_eq_in_garage = [] %}
                    {% for eq in garage.equipements %}
                        {% if eq in equipements %}
                            {% set mes_eq_in_garage = mes_eq_in_garage|merge([eq.nom]) %}
                        {% endif %}
                    {% endfor %}
                    {
                        id: {{ garage.id }},
                        nom: "{{ garage.nom|escape('js') }}",
                        adresse: "{{ garage.adresse|escape('js') }}",
                        telephone: "{{ garage.telephone|escape('js') }}",
                        capacite: "{{ garage.capacite }}",
                        mesEquipements: {{ mes_eq_in_garage|json_encode|raw }},
                        lat: {{ garage.latitude|number_format(6, '.', '') }},
                        lng: {{ garage.longitude|number_format(6, '.', '') }}
                    },
                {% endif %}
            {% endfor %}
        ];

        var bounds = [];
        garages.forEach(function(garage) {
            var marker = L.marker([garage.lat, garage.lng]).addTo(map);
            
            var eqHtml = '';
            if (garage.mesEquipements && garage.mesEquipements.length > 0) {
                eqHtml = '<p style="margin: 10px 0 5px 0; font-size: 13px; color: #198B61; font-weight: bold;">Vos équipements ici :</p><ul style="margin: 0; padding-left: 20px; font-size: 13px; color: #333;">';
                garage.mesEquipements.forEach(function(eqName) {
                    eqHtml += '<li>' + eqName + '</li>';
                });
                eqHtml += '</ul>';
            } else {
                eqHtml = '<p style="margin: 10px 0 0 0; font-size: 12px; color: #7f8c8d; font-style: italic;">Aucun de vos équipements ici.</p>';
            }

            var popupContent = `
                <div style="color: #333; font-family: 'Inter', sans-serif; min-width: 220px;">
                    <h4 style="margin: 0 0 5px 0; color: #2C3E50; font-weight: 700;">${garage.nom}</h4>
                    <p style="margin: 0 0 5px 0; font-size: 13px;"><strong>Adresse:</strong> ${garage.adresse || 'Non précisée'}</p>
                    <p style="margin: 0 0 5px 0; font-size: 13px;"><strong>Tél:</strong> ${garage.telephone || 'Non précisé'}</p>
                    ${eqHtml}
                    <!-- Div for Weather Info -->
                    <div id="weather-garage-${garage.id}" style="margin-top: 10px; font-size: 12px; color: #7f8c8d;">
                        <i class="fa-solid fa-cloud"></i> Charger la météo locale...
                    </div>
                </div>
            `;
            marker.bindPopup(popupContent);
            bounds.push([garage.lat, garage.lng]);

            // Event listener to fetch weather when popup opens
            marker.on('popupopen', async function(e) {
                var popup = e.popup;
                if (popup._weatherFetched) return;
                
                // Use a slight delay to ensure the popup DOM is fully inserted
                setTimeout(async () => {
                    var weatherDiv = document.getElementById('weather-garage-' + garage.id);
                    if (weatherDiv) {
                        weatherDiv.innerHTML = '<i class="fa-solid fa-spinner fa-spin"></i> Récupération météo...';
                        try {
                            const response = await fetch(`https://api.open-meteo.com/v1/forecast?latitude=${garage.lat}&longitude=${garage.lng}&current_weather=true`);
                            const data = await response.json();
                            const weather = data.current_weather;
                            
                            let icon = 'fa-sun';
                            let color = '#f1c40f';
                            let impactHtml = '';
                            
                            if (weather.weathercode >= 61 && weather.weathercode <= 65) {
                                icon = 'fa-cloud-rain'; color = '#3498db';
                                impactHtml = '<div style="margin-top:5px; padding:5px; background:rgba(52,152,219,0.1); border-left:3px solid #3498db; font-size:11px; color:#2980b9;">⚠️ <strong>Pluie :</strong> Risque d\'oxydation. Évitez de sortir les équipements sensibles.</div>';
                            } else if (weather.weathercode >= 71 && weather.weathercode <= 75) {
                                icon = 'fa-snowflake'; color = '#00cec9';
                                impactHtml = '<div style="margin-top:5px; padding:5px; background:rgba(0,206,201,0.1); border-left:3px solid #00cec9; font-size:11px; color:#01a3a4;">❄️ <strong>Neige :</strong> Protégez les moteurs contre le gel.</div>';
                            } else if (weather.weathercode >= 95) {
                                icon = 'fa-bolt'; color = '#8e44ad';
                                impactHtml = '<div style="margin-top:5px; padding:5px; background:rgba(142,68,173,0.1); border-left:3px solid #8e44ad; font-size:11px; color:#8e44ad;">⚡ <strong>Orage :</strong> Débranchez les équipements électriques de la zone.</div>';
                            } else if (weather.temperature > 35) {
                                icon = 'fa-temperature-high'; color = '#e74c3c';
                                impactHtml = '<div style="margin-top:5px; padding:5px; background:rgba(231,76,60,0.1); border-left:3px solid #e74c3c; font-size:11px; color:#c0392b;">🔥 <strong>Chaleur extrême :</strong> Risque de surchauffe. Assurez la ventilation du garage.</div>';
                            } else {
                                icon = 'fa-cloud-sun'; color = '#f39c12';
                                impactHtml = '<div style="margin-top:5px; padding:5px; background:rgba(46,204,113,0.1); border-left:3px solid #2ecc71; font-size:11px; color:#27ae60;">✅ Conditions météo optimales pour le stockage.</div>';
                            }

                            weatherDiv.innerHTML = `
                                <div style="display:flex; align-items:center; gap:8px; margin-top:8px; padding-top:8px; border-top:1px solid #eee;">
                                    <i class="fa-solid ${icon}" style="font-size:1.4rem; color:${color};"></i>
                                    <div>
                                        <strong style="font-size:14px; color:#2c3e50;">${weather.temperature}°C</strong>
                                        <div style="font-size:11px; color:#7f8c8d;">Vent: ${weather.windspeed} km/h</div>
                                    </div>
                                </div>
                                ${impactHtml}
                            `;
                            popup._weatherFetched = true;
                        } catch (err) {
                            weatherDiv.innerHTML = '<span style="color:#e74c3c; font-size:11px;">❌ Erreur météo</span>';
                        }
                    }
                }, 100);
            });
        }); // <-- Fermeture du forEach ajoutée ici

        // Ajuster le zoom pour montrer tous les marqueurs s'il y en a
        if (bounds.length > 0) {
            map.fitBounds(bounds, { padding: [50, 50] });
        }
    });
</script>
{% endblock %}
