{% extends 'base.html.twig' %}

{% block title %}Mes Équipements | Agrimans{% endblock %}

{% block body %}
<section class="content-section" style="margin-top: 2rem;">

    <div style="display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 2.5rem; flex-wrap: wrap; gap: 1rem;">
        <div>
            <h1 style="font-size: 2rem; font-weight: 800; margin-bottom: 0.5rem;">
                <i class="fa-solid fa-tractor" style="color: var(--light-green); margin-right: 10px;"></i>Mes Équipements
            </h1>
            <p style="color: rgba(255,255,255,0.6);">
                Équipements qui vous ont été assignés. Vous pouvez laisser un avis sur chacun d'eux.
            </p>
        </div>
        <a href="{{ path('user_review_index') }}" class="hero-btn-primary" style="font-size: 0.9rem;">
            <i class="fa-solid fa-star"></i> Voir mes Avis
        </a>
    </div>

    {% for msg in app.flashes('success') %}
        <div style="padding: 0.9rem 1.2rem; background: rgba(46,204,113,0.1); border: 1px solid rgba(46,204,113,0.3); border-radius: 10px; margin-bottom: 1.5rem; color: #2ecc71; font-size: 0.9rem;">
            <i class="fa-solid fa-check-circle"></i> {{ msg }}
        </div>
    {% endfor %}

    {% if equipements is empty %}
        <div style="text-align: center; padding: 5rem 2rem; background: rgba(255,255,255,0.03); border: 1px solid rgba(255,255,255,0.08); border-radius: 20px;">
            <i class="fa-solid fa-tractor" style="font-size: 4rem; opacity: 0.2; margin-bottom: 1.5rem; display: block;"></i>
            <h3 style="font-size: 1.3rem; margin-bottom: 0.5rem;">Aucun équipement assigné</h3>
            <p style="color: rgba(255,255,255,0.5); font-size: 0.9rem;">Aucun équipement ne vous a encore été assigné par l'administration.</p>
        </div>
    {% else %}
        <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(320px, 1fr)); gap: 1.5rem;">
            {% for eq in equipements %}
            <div style="background: rgba(255,255,255,0.04); border: 1px solid rgba(255,255,255,0.1); border-radius: 18px; padding: 1.5rem; transition: transform 0.25s, border-color 0.25s; position: relative; overflow: hidden;">
                <!-- Status ribbon -->
                <div style="position: absolute; top: 0; right: 0;">
                    {% if eq.disponibilite == 'Disponible' %}
                        <div style="background: rgba(46,204,113,0.9); color: white; font-size: 0.72rem; font-weight: 700; padding: 4px 12px; border-bottom-left-radius: 10px;">DISPONIBLE</div>
                    {% elseif eq.disponibilite == 'Indisponible' %}
                        <div style="background: rgba(231,76,60,0.9); color: white; font-size: 0.72rem; font-weight: 700; padding: 4px 12px; border-bottom-left-radius: 10px;">INDISPONIBLE</div>
                    {% else %}
                        <div style="background: rgba(241,196,15,0.9); color: #1a1a1a; font-size: 0.72rem; font-weight: 700; padding: 4px 12px; border-bottom-left-radius: 10px;">{{ eq.disponibilite|upper }}</div>
                    {% endif %}
                </div>

                <!-- Icon -->
                <div style="width: 52px; height: 52px; background: rgba(125,191,108,0.12); border-radius: 14px; display: flex; align-items: center; justify-content: center; margin-bottom: 1rem;">
                    <i class="fa-solid fa-tractor" style="font-size: 1.4rem; color: var(--light-green);"></i>
                </div>

                <h3 style="font-size: 1.15rem; font-weight: 700; margin-bottom: 0.3rem;">{{ eq.nom }}</h3>
                <p style="font-size: 0.85rem; color: rgba(255,255,255,0.5); margin-bottom: 1rem;">{{ eq.type }}</p>

                <div style="display: flex; align-items: center; justify-content: space-between; border-top: 1px solid rgba(255,255,255,0.07); padding-top: 1rem; margin-top: 0.5rem;">
                    <div>
                        <div style="font-size: 0.75rem; color: rgba(255,255,255,0.4); margin-bottom: 2px;">Valeur</div>
                        <div style="font-size: 1.1rem; font-weight: 700; color: var(--light-green);">{{ eq.prix|number_format(2, ',', ' ') }} DT</div>
                    </div>
                    <a href="{{ path('user_review_new', {eq_id: eq.id}) }}"
                       style="display: inline-flex; align-items: center; gap: 6px; background: rgba(241,196,15,0.12); border: 1px solid rgba(241,196,15,0.3); color: #f1c40f; padding: 0.5rem 1rem; border-radius: 8px; text-decoration: none; font-size: 0.85rem; font-weight: 600; transition: all 0.2s;"
                       onmouseover="this.style.background='rgba(241,196,15,0.2)'" onmouseout="this.style.background='rgba(241,196,15,0.12)'">
                        <i class="fa-solid fa-star"></i> Laisser un Avis
                    </a>
                </div>
            </div>
            {% endfor %}
        </div>
    {% endif %}

</section>
{% endblock %}
