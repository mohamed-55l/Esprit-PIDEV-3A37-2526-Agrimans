{% extends 'base.html.twig' %}

{% block title %}Mon Tableau de Bord | Agrimans{% endblock %}

{% block body %}
<!-- Hero Section -->
<section class="hero-section" style="margin-top: 2rem;">
    <div class="hero-content">
        <h1 class="hero-title" style="font-size: 2.8rem;">Bienvenue, {{ app.user.userIdentifier }}&nbsp;👋</h1>
        <p class="hero-subtitle">Voici un aperçu général de vos statistiques et de l'état de votre domaine Agricole.</p>
        
        <div class="hero-actions">
            <a href="{{ path('app_parcelle_index') }}" class="hero-btn-primary"><i class="fa-solid fa-map"></i> Voir mes Parcelles</a>
            <a href="{{ path('waad_animal_index') }}" class="btn btn-glow"><i class="fa-solid fa-cow"></i> Gérer mon Élevage</a>
        </div>
    </div>
</section>

<!-- Statistiques Globales (Features Grid Style) -->
<section style="margin-top: 4rem;">
    <h2 class="section-title" style="font-size: 2rem; margin-bottom: 2rem;">Statistiques Globales</h2>
    
    <div class="features-grid">
        
        <!-- Stat: Parcelles -->
        <div class="feature-card visible" style="transform:translateY(0); opacity:1;">
            <div class="feature-icon-wrapper">
                <i class="feature-icon fa-solid fa-map-location-dot"></i>
                <h3 class="feature-title">Mes Parcelles</h3>
            </div>
            <div style="font-size: 3rem; font-weight: 800; color: var(--light-green); display: flex; align-items: baseline; gap: 10px;">
                {{ stats.total_parcelles }} <span style="font-size: 1rem; color: rgba(255,255,255,0.6); font-weight: 500;">terrains enregistrés</span>
            </div>
            <a href="{{ path('app_parcelle_index') }}" class="feature-link">Gérer <i class="fa-solid fa-arrow-right" style="margin-left: 5px; font-size:0.8rem;"></i></a>
        </div>

        <!-- Stat: Cultures -->
        <div class="feature-card visible" style="transform:translateY(0); opacity:1;">
            <div class="feature-icon-wrapper">
                <i class="feature-icon fa-solid fa-seedling"></i>
                <h3 class="feature-title">Cultures Actives</h3>
            </div>
            <div style="font-size: 3rem; font-weight: 800; color: var(--light-green); display: flex; align-items: baseline; gap: 10px;">
                {{ stats.total_cultures }} <span style="font-size: 1rem; color: rgba(255,255,255,0.6); font-weight: 500;">en croissance</span>
            </div>
            <a href="{{ path('app_culture_index') }}" class="feature-link">Suivi <i class="fa-solid fa-arrow-right" style="margin-left: 5px; font-size:0.8rem;"></i></a>
        </div>

        <!-- Stat: Animaux -->
        <div class="feature-card visible" style="transform:translateY(0); opacity:1;">
            <div class="feature-icon-wrapper">
                <i class="feature-icon fa-solid fa-cow"></i>
                <h3 class="feature-title">Cheptel Animal</h3>
            </div>
            <div style="font-size: 3rem; font-weight: 800; color: var(--light-green); display: flex; align-items: baseline; gap: 10px;">
                {{ stats.total_animaux }} <span style="font-size: 1rem; color: rgba(255,255,255,0.6); font-weight: 500;">animaux suivis</span>
            </div>
            <a href="{{ path('waad_animal_index') }}" class="feature-link">Détails <i class="fa-solid fa-arrow-right" style="margin-left: 5px; font-size:0.8rem;"></i></a>
        </div>

        <!-- Stat: Commandes / Boutique -->
        <div class="feature-card visible" style="transform:translateY(0); opacity:1;">
            <div class="feature-icon-wrapper">
                <i class="feature-icon fa-solid fa-bag-shopping"></i>
                <h3 class="feature-title">Achats en cours</h3>
            </div>
            <div style="font-size: 3rem; font-weight: 800; color: var(--light-green); display: flex; align-items: baseline; gap: 10px;">
                {{ stats.commandes_en_cours }} <span style="font-size: 1rem; color: rgba(255,255,255,0.6); font-weight: 500;">commandes actives</span>
            </div>
            <a href="{{ path('app_marketplace_index') }}" class="feature-link">Marketplace <i class="fa-solid fa-arrow-right" style="margin-left: 5px; font-size:0.8rem;"></i></a>
        </div>

    </div>
</section>

<!-- Section Alertes / Opportunités (Exemple visuel supplémentaire) -->
<section class="content-section" style="margin-top: 3rem;">
    <h3 style="margin-bottom: 1.5rem;"><i class="fa-solid fa-bell" style="color: #f1c40f;"></i> Activité & Alertes Récentes</h3>
    {% if stats.alertes > 0 %}
        <div style="padding: 1rem; background: rgba(241, 196, 15, 0.1); border-left: 4px solid #f1c40f; border-radius: 8px;">
            Vous avez <strong>{{ stats.alertes }}</strong> alerte(s) à consulter concernant vos cultures ou la santé des animaux.
        </div>
    {% else %}
        <div style="padding: 1rem; background: rgba(125, 191, 108, 0.1); border-left: 4px solid var(--light-green); border-radius: 8px; color: var(--white);">
            <i class="fa-solid fa-check-circle" style="color: var(--light-green); margin-right: 5px;"></i> Tout fonctionne parfaitement ! Aucune alerte n'est à signaler pour le moment.
        </div>
    {% endif %}
</section>
{% endblock %}
