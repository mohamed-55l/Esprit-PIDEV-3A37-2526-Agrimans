{% extends 'base.html.twig' %}

{% block title %}Laisser un Avis | Agrimans{% endblock %}

{% block body %}
<section class="content-section" style="margin-top: 2rem; max-width: 680px; margin-left: auto; margin-right: auto;">

    <div style="margin-bottom: 2rem;">
        <a href="{{ path('user_equipement_index') }}" style="color: rgba(255,255,255,0.4); text-decoration: none; font-size: 0.85rem; display: inline-flex; align-items: center; gap: 6px;">
            <i class="fa-solid fa-arrow-left"></i> Retour à mes équipements
        </a>
    </div>

    <h1 style="font-size: 2rem; font-weight: 800; margin-bottom: 0.5rem;">
        <i class="fa-solid fa-star" style="color: #f1c40f; margin-right: 10px;"></i>Laisser un Avis
    </h1>

    {% if equipement %}
        <div style="background: rgba(125,191,108,0.08); border: 1px solid rgba(125,191,108,0.2); border-radius: 12px; padding: 1rem 1.2rem; margin-bottom: 2rem; display: flex; align-items: center; gap: 12px;">
            <i class="fa-solid fa-tractor" style="color: var(--light-green); font-size: 1.2rem;"></i>
            <div>
                <div style="font-size: 0.75rem; color: rgba(255,255,255,0.4); text-transform: uppercase; letter-spacing: .5px;">Équipement sélectionné</div>
                <div style="font-weight: 700; font-size: 1rem;">{{ equipement.nom }} <span style="font-weight: 400; color: rgba(255,255,255,0.5); font-size: 0.85rem;">— {{ equipement.type }}</span></div>
            </div>
        </div>
    {% else %}
        <p style="color: rgba(255,255,255,0.6); margin-bottom: 2rem;">Choisissez l'équipement sur lequel vous souhaitez laisser un avis.</p>
    {% endif %}

    <div style="background: rgba(255,255,255,0.04); border: 1px solid rgba(255,255,255,0.1); border-radius: 18px; padding: 2rem;">
        {{ form_start(form, {attr: {novalidate: 'novalidate'}}) }}

            <div style="margin-bottom: 1.5rem;">
                <label style="display: block; font-size: 0.82rem; text-transform: uppercase; letter-spacing: .5px; color: rgba(255,255,255,0.5); margin-bottom: 0.5rem;">Équipement</label>
                {{ form_widget(form.equipement) }}
                {{ form_errors(form.equipement) }}
            </div>

            <!-- Star picker -->
            <div style="margin-bottom: 1.5rem;">
                <label style="display: block; font-size: 0.82rem; text-transform: uppercase; letter-spacing: .5px; color: rgba(255,255,255,0.5); margin-bottom: 0.75rem;">Votre note</label>
                <div id="star-picker" style="display: flex; gap: 0.5rem; margin-bottom: 0.75rem;">
                    {% for i in 1..5 %}
                    <i class="fa-solid fa-star star-pick" data-val="{{ i }}"
                       style="font-size: 2rem; color: rgba(255,255,255,0.15); cursor: pointer; transition: color 0.15s;"></i>
                    {% endfor %}
                </div>
                {{ form_widget(form.note, {attr: {style: 'display:none;', id: 'note_select'}}) }}
                {{ form_errors(form.note) }}
            </div>

            <div style="margin-bottom: 1.5rem;">
                <label style="display: block; font-size: 0.82rem; text-transform: uppercase; letter-spacing: .5px; color: rgba(255,255,255,0.5); margin-bottom: 0.5rem;">Commentaire</label>
                {{ form_widget(form.commentaire, {attr: {style: 'background: rgba(0,0,0,0.3); border: 1px solid rgba(255,255,255,0.1); color: white; padding: 0.8rem 1rem; border-radius: 10px; width: 100%; resize: vertical; font-family: Inter, sans-serif; font-size: 0.92rem; outline: none;'}}) }}
                {{ form_errors(form.commentaire) }}
            </div>

            <div style="display: flex; gap: 1rem; margin-top: 1.5rem; flex-wrap: wrap;">
                <button type="submit" class="hero-btn-primary" style="font-size: 0.9rem;">
                    <i class="fa-solid fa-paper-plane"></i> Publier mon avis
                </button>
                <a href="{{ path('user_equipement_index') }}" style="display: inline-flex; align-items: center; gap: 6px; padding: 0.7rem 1.2rem; border-radius: 10px; background: rgba(255,255,255,0.05); border: 1px solid rgba(255,255,255,0.1); color: rgba(255,255,255,0.6); text-decoration: none; font-size: 0.9rem; transition: all 0.2s;">
                    <i class="fa-solid fa-times"></i> Annuler
                </a>
            </div>
        {{ form_end(form) }}
    </div>
</section>

<script>
document.addEventListener('DOMContentLoaded', function () {
    const stars = document.querySelectorAll('.star-pick');
    const select = document.getElementById('note_select');

    function paintStars(val) {
        stars.forEach(s => {
            s.style.color = parseInt(s.dataset.val) <= val ? '#f1c40f' : 'rgba(255,255,255,0.15)';
        });
    }

    // Sync initial value
    if (select && select.value) paintStars(parseInt(select.value));

    stars.forEach(star => {
        star.addEventListener('mouseover', () => paintStars(parseInt(star.dataset.val)));
        star.addEventListener('mouseleave', () => paintStars(select ? parseInt(select.value) || 0 : 0));
        star.addEventListener('click', () => {
            if (select) {
                select.value = star.dataset.val;
                paintStars(parseInt(star.dataset.val));
            }
        });
    });
});
</script>
{% endblock %}
