{% extends 'base.html.twig' %}

{% block title %}Détails de la Culture | Agrimans{% endblock %}

{% block body %}
<div class="content-section" style="max-width: 800px; margin: 2rem auto;">
    <div class="page-header" style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 2rem;">
        <div>
            <a href="{{ path('app_culture_index') }}" style="color: rgba(255,255,255,0.5); text-decoration: none; font-size: 0.9rem; margin-bottom: 10px; display: inline-block;">
                <i class="fa-solid fa-arrow-left"></i> Retour à la liste
            </a>
            <h1 style="font-size: 2.2rem; font-weight: 700; color: #fff; margin-bottom: 0.5rem;"><i class="fa-solid fa-seedling" style="color: var(--primary); margin-right: 10px;"></i> {{ culture.nom }}</h1>
        </div>
        <div class="page-actions" style="display: flex; gap: 1rem;">
            <a href="{{ path('app_culture_edit', {'id': culture.id}) }}" class="btn" style="background: rgba(52, 152, 219, 0.2); color: #3498db; padding: 0.6rem 1.2rem; border-radius: 8px; text-decoration: none; font-weight: 600;">
                <i class="fa-solid fa-pen"></i> Modifier
            </a>
        </div>
    </div>

    <div style="background: rgba(255,255,255,0.03); border: 1px solid rgba(255,255,255,0.08); border-radius: 12px; padding: 2rem; margin-bottom: 2rem;">
        <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 1.5rem;">
            <h3 style="color: var(--primary); margin: 0; font-size: 1.2rem;"><i class="fa-solid fa-circle-info"></i> Informations sur la Culture</h3>
            
            {% if culture.etat_culture|lower == 'en croissance' or culture.etat_culture|lower == 'active' %}
                <span style="background: rgba(46, 204, 113, 0.2); color: #2ecc71; padding: 6px 16px; border-radius: 20px; font-weight: 600;"><i class="fa-solid fa-leaf"></i> {{ culture.etat_culture }}</span>
            {% elseif culture.etat_culture|lower == 'recoltée' or culture.etat_culture|lower == 'récolté' %}
                <span style="background: rgba(155, 89, 182, 0.2); color: #9b59b6; padding: 6px 16px; border-radius: 20px; font-weight: 600;"><i class="fa-solid fa-check-double"></i> {{ culture.etat_culture }}</span>
            {% else %}
                <span style="background: rgba(241, 196, 15, 0.2); color: #f1c40f; padding: 6px 16px; border-radius: 20px; font-weight: 600;"><i class="fa-solid fa-clock"></i> {{ culture.etat_culture }}</span>
            {% endif %}
        </div>
        
        <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 2rem;">
            <div>
                <p style="color: rgba(255,255,255,0.5); font-size: 0.85rem; text-transform: uppercase; margin-bottom: 0.2rem;">Nom / Variété</p>
                <p style="font-size: 1.1rem; font-weight: 500; color: #fff;">{{ culture.nom }}</p>
            </div>
            <div>
                <p style="color: rgba(255,255,255,0.5); font-size: 0.85rem; text-transform: uppercase; margin-bottom: 0.2rem;">Type de culture</p>
                <p style="font-size: 1.1rem; font-weight: 500; color: #fff;">{{ culture.type_culture }}</p>
            </div>
            <div>
                <p style="color: rgba(255,255,255,0.5); font-size: 0.85rem; text-transform: uppercase; margin-bottom: 0.2rem;">Date de plantation</p>
                <p style="font-size: 1.1rem; font-weight: 500; color: #fff;">
                    <i class="fa-regular fa-calendar" style="color: rgba(255,255,255,0.4); margin-right: 5px;"></i> {{ culture.date_plantation ? culture.date_plantation|date('d F Y') : 'Non définie' }}
                </p>
            </div>
            <div>
                <p style="color: rgba(255,255,255,0.5); font-size: 0.85rem; text-transform: uppercase; margin-bottom: 0.2rem;">Date de récolte prévue</p>
                <p style="font-size: 1.1rem; font-weight: 500; color: #fff;">
                    <i class="fa-regular fa-calendar-check" style="color: rgba(255,255,255,0.4); margin-right: 5px;"></i> {{ culture.date_recolte_prevue ? culture.date_recolte_prevue|date('d F Y') : 'Non définie' }}
                </p>
            </div>
        </div>

        <div style="margin-top: 2rem; padding-top: 2rem; border-top: 1px solid rgba(255,255,255,0.1);">
            <p style="color: rgba(255,255,255,0.5); font-size: 0.85rem; text-transform: uppercase; margin-bottom: 0.5rem;">Parcelle Assignée</p>
            {% if culture.parcelle %}
                <a href="{{ path('app_parcelle_show', {'id': culture.parcelle.id}) }}" style="display: inline-flex; align-items: center; gap: 10px; background: rgba(25, 139, 97, 0.1); padding: 1rem; border-radius: 8px; text-decoration: none; border: 1px solid rgba(25, 139, 97, 0.3); width: 100%; transition: all 0.3s;">
                    <div style="width: 40px; height: 40px; border-radius: 8px; background: var(--primary); display: flex; align-items: center; justify-content: center; color: white;">
                        <i class="fa-solid fa-map-location-dot"></i>
                    </div>
                    <div style="flex: 1;">
                        <div style="color: #fff; font-weight: 600; font-size: 1.1rem;">{{ culture.parcelle.nom }}</div>
                        <div style="color: rgba(255,255,255,0.6); font-size: 0.85rem;">{{ culture.parcelle.superficie }} ha • {{ culture.parcelle.localisation }}</div>
                    </div>
                    <i class="fa-solid fa-chevron-right" style="color: rgba(255,255,255,0.3);"></i>
                </a>
            {% else %}
                <div style="background: rgba(255,255,255,0.05); padding: 1rem; border-radius: 8px; color: rgba(255,255,255,0.5); display: flex; align-items: center; gap: 10px;">
                    <i class="fa-solid fa-circle-exclamation"></i> Aucune parcelle assignée à cette culture.
                </div>
            {% endif %}
        </div>
    </div>

    <div style="display: flex; justify-content: flex-end;">
        <div style="background: rgba(231, 76, 60, 0.1); border: 1px solid rgba(231, 76, 60, 0.2); border-radius: 12px; padding: 1.5rem; display: flex; align-items: center; justify-content: space-between; width: 100%;">
            <div>
                <h4 style="color: #e74c3c; margin: 0 0 0.5rem 0;">Zone de danger</h4>
                <p style="color: rgba(255,255,255,0.6); margin: 0; font-size: 0.9rem;">La suppression de cette culture supprimera son historique.</p>
            </div>
            {{ include('culture/_delete_form.html.twig') }}
        </div>
    </div>
</div>

<style>
    /* Hover effect for parcelle card */
    a[href*='app_parcelle_show']:hover {
        background: rgba(25, 139, 97, 0.2) !important;
        border-color: var(--primary) !important;
    }
</style>
{% endblock %}
