{{ form_start(form) }}
    <div style="color: #e74c3c; margin-bottom: 1rem;">{{ form_errors(form) }}</div>

    <div class="form-group">
        {{ form_label(form.nom) }}
        {{ form_widget(form.nom) }}
        <div style="color: #e74c3c; font-size: 0.85rem; margin-top: 0.3rem;">{{ form_errors(form.nom) }}</div>
    </div>

    <div class="form-group">
        {{ form_label(form.type_culture) }}
        {{ form_widget(form.type_culture) }}
        <div style="color: #e74c3c; font-size: 0.85rem; margin-top: 0.3rem;">{{ form_errors(form.type_culture) }}</div>
    </div>

    <div class="form-group">
        {{ form_label(form.date_plantation) }}
        {{ form_widget(form.date_plantation) }}
        <div style="color: #e74c3c; font-size: 0.85rem; margin-top: 0.3rem;">{{ form_errors(form.date_plantation) }}</div>
    </div>

    <div class="form-group">
        {{ form_label(form.date_recolte_prevue) }}
        {{ form_widget(form.date_recolte_prevue) }}
        <div style="color: #e74c3c; font-size: 0.85rem; margin-top: 0.3rem;">{{ form_errors(form.date_recolte_prevue) }}</div>
    </div>

    <div class="form-group">
        {{ form_label(form.etat_culture) }}
        {{ form_widget(form.etat_culture) }}
        <div style="color: #e74c3c; font-size: 0.85rem; margin-top: 0.3rem;">{{ form_errors(form.etat_culture) }}</div>
    </div>

    <div class="form-group">
        {{ form_label(form.parcelle) }}
        {{ form_widget(form.parcelle) }}
        <div style="color: #e74c3c; font-size: 0.85rem; margin-top: 0.3rem;">{{ form_errors(form.parcelle) }}</div>
    </div>

    <div class="form-group" style="background: rgba(52, 152, 219, 0.05); padding: 1.5rem; border-radius: 8px; border: 1px dashed rgba(52, 152, 219, 0.3);">
        <h4 style="color: #3498db; margin-top: 0; margin-bottom: 1rem;"><i class="fa-solid fa-file-pdf"></i> Document de Formation</h4>
        {{ form_label(form.infoFile) }}
        {{ form_widget(form.infoFile) }}
        <p style="color: rgba(255,255,255,0.5); font-size: 0.85rem; margin-top: 0.5rem; margin-bottom: 0;"><i class="fa-solid fa-circle-info"></i> Formats acceptés : .pdf</p>
        <div style="color: #e74c3c; font-size: 0.85rem; margin-top: 0.3rem;">{{ form_errors(form.infoFile) }}</div>
    </div>

    <button class="btn btn-primary">{{ button_label|default('Save') }}</button>
{{ form_end(form) }}
