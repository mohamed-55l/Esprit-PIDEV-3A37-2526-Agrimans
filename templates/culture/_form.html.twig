    </div>

    <div class="form-group">
        {{ form_label(form.type_culture) }}
        {{ form_widget(form.type_culture) }}
        <div style="color: #e74c3c; font-size: 0.85rem; margin-top: 0.3rem;">{{ form_errors(form.type_culture) }}</div>
    </div>

    <div class="form-group">
        {{ form_label(form.date_plantation) }}
