<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <title>Liste des animaux</title>
    <style>
        body { font-family: DejaVu Sans, sans-serif; font-size: 11px; color: #222; }
        h1 { font-size: 18px; margin-bottom: 4px; }
        .meta { color: #555; margin-bottom: 16px; }
        table { width: 100%; border-collapse: collapse; }
        th, td { border: 1px solid #ccc; padding: 6px 8px; text-align: left; }
        th { background: #f0f0f0; }
    </style>
</head>
<body>
<h1>Cheptel — export PDF</h1>
<p class="meta">Généré le {{ generatedAt|date('d/m/Y H:i') }}</p>
<table>
    <thead>
    <tr>
        <th>Nom</th>
        <th>Espèce</th>
        <th>Race</th>
        <th>Poids (kg)</th>
        <th>Santé</th>
        <th>Naissance</th>
    </tr>
    </thead>
    <tbody>
    {% for animal in animals %}
        <tr>
            <td>{{ animal.nom }}</td>
            <td>{{ animal.espece }}</td>
            <td>{{ animal.race ?? '—' }}</td>
            <td>{{ animal.poids is not null ? animal.poids|number_format(2, ',', ' ') : '—' }}</td>
            <td>{{ animal.etatSante ?? '—' }}</td>
            <td>{{ animal.dateNaissance ? animal.dateNaissance|date('d/m/Y') : '—' }}</td>
        </tr>
    {% else %}
        <tr><td colspan="6">Aucun animal actif.</td></tr>
    {% endfor %}
    </tbody>
</table>
</body>
</html>
