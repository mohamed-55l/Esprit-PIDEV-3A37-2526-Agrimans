{% extends 'base.html.twig' %}

{% block title %}Calendrier Cultural | Agrimans{% endblock %}

{% block stylesheets %}
<link href='https://cdn.jsdelivr.net/npm/fullcalendar@6.1.11/index.global.min.css' rel='stylesheet' />
<style>
    .cal-page { max-width: 1200px; margin: 2rem auto; padding: 0 1rem; }
    .cal-hero {
        background: linear-gradient(135deg, rgba(230,126,34,0.15), rgba(243,156,18,0.08));
        border: 1px solid rgba(230,126,34,0.25); border-radius: 20px;
        padding: 2.5rem; margin-bottom: 2rem;
        display: flex; align-items: center; gap: 1.2rem;
    }
    .legend-cal {
        display: flex; gap: 1.5rem; flex-wrap: wrap;
        background: rgba(255,255,255,0.03); border-radius: 12px;
        padding: 1rem 1.5rem; margin-bottom: 1.5rem; align-items: center;
    }
    .legend-dot-cal {
        width: 14px; height: 14px; border-radius: 4px; display: inline-block;
    }
    .fc-theme-standard .fc-scrollgrid { border-color: rgba(255,255,255,0.1) !important; }
    .fc { background: rgba(255,255,255,0.03); border-radius: 16px; padding: 1.5rem; border: 1px solid rgba(255,255,255,0.08); }
    .fc-day-today { background: rgba(25,139,97,0.08) !important; }
    .fc-col-header-cell { background: rgba(0,0,0,0.2) !important; }
    .fc-col-header-cell-cushion { color: rgba(255,255,255,0.7) !important; font-weight: 600; text-transform: uppercase; font-size: 0.8rem; }
    .fc-daygrid-day-number { color: rgba(255,255,255,0.6) !important; }
    .fc-toolbar-title { color: #fff !important; font-size: 1.2rem !important; font-weight: 700 !important; }
    .fc-button { background: rgba(255,255,255,0.1) !important; border: 1px solid rgba(255,255,255,0.15) !important; color: #fff !important; border-radius: 8px !important; padding: 0.4rem 0.9rem !important; }
    .fc-button:hover { background: rgba(255,255,255,0.2) !important; }
    .fc-button-active { background: rgba(25,139,97,0.4) !important; border-color: #198B61 !important; }
    .fc-event { border-radius: 6px !important; font-size: 0.78rem !important; padding: 2px 5px !important; border: none !important; }
    .fc-daygrid-dot-event { background: rgba(255,255,255,0.05) !important; }
    .fc-scrollgrid-section-header th { border-color: rgba(255,255,255,0.08) !important; }
    .fc-daygrid-day { border-color: rgba(255,255,255,0.06) !important; }
    .fc-list-event:hover td { background: rgba(255,255,255,0.08) !important; }
    .fc-list-day-cushion { background: rgba(0,0,0,0.2) !important; }

    /* Popup détail événement */
    .event-popup {
        position: fixed; top: 50%; left: 50%; transform: translate(-50%, -50%);
        background: #1a2332; border: 1px solid rgba(255,255,255,0.12);
        border-radius: 16px; padding: 2rem; z-index: 9999;
        min-width: 300px; max-width: 400px; display: none;
        box-shadow: 0 20px 60px rgba(0,0,0,0.5);
        animation: popIn 0.2s ease;
    }
    @keyframes popIn { from { opacity:0; transform:translate(-50%,-50%) scale(0.9); } to { opacity:1; transform:translate(-50%,-50%) scale(1); } }
    .popup-overlay { position:fixed; inset:0; background:rgba(0,0,0,0.5); z-index:9998; display:none; }
    .popup-close { position:absolute; top:1rem; right:1rem; background:none; border:none; color:rgba(255,255,255,0.5); cursor:pointer; font-size:1.2rem; }
    .popup-close:hover { color:#fff; }
    .popup-badge { display:inline-block; padding:0.3rem 0.8rem; border-radius:20px; font-size:0.8rem; font-weight:600; margin-bottom:1rem; }
</style>
{% endblock %}

{% block body %}
<div class="cal-page">

    {# Hero #}
    <div class="cal-hero">
        <div style="width:60px;height:60px;border-radius:16px;background:rgba(230,126,34,0.3);display:flex;align-items:center;justify-content:center;font-size:1.8rem;">📅</div>
        <div>
            <h1 style="font-size:1.9rem;font-weight:800;color:#fff;margin:0;">Calendrier Cultural</h1>
            <p style="color:rgba(255,255,255,0.55);margin:0.3rem 0 0;">Visualisez les dates de plantation et de récolte de toutes vos cultures</p>
        </div>
    </div>

    {# Légende #}
    <div class="legend-cal">
        <span style="font-size:0.85rem;color:rgba(255,255,255,0.5);font-weight:600;">Légende :</span>
        <span style="display:flex;align-items:center;gap:0.5rem;font-size:0.85rem;color:rgba(255,255,255,0.7);">
            <span class="legend-dot-cal" style="background:#198B61;"></span> Plantation
        </span>
        <span style="display:flex;align-items:center;gap:0.5rem;font-size:0.85rem;color:rgba(255,255,255,0.7);">
            <span class="legend-dot-cal" style="background:#e67e22;"></span> Récolte prévue
        </span>
        <div style="flex:1;"></div>
        <a href="{{ path('app_agriculture_statistiques') }}" style="font-size:0.85rem;color:rgba(255,255,255,0.5);text-decoration:none;">
            <i class="fa-solid fa-chart-bar"></i> Statistiques
        </a>
    </div>

    {# Calendrier FullCalendar #}
    <div id="calendrier"></div>

    {# Popup détail #}
    <div class="popup-overlay" id="popupOverlay" onclick="closePopup()"></div>
    <div class="event-popup" id="eventPopup">
        <button class="popup-close" onclick="closePopup()"><i class="fa-solid fa-xmark"></i></button>
        <div id="popupBadge" class="popup-badge"></div>
        <h3 id="popupTitle" style="color:#fff;font-size:1.1rem;font-weight:700;margin-bottom:1rem;"></h3>
        <div id="popupDetails"></div>
    </div>

</div>

<script src='https://cdn.jsdelivr.net/npm/fullcalendar@6.1.11/index.global.min.js'></script>
<script>
document.addEventListener('DOMContentLoaded', function() {
    const cal = document.getElementById('calendrier');
    const calendar = new FullCalendar.Calendar(cal, {
        initialView: 'dayGridMonth',
        locale: 'fr',
        headerToolbar: {
            left:   'prev,next today',
            center: 'title',
            right:  'dayGridMonth,timeGridWeek,listMonth'
        },
        buttonText: {
            today:     'Aujourd\'hui',
            month:     'Mois',
            week:      'Semaine',
            list:      'Liste'
        },
        events: '{{ path('app_agriculture_calendrier_events') }}',
        eventClick: function(info) {
            const props = info.event.extendedProps;
            const isPlant = props.type === 'plantation';

            document.getElementById('popupBadge').textContent = isPlant ? '🌱 Plantation' : '🌾 Récolte prévue';
            document.getElementById('popupBadge').style.background = isPlant ? 'rgba(25,139,97,0.2)' : 'rgba(230,126,34,0.2)';
            document.getElementById('popupBadge').style.color = isPlant ? '#27ae60' : '#e67e22';

            document.getElementById('popupTitle').textContent = props.culture || info.event.title;

            let details = '';
            if (props.etat) details += `<div style="margin-bottom:0.6rem;"><span style="color:rgba(255,255,255,0.5);font-size:0.85rem;">État :</span> <span style="color:#fff;font-size:0.9rem;">${props.etat}</span></div>`;
            if (props.parcelle) details += `<div style="margin-bottom:0.6rem;"><span style="color:rgba(255,255,255,0.5);font-size:0.85rem;">Parcelle :</span> <span style="color:#fff;font-size:0.9rem;">${props.parcelle}</span></div>`;
            details += `<div><span style="color:rgba(255,255,255,0.5);font-size:0.85rem;">Date :</span> <span style="color:#fff;font-size:0.9rem;">${info.event.start.toLocaleDateString('fr-FR')}</span></div>`;
            document.getElementById('popupDetails').innerHTML = details;

            document.getElementById('popupOverlay').style.display = 'block';
            document.getElementById('eventPopup').style.display = 'block';
        },
        eventDidMount: function(info) {
            info.el.title = info.event.title;
        },
        noEventsContent: 'Aucune culture avec des dates de plantation ou de récolte.',
    });
    calendar.render();
});

function closePopup() {
    document.getElementById('popupOverlay').style.display = 'none';
    document.getElementById('eventPopup').style.display = 'none';
}
</script>
{% endblock %}
