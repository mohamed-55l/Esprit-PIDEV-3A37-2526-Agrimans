{% extends 'base.html.twig' %}

{% block title %}Connexion{% endblock %}

{% block body %}
<section class="content-section" style="margin-top: 2rem; max-width: 400px; margin-left: auto; margin-right: auto;">
    <div style="background:rgba(255,255,255,0.04); border:1px solid rgba(255,255,255,0.08); border-radius:12px; padding:2rem;">
        <h2 style="text-align: center; margin-bottom: 1.5rem; color: #198B61;">Connexion</h2>

        {% if error %}
            <div style="background:rgba(231,76,60,0.15); border:1px solid #e74c3c; color:#e74c3c; padding:0.75rem 1rem; border-radius:8px; margin-bottom:1rem;">
                <i class="fa-solid fa-circle-xmark"></i> {{ error.messageKey|trans(error.messageData, 'security') }}
            </div>
        {% endif %}

        {% if app.user %}
            <div style="text-align: center;">
                Vous êtes connecté en tant que {{ app.user.userIdentifier }}<br>
                <a href="{{ path('app_logout') }}" class="btn btn-secondary" style="margin-top: 1rem;">Déconnexion</a>
            </div>
        {% else %}
            <form method="post">
                <div style="margin-bottom: 1rem;">
                    <label for="inputEmail" style="display: block; margin-bottom: 0.5rem; color: rgba(255,255,255,0.8);">Email</label>
                    <input type="email" value="{{ last_username }}" name="_username" id="inputEmail" class="form-control" autocomplete="email" required autofocus>
                </div>

                <div style="margin-bottom: 1.5rem;">
                    <label for="inputPassword" style="display: block; margin-bottom: 0.5rem; color: rgba(255,255,255,0.8);">Mot de passe</label>
                    <input type="password" name="_password" id="inputPassword" class="form-control" autocomplete="current-password" required>
                </div>

                <input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}">

                <button class="hero-btn-primary" type="submit" style="width: 100%; font-size: 1rem;">
                    <i class="fa-solid fa-sign-in-alt"></i> Se connecter
                </button>
            </form>
        {% endif %}
    </div>
</section>
{% endblock %}