{% extends 'base.html.twig' %}

{% block title %}{{ product.name }} - Marketplace{% endblock %}

{% block body %}
    <section class="content-section" style="margin-top: 2rem;">
        {# Flash messages #}
        {% for type, messages in app.flashes %}
            {% for message in messages %}
                <div style="padding: 1rem; margin-bottom: 1rem; border-radius: 8px; background: {{ type == 'success' ? 'rgba(125, 191, 108, 0.2)' : 'rgba(231, 76, 60, 0.2)' }}; border: 1px solid {{ type == 'success' ? '#7DBF6C' : '#e74c3c' }};">
                    <i class="fa-solid {{ type == 'success' ? 'fa-check-circle' : 'fa-exclamation-circle' }}"></i> {{ message }}
                </div>
            {% endfor %}
        {% endfor %}

        <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 2rem;">
            {# Product Details #}
            <div class="glass-card" style="padding: 2rem;">
                <div style="display: flex; justify-content: space-between; align-items: start; margin-bottom: 1.5rem;">
                    <span class="badge {{ product.category == 'VEGETABLES' ? 'badge-success' : (product.category == 'FRUITS' ? 'badge-warning' : 'badge-primary') }}">
                        <i class="fa-solid {{ product.categoryIcon }}"></i> {{ product.category }}
                    </span>
                    <span style="color: rgba(255,255,255,0.4);">#{{ product.id }}</span>
                </div>

                <div style="text-align: center; margin-bottom: 1.5rem; max-height: 300px; overflow: hidden; border-radius: 10px;">
                    {% if product.image %}
                        <img src="{{ asset('uploads/products/' ~ product.image) }}" alt="{{ product.name }}" style="max-width: 100%; max-height: 300px; object-fit: cover; border-radius: 10px;">
                    {% else %}
                        <div style="padding: 2rem;">
                            <i class="fa-solid {{ product.categoryIcon }}" style="font-size: 4rem; color: var(--primary-color); opacity: 0.7;"></i>
                        </div>
                    {% endif %}
                </div>

                <h1 style="font-size: 1.8rem; margin-bottom: 1rem;">{{ product.name }}</h1>

                <p style="color: rgba(255,255,255,0.7); margin-bottom: 1.5rem; line-height: 1.6;">{{ product.description }}</p>

                <table class="styled-table" style="margin-bottom: 1.5rem;">
                    <tbody>
                        <tr>
                            <th>Prix</th>
                            <td><span style="font-size: 1.3rem; color: var(--primary-color); font-weight: bold;">{{ product.price|number_format(2, ',', ' ') }} DT/kg</span></td>
                        </tr>
                        <tr>
                            <th>Stock</th>
                            <td>
                                {% if product.quantity > 0 %}
                                    <span class="badge badge-success">{{ product.quantity }} kg disponibles</span>
                                {% else %}
                                    <span class="badge badge-danger">Rupture de stock</span>
                                {% endif %}
                            </td>
                        </tr>
                        {% if product.supplier %}
                        <tr>
                            <th>Fournisseur</th>
                            <td><i class="fa-solid fa-truck"></i> {{ product.supplier }}</td>
                        </tr>
                        {% endif %}
                        {% if product.expiryDate %}
                        <tr>
                            <th>Expiration</th>
                            <td><i class="fa-solid fa-calendar"></i> {{ product.expiryDate|date('d/m/Y') }}</td>
                        </tr>
                        {% endif %}
                        <tr>
                            <th>Note moyenne</th>
                            <td>
                                {% if avgRating > 0 %}
                                    {% for i in 1..5 %}
                                        <i class="fa-{{ i <= avgRating ? 'solid' : 'regular' }} fa-star" style="color: #f1c40f;"></i>
                                    {% endfor %}
                                    <span style="margin-left: 0.5rem;">{{ avgRating }}/5 ({{ product.ratings|length }} avis)</span>
                                {% else %}
                                    <span style="color: rgba(255,255,255,0.5);">Aucun avis</span>
                                {% endif %}
                            </td>
                        </tr>
                    </tbody>
                </table>

                {# Price category analysis #}
                {% if priceAnalysis.HIGH > 0 or priceAnalysis.GOOD > 0 or priceAnalysis.LOW > 0 %}
                    <div style="margin-bottom: 1.5rem;">
                        <h4 style="margin-bottom: 0.5rem; font-size: 0.9rem; color: rgba(255,255,255,0.7);">Perception du prix :</h4>
                        <div style="display: flex; gap: 0.5rem;">
                            <span class="badge badge-danger" style="font-size: 0.8rem;"><i class="fa-solid fa-arrow-up"></i> Cher: {{ priceAnalysis.HIGH }}</span>
                            <span class="badge badge-success" style="font-size: 0.8rem;"><i class="fa-solid fa-check"></i> Bon: {{ priceAnalysis.GOOD }}</span>
                            <span class="badge badge-warning" style="font-size: 0.8rem;"><i class="fa-solid fa-arrow-down"></i> Bas: {{ priceAnalysis.LOW }}</span>
                        </div>
                    </div>
                {% endif %}

                {# Add to cart #}
                {% if product.quantity > 0 %}
                    <form method="post" action="{{ path('app_marketplace_cart_add', {'id': product.id}) }}" style="display: flex; gap: 0.5rem;">
                        <input type="number" name="quantity" value="1" min="1" max="{{ product.quantity }}" class="form-control" style="width: 80px; text-align: center;">
                        <button type="submit" class="btn btn-primary" style="flex: 1;">
                            <i class="fa-solid fa-cart-plus"></i> Ajouter au Panier
                        </button>
                    </form>
                {% endif %}

                <div style="margin-top: 1.5rem; display: flex; gap: 1rem;">
                    <a href="{{ path('app_marketplace_index') }}" class="btn btn-secondary"><i class="fa-solid fa-arrow-left"></i> Retour</a>
                    <a href="{{ path('app_marketplace_product_edit', {'id': product.id}) }}" class="btn btn-primary"><i class="fa-solid fa-pen"></i> Modifier</a>
                </div>
            </div>

            {# Ratings Section #}
            <div>
                {# Rating Form #}
                <div class="glass-card" style="padding: 1.5rem; margin-bottom: 1.5rem;">
                    <h3 style="margin-bottom: 1rem;"><i class="fa-solid fa-star"></i> Donner votre avis</h3>

                    {{ form_start(ratingForm, {'attr': {'class': 'form-wrapper'}}) }}
                        <div class="form-group">
                            <label style="display: block; margin-bottom: 0.5rem;">Note</label>
                            <div style="display: flex; gap: 1rem; font-size: 1.2rem;">
                                {% for child in ratingForm.rating %}
                                    <label style="cursor: pointer; display: flex; align-items: center; gap: 0.3rem;">
                                        {{ form_widget(child) }}
                                        {{ child.vars.label }} <i class="fa-solid fa-star" style="color: #f1c40f;"></i>
                                    </label>
                                {% endfor %}
                            </div>
                            <div style="color: #e74c3c; font-size: 0.85rem;">{{ form_errors(ratingForm.rating) }}</div>
                        </div>

                        <div class="form-group">
                            {{ form_label(ratingForm.priceCategory) }}
                            {{ form_widget(ratingForm.priceCategory, {'attr': {'class': 'form-control'}}) }}
                        </div>

                        <div class="form-group">
                            {{ form_label(ratingForm.comment) }}
                            {{ form_widget(ratingForm.comment, {'attr': {'class': 'form-control'}}) }}
                        </div>

                        <button class="btn btn-primary" style="width: 100%;"><i class="fa-solid fa-paper-plane"></i> Envoyer</button>
                    {{ form_end(ratingForm) }}
                </div>

                {# Existing Ratings #}
                <div class="glass-card" style="padding: 1.5rem;">
                    <h3 style="margin-bottom: 1rem;"><i class="fa-solid fa-comments"></i> Avis ({{ product.ratings|length }})</h3>

                    {% for rating in product.ratings %}
                        <div style="padding: 1rem; margin-bottom: 1rem; background: rgba(255,255,255,0.05); border-radius: 8px; border-left: 3px solid var(--primary-color);">
                            <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 0.5rem;">
                                <div>
                                    {% for i in 1..5 %}
                                        <i class="fa-{{ i <= rating.rating ? 'solid' : 'regular' }} fa-star" style="color: #f1c40f; font-size: 0.9rem;"></i>
                                    {% endfor %}
                                    {% if rating.priceCategory %}
                                        <span class="badge {{ rating.priceCategory == 'HIGH' ? 'badge-danger' : (rating.priceCategory == 'GOOD' ? 'badge-success' : 'badge-warning') }}" style="font-size: 0.7rem; margin-left: 0.5rem;">
                                            {{ rating.priceCategory }}
                                        </span>
                                    {% endif %}
                                </div>
                                <span style="font-size: 0.75rem; color: rgba(255,255,255,0.4);">{{ rating.createdAt|date('d/m/Y H:i') }}</span>
                            </div>
                            {% if rating.comment %}
                                <p style="color: rgba(255,255,255,0.8); font-size: 0.9rem; margin: 0;">{{ rating.comment }}</p>
                            {% endif %}
                        </div>
                    {% else %}
                        <p style="color: rgba(255,255,255,0.5); text-align: center;">Aucun avis pour ce produit.</p>
                    {% endfor %}
                </div>
            </div>
        </div>
    </section>
{% endblock %}
