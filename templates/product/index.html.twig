{% extends 'base.html.twig' %}

{% block title %}Marketplace - Explorer la Boutique{% endblock %}

{% block body %}
    <section class="content-section" style="margin-top: 2rem;">
        {# Header #}
        <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 2rem;">
            <div>
                <h2 style="font-size: 2rem; margin-bottom: 0.5rem;"><i class="fa-solid fa-store"></i> Marketplace Agrimans</h2>
                <p style="color: rgba(255,255,255,0.7);">Explorez les produits agricoles frais de nos producteurs.</p>
            </div>
            <div style="display: flex; gap: 1rem; align-items: center;">
                <a href="{{ path('app_marketplace_cart') }}" class="btn btn-secondary" style="position: relative;">
                    <i class="fa-solid fa-cart-shopping"></i> Panier
                    {% if cartCount > 0 %}
                        <span style="position: absolute; top: -8px; right: -8px; background: #e74c3c; color: white; border-radius: 50%; width: 20px; height: 20px; font-size: 0.7rem; display: flex; align-items: center; justify-content: center;">{{ cartCount }}</span>
                    {% endif %}
                </a>
                <a href="{{ path('app_marketplace_my_products') }}" class="btn btn-secondary">
                    <i class="fa-solid fa-box-open"></i> Mes Produits
                </a>
                <a href="{{ path('app_marketplace_product_new') }}" class="hero-btn-primary" style="font-size: 0.9rem;">
                    + Ajouter Produit
                </a>
                <div class="dropdown" style="display: inline-block;">
                    <button class="btn btn-secondary"><i class="fa-solid fa-coins"></i> {{ currency }} <i class="fa-solid fa-caret-down"></i></button>
                    <div class="dropdown-content">
                        <a href="{{ path('app_marketplace_set_currency', {'currency': 'TND'}) }}" style="{{ currency == 'TND' ? 'font-weight:bold;color:#198B61;' : '' }}">TND</a>
                        <a href="{{ path('app_marketplace_set_currency', {'currency': 'EUR'}) }}" style="{{ currency == 'EUR' ? 'font-weight:bold;color:#198B61;' : '' }}">EUR</a>
                        <a href="{{ path('app_marketplace_set_currency', {'currency': 'USD'}) }}" style="{{ currency == 'USD' ? 'font-weight:bold;color:#198B61;' : '' }}">USD</a>
                    </div>
                </div>
            </div>
        </div>

        {# Flash messages #}
        {% for type, messages in app.flashes %}
            {% for message in messages %}
                <div style="padding: 1rem; margin-bottom: 1rem; border-radius: 8px; background: {{ type == 'success' ? 'rgba(125, 191, 108, 0.2)' : 'rgba(231, 76, 60, 0.2)' }}; border: 1px solid {{ type == 'success' ? '#7DBF6C' : '#e74c3c' }};">
                    <i class="fa-solid {{ type == 'success' ? 'fa-check-circle' : 'fa-exclamation-circle' }}"></i> {{ message }}
                </div>
            {% endfor %}
        {% endfor %}

        {# Search and Filter #}
        <div class="glass-card" style="margin-bottom: 2rem; padding: 1.5rem;">
            <form id="filterForm" method="get" action="{{ path('app_marketplace_index') }}" style="display: flex; gap: 1rem; align-items: flex-end; flex-wrap: wrap;">
                <div style="flex: 1; min-width: 200px;">
                    <label style="display: block; margin-bottom: 0.5rem; font-size: 0.85rem; color: rgba(255,255,255,0.7);">Rechercher</label>
                    <input type="text" name="search" id="searchInput" value="{{ search }}" placeholder="Nom, description, fournisseur..." class="form-control" style="width: 100%;">
                </div>
                <div style="min-width: 180px;">
                    <label style="display: block; margin-bottom: 0.5rem; font-size: 0.85rem; color: rgba(255,255,255,0.7);">Catégorie</label>
                    <select name="category" id="categorySelect" class="form-control">
                        <option value="">Toutes</option>
                        <option value="VEGETABLES" {{ category == 'VEGETABLES' ? 'selected' }}>Légumes</option>
                        <option value="FRUITS" {{ category == 'FRUITS' ? 'selected' }}>Fruits</option>
                        <option value="GRAINS" {{ category == 'GRAINS' ? 'selected' }}>Céréales</option>
                        <option value="HAY" {{ category == 'HAY' ? 'selected' }}>Foin</option>
                    </select>
                </div>
                <button type="submit" class="btn btn-primary"><i class="fa-solid fa-search"></i> Filtrer</button>
                {% if search or category %}
                    <a href="{{ path('app_marketplace_index') }}" class="btn btn-secondary"><i class="fa-solid fa-times"></i> Réinitialiser</a>
                {% endif %}
            </form>
        </div>

        {# Product Cards Grid #}
        <div id="products-container" style="position: relative; min-height: 200px;">
        {% if products|length > 0 %}
            <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 1.5rem;">
                {% for product in products %}
                    <div class="glass-card" style="padding: 1.5rem; display: flex; flex-direction: column; transition: transform 0.2s; position: relative;">
                        {# Category badge #}
                        <div style="position: absolute; top: 1rem; right: 1rem;">
                            <span class="badge {{ product.category == 'VEGETABLES' ? 'badge-success' : (product.category == 'FRUITS' ? 'badge-warning' : 'badge-primary') }}" style="font-size: 0.75rem;">
                                <i class="fa-solid {{ product.categoryIcon }}"></i> {{ product.category }}
                            </span>
                        </div>

                        {# Product image #}
                        <div style="text-align: center; margin-bottom: 1rem; height: 150px; display: flex; align-items: center; justify-content: center; overflow: hidden; border-radius: 8px;">
                            {% if product.image %}
                                <img src="{{ asset('uploads/products/' ~ product.image) }}" alt="{{ product.name }}" style="max-width: 100%; max-height: 150px; object-fit: cover; border-radius: 8px;">
                            {% else %}
                                <i class="fa-solid {{ product.categoryIcon }}" style="font-size: 3rem; color: var(--primary-color); opacity: 0.8;"></i>
                            {% endif %}
                        </div>

                        {# Product name #}
                        <h3 style="margin-bottom: 0.5rem; font-size: 1.1rem;">
                            <a href="{{ path('app_marketplace_product_show', {'id': product.id}) }}" style="color: inherit; text-decoration: none;">
                                {{ product.name|length > 25 ? product.name|slice(0, 25) ~ '...' : product.name }}
                            </a>
                        </h3>

                        {% if product.supplier %}
                            <p style="color: rgba(255,255,255,0.5); font-size: 0.8rem; margin-bottom: 0.5rem;">
                                <i class="fa-solid fa-truck"></i> {{ product.supplier }}
                            </p>
                        {% endif %}

                        {# Price and stock #}
                        <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 0.75rem;">
                            <span style="font-size: 1.3rem; font-weight: 700; color: var(--primary-color);">{{ (product.price * rates[currency])|number_format(2, ',', ' ') }} {{ currency }}</span>
                            <span style="font-size: 0.85rem; color: {{ product.quantity > 0 ? 'rgba(255,255,255,0.6)' : '#e74c3c' }};">
                                <i class="fa-solid fa-boxes-stacked"></i> {{ product.quantity }} kg
                            </span>
                        </div>

                        {# Rating #}
                        {% if product.averageRating > 0 %}
                            <div style="margin-bottom: 0.75rem; font-size: 0.85rem;">
                                {% for i in 1..5 %}
                                    <i class="fa-{{ i <= product.averageRating ? 'solid' : 'regular' }} fa-star" style="color: #f1c40f;"></i>
                                {% endfor %}
                                <span style="color: rgba(255,255,255,0.5); margin-left: 0.3rem;">({{ product.ratings|length }})</span>
                            </div>
                        {% endif %}

                        {# Expiry date #}
                        {% if product.expiryDate %}
                            <p style="font-size: 0.8rem; color: rgba(255,255,255,0.5); margin-bottom: 0.75rem;">
                                <i class="fa-solid fa-calendar"></i> Expire: {{ product.expiryDate|date('d/m/Y') }}
                            </p>
                        {% endif %}

                        {# Add to cart form #}
                        <div style="margin-top: auto; padding-top: 1rem;">
                            {% if product.quantity > 0 %}
                                <form method="post" action="{{ path('app_marketplace_cart_add', {'id': product.id}) }}" style="display: flex; gap: 0.5rem;">
                                    <input type="number" name="quantity" value="1" min="1" max="{{ product.quantity }}" class="form-control" style="width: 70px; text-align: center;">
                                    <button type="submit" class="btn btn-primary" style="flex: 1;">
                                        <i class="fa-solid fa-cart-plus"></i> Ajouter
                                    </button>
                                </form>
                            {% else %}
                                <button class="btn" style="width: 100%; opacity: 0.5; cursor: not-allowed;" disabled>
                                    <i class="fa-solid fa-ban"></i> Rupture de stock
                                </button>
                            {% endif %}
                        </div>
                    </div>
                {% endfor %}
            </div>
        {% else %}
            <div style="text-align: center; padding: 4rem; color: rgba(255,255,255,0.6);">
                <i class="fa-solid fa-box-open" style="font-size: 4rem; opacity: 0.5; margin-bottom: 1rem; display: block;"></i>
                <h2>Aucun produit trouvé</h2>
                <p>Essayez de modifier vos critères de recherche.</p>
            </div>
        {% endif %}
        </div>
    </section>

    <script>
        document.addEventListener('DOMContentLoaded', function() {
            const filterForm = document.getElementById('filterForm');
            const searchInput = document.getElementById('searchInput');
            const categorySelect = document.getElementById('categorySelect');
            let timeout = null;

            function fetchResults() {
                const formData = new FormData(filterForm);
                const queryString = new URLSearchParams(formData).toString();

                // Add a small opacity effect while loading
                document.getElementById('products-container').style.opacity = '0.5';

                fetch(`{{ path('app_marketplace_index') }}?${queryString}`, {
                    headers: { 'X-Requested-With': 'XMLHttpRequest' }
                })
                .then(response => response.text())
                .then(html => {
                    const parser = new DOMParser();
                    const doc = parser.parseFromString(html, 'text/html');
                    const newContent = doc.getElementById('products-container').innerHTML;
                    document.getElementById('products-container').innerHTML = newContent;
                    document.getElementById('products-container').style.opacity = '1';
                });
            }

            filterForm.addEventListener('submit', function(e) {
                e.preventDefault();
                fetchResults();
            });

            searchInput.addEventListener('input', function() {
                clearTimeout(timeout);
                timeout = setTimeout(fetchResults, 300); // 300ms debounce
            });

            categorySelect.addEventListener('change', fetchResults);
        });
    </script>

    {# ===== AI FLOATING BUTTON & PANEL (Boutique only) ===== #}

    {# Floating Button #}
    <button id="aiBoutiqueBtn" onclick="toggleAIPanel()" title="Assistant IA - Boutique" style="
        position: fixed;
        bottom: 2rem;
        right: 2rem;
        width: 62px;
        height: 62px;
        border-radius: 50%;
        background: linear-gradient(135deg, #198B61 0%, #7DBF6C 100%);
        border: none;
        cursor: pointer;
        box-shadow: 0 4px 20px rgba(25, 139, 97, 0.55);
        display: flex;
        align-items: center;
        justify-content: center;
        z-index: 1000;
        transition: transform 0.3s ease, box-shadow 0.3s ease;
        animation: aiPulse 2.5s infinite;
    ">
        <span id="aiBtnIcon" style="font-size: 1.6rem; line-height: 1;">🤖</span>
    </button>

    {# Slide-in AI Chat Panel #}
    <div id="aiChatPanel" style="
        position: fixed;
        bottom: 6.5rem;
        right: 2rem;
        width: 370px;
        max-height: 560px;
        background: linear-gradient(160deg, rgba(15,30,20,0.97) 0%, rgba(20,45,30,0.97) 100%);
        border: 1px solid rgba(125, 191, 108, 0.35);
        border-radius: 16px;
        box-shadow: 0 8px 40px rgba(0,0,0,0.55);
        display: flex;
        flex-direction: column;
        z-index: 999;
        transform: translateY(20px) scale(0.95);
        opacity: 0;
        pointer-events: none;
        transition: all 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
        overflow: hidden;
    ">
        {# Panel Header #}
        <div style="
            padding: 1rem 1.25rem;
            background: linear-gradient(90deg, rgba(25,139,97,0.3) 0%, rgba(125,191,108,0.15) 100%);
            border-bottom: 1px solid rgba(125,191,108,0.25);
            display: flex;
            align-items: center;
            gap: 0.75rem;
        ">
            <div style="
                width: 36px; height: 36px;
                background: rgba(25,139,97,0.4);
                border-radius: 50%;
                display: flex; align-items: center; justify-content: center;
                font-size: 1.2rem; flex-shrink: 0;
            ">🤖</div>
            <div style="flex: 1;">
                <div style="font-weight: 700; font-size: 0.95rem; color: #fff;">Assistant IA</div>
                <div style="font-size: 0.75rem; color: rgba(125,191,108,0.9);">Trouvez le produit parfait 🌱</div>
            </div>
            <a href="{{ path('app_chatbot_index') }}" title="Ouvrir en plein écran" style="
                color: rgba(255,255,255,0.5);
                text-decoration: none; font-size: 0.8rem;
                padding: 0.25rem 0.5rem;
                border: 1px solid rgba(255,255,255,0.15);
                border-radius: 6px;
                transition: all 0.2s;
                white-space: nowrap;
            " onmouseover="this.style.color='#7DBF6C';this.style.borderColor='#7DBF6C'" onmouseout="this.style.color='rgba(255,255,255,0.5)';this.style.borderColor='rgba(255,255,255,0.15)'">
                ⛶ Plein écran
            </a>
            <button onclick="toggleAIPanel()" style="
                background: none; border: none; color: rgba(255,255,255,0.5);
                cursor: pointer; font-size: 1.2rem; padding: 0;
                transition: color 0.2s;
            " onmouseover="this.style.color='#e74c3c'" onmouseout="this.style.color='rgba(255,255,255,0.5)'">✕</button>
        </div>

        {# Quick suggestion chips #}
        <div style="padding: 0.75rem 1rem; border-bottom: 1px solid rgba(255,255,255,0.07); display: flex; gap: 0.5rem; flex-wrap: wrap;">
            <button onclick="aiSend('Légumes disponibles')" class="ai-chip">🥬 Légumes</button>
            <button onclick="aiSend('Fruits moins de 5 TND')" class="ai-chip">🍎 &lt;5 TND</button>
            <button onclick="aiSend('Meilleurs produits notés')" class="ai-chip">⭐ Top notés</button>
            <button onclick="aiSend('Produits en stock')" class="ai-chip">📦 En stock</button>
        </div>

        {# Messages Area #}
        <div id="aiMessages" style="
            flex: 1;
            overflow-y: auto;
            padding: 1rem;
            display: flex;
            flex-direction: column;
            gap: 0.75rem;
            scrollbar-width: thin;
            scrollbar-color: rgba(125,191,108,0.3) transparent;
        ">
            {# Welcome message #}
            <div class="ai-msg-bot">
                <div class="ai-avatar">🤖</div>
                <div class="ai-bubble-bot">
                    Bonjour ! 👋 Je suis votre assistant boutique.<br>
                    Posez-moi une question sur les produits disponibles !
                </div>
            </div>
        </div>

        {# Input Area #}
        <div style="padding: 0.875rem 1rem; border-top: 1px solid rgba(255,255,255,0.07);">
            <form id="aiMiniForm" onsubmit="aiFormSubmit(event)" style="display: flex; gap: 0.6rem; align-items: center;">
                <input
                    id="aiMiniInput"
                    type="text"
                    placeholder="Ex: tomates rouges bio..."
                    autocomplete="off"
                    style="
                        flex: 1;
                        padding: 0.65rem 0.9rem;
                        border: 1px solid rgba(255,255,255,0.15);
                        background: rgba(255,255,255,0.06);
                        color: #fff;
                        border-radius: 8px;
                        font-size: 0.9rem;
                        outline: none;
                        transition: border-color 0.2s;
                    "
                    onfocus="this.style.borderColor='rgba(125,191,108,0.6)'"
                    onblur="this.style.borderColor='rgba(255,255,255,0.15)'"
                >
                <button type="submit" style="
                    width: 40px; height: 40px;
                    border-radius: 10px;
                    background: linear-gradient(135deg, #198B61, #7DBF6C);
                    border: none; cursor: pointer;
                    display: flex; align-items: center; justify-content: center;
                    font-size: 1rem; flex-shrink: 0;
                    transition: transform 0.2s, box-shadow 0.2s;
                " onmouseover="this.style.transform='scale(1.1)'" onmouseout="this.style.transform='scale(1)'">
                    ➤
                </button>
            </form>
        </div>
    </div>

    <style>
        @keyframes aiPulse {
            0%, 100% { box-shadow: 0 4px 20px rgba(25, 139, 97, 0.55); }
            50%       { box-shadow: 0 4px 32px rgba(125, 191, 108, 0.75), 0 0 0 8px rgba(25,139,97,0.12); }
        }
        #aiBoutiqueBtn:hover {
            transform: scale(1.1) !important;
            box-shadow: 0 6px 28px rgba(25, 139, 97, 0.75) !important;
        }
        .ai-chip {
            background: rgba(125,191,108,0.1);
            border: 1px solid rgba(125,191,108,0.3);
            color: rgba(255,255,255,0.85);
            padding: 0.3rem 0.65rem;
            border-radius: 20px;
            font-size: 0.78rem;
            cursor: pointer;
            transition: all 0.2s;
            white-space: nowrap;
        }
        .ai-chip:hover {
            background: rgba(125,191,108,0.25);
            border-color: #7DBF6C;
            color: #fff;
        }
        .ai-msg-bot {
            display: flex;
            gap: 0.6rem;
            align-items: flex-start;
        }
        .ai-msg-user {
            display: flex;
            justify-content: flex-end;
        }
        .ai-avatar {
            width: 30px; height: 30px;
            background: rgba(25,139,97,0.3);
            border-radius: 50%;
            display: flex; align-items: center; justify-content: center;
            font-size: 0.9rem; flex-shrink: 0;
        }
        .ai-bubble-bot {
            background: rgba(255,255,255,0.06);
            border: 1px solid rgba(255,255,255,0.1);
            padding: 0.65rem 0.85rem;
            border-radius: 0 10px 10px 10px;
            font-size: 0.875rem;
            color: rgba(255,255,255,0.9);
            line-height: 1.5;
            max-width: 85%;
            word-wrap: break-word;
        }
        .ai-bubble-user {
            background: linear-gradient(135deg, #198B61, #1aab79);
            padding: 0.65rem 0.85rem;
            border-radius: 10px 10px 0 10px;
            font-size: 0.875rem;
            color: #fff;
            max-width: 85%;
            word-wrap: break-word;
        }
        .ai-product-card {
            display: flex;
            align-items: center;
            gap: 0.5rem;
            background: rgba(125,191,108,0.08);
            border: 1px solid rgba(125,191,108,0.25);
            padding: 0.5rem 0.75rem;
            border-radius: 8px;
            margin-top: 0.4rem;
            text-decoration: none;
            color: #fff;
            font-size: 0.82rem;
            transition: background 0.2s;
        }
        .ai-product-card:hover { background: rgba(125,191,108,0.18); }
        .ai-typing {
            display: flex; gap: 4px; align-items: center; padding: 0.3rem 0;
        }
        .ai-typing span {
            width: 7px; height: 7px;
            background: #7DBF6C;
            border-radius: 50%;
            animation: aiTyping 1s infinite;
        }
        .ai-typing span:nth-child(2) { animation-delay: 0.15s; }
        .ai-typing span:nth-child(3) { animation-delay: 0.3s; }
        @keyframes aiTyping {
            0%, 60%, 100% { transform: translateY(0); opacity: 0.5; }
            30%            { transform: translateY(-5px); opacity: 1; }
        }
    </style>

    <script>
        let aiPanelOpen = false;

        function toggleAIPanel() {
            aiPanelOpen = !aiPanelOpen;
            const panel = document.getElementById('aiChatPanel');
            const btn   = document.getElementById('aiBtnIcon');
            if (aiPanelOpen) {
                panel.style.opacity = '1';
                panel.style.transform = 'translateY(0) scale(1)';
                panel.style.pointerEvents = 'all';
                btn.textContent = '✕';
                document.getElementById('aiMiniInput').focus();
            } else {
                panel.style.opacity = '0';
                panel.style.transform = 'translateY(20px) scale(0.95)';
                panel.style.pointerEvents = 'none';
                btn.textContent = '🤖';
            }
        }

        function aiFormSubmit(e) {
            e.preventDefault();
            const input = document.getElementById('aiMiniInput');
            const msg = input.value.trim();
            if (msg) { aiSend(msg); input.value = ''; }
        }

        function aiSend(message) {
            const messages = document.getElementById('aiMessages');

            // Add user bubble
            const userDiv = document.createElement('div');
            userDiv.className = 'ai-msg-user';
            userDiv.innerHTML = `<div class="ai-bubble-user">${escapeAI(message)}</div>`;
            messages.appendChild(userDiv);

            // Typing indicator
            const typingDiv = document.createElement('div');
            typingDiv.className = 'ai-msg-bot';
            typingDiv.id = 'aiTyping';
            typingDiv.innerHTML = `
                <div class="ai-avatar">🤖</div>
                <div class="ai-bubble-bot">
                    <div class="ai-typing"><span></span><span></span><span></span></div>
                </div>
            `;
            messages.appendChild(typingDiv);
            messages.scrollTop = messages.scrollHeight;

            // Fetch from chatbot endpoint
            fetch('{{ path('app_chatbot_message') }}', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json', 'X-Requested-With': 'XMLHttpRequest' },
                body: JSON.stringify({ message: message })
            })
            .then(r => r.json())
            .then(data => {
                document.getElementById('aiTyping')?.remove();
                const botDiv = document.createElement('div');
                botDiv.className = 'ai-msg-bot';

                let productsHtml = '';
                if (data.products && data.products.length > 0) {
                    data.products.slice(0, 4).forEach(p => {
                        productsHtml += `
                            <a href="{{ path('app_marketplace_index') }}?search=${encodeURIComponent(p.name)}" class="ai-product-card">
                                <span style="font-size:1.1rem;">🌿</span>
                                <div style="flex:1;">
                                    <div style="font-weight:600;">${escapeAI(p.name)}</div>
                                    <div style="color:#7DBF6C;font-size:0.78rem;">${p.price.toFixed(2)} TND</div>
                                </div>
                            </a>
                        `;
                    });
                }

                const responseText = data.success
                    ? (data.response || 'Voici ce que j\'ai trouvé !')
                    : '❌ Une erreur s\'est produite.';

                botDiv.innerHTML = `
                    <div class="ai-avatar">🤖</div>
                    <div class="ai-bubble-bot">
                        <div>${escapeAI(responseText).replace(/\*\*(.*?)\*\*/g, '<strong style="color:#7DBF6C;">$1</strong>').replace(/\n/g, '<br>')}</div>
                        ${productsHtml}
                    </div>
                `;
                messages.appendChild(botDiv);
                messages.scrollTop = messages.scrollHeight;
            })
            .catch(() => {
                document.getElementById('aiTyping')?.remove();
                const errDiv = document.createElement('div');
                errDiv.className = 'ai-msg-bot';
                errDiv.innerHTML = `<div class="ai-avatar">🤖</div><div class="ai-bubble-bot">❌ Erreur de connexion. Réessayez.</div>`;
                messages.appendChild(errDiv);
                messages.scrollTop = messages.scrollHeight;
            });
        }

        function escapeAI(text) {
            return String(text).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
        }
    </script>

{% endblock %}
