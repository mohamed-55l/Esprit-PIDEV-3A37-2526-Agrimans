{% if products|length > 0 %}
    <div style="margin-bottom: 1rem; color: rgba(255,255,255,0.6); font-size: 0.9rem;">
        <i class="fa-solid fa-layer-group"></i> {{ totalProducts }} produit(s) trouvé(s)
    </div>
    <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 1.5rem;">
        {% for product in products %}
            <div class="glass-card" style="padding: 1.5rem; display: flex; flex-direction: column; transition: transform 0.2s; position: relative;">
                {# Category badge #}
                <div style="position: absolute; top: 1rem; right: 1rem;">
                    <span class="badge {{ product.category == 'VEGETABLES' ? 'badge-success' : (product.category == 'FRUITS' ? 'badge-warning' : 'badge-primary') }}" style="font-size: 0.75rem;">
                        <i class="fa-solid {{ product.categoryIcon }}"></i> {{ product.category }}
                    </span>
                </div>

                {# Product image #}
                <div style="text-align: center; margin-bottom: 1rem; height: 150px; display: flex; align-items: center; justify-content: center; overflow: hidden; border-radius: 8px;">
                    {% if product.image %}
                        <img src="{{ asset('uploads/products/' ~ product.image) }}" alt="{{ product.name }}" style="max-width: 100%; max-height: 150px; object-fit: cover; border-radius: 8px;">
                    {% else %}
                        <i class="fa-solid {{ product.categoryIcon }}" style="font-size: 3rem; color: var(--primary-color); opacity: 0.8;"></i>
                    {% endif %}
                </div>

                {# Product name #}
                <h3 style="margin-bottom: 0.5rem; font-size: 1.1rem;">
                    <a href="{{ path('app_marketplace_product_show', {'id': product.id}) }}" style="color: inherit; text-decoration: none;">
                        {{ product.name|length > 25 ? product.name|slice(0, 25) ~ '...' : product.name }}
                    </a>
                </h3>

                {% if product.supplier %}
                    <p style="color: rgba(255,255,255,0.5); font-size: 0.8rem; margin-bottom: 0.5rem;">
                        <i class="fa-solid fa-truck"></i> {{ product.supplier }}
                    </p>
                {% endif %}

                {# Price and stock #}
                <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 0.75rem;">
                    <span style="font-size: 1.3rem; font-weight: 700; color: var(--primary-color);">{{ (product.price * rates[currency])|number_format(2, ',', ' ') }} {{ currency }}</span>
                    <span style="font-size: 0.85rem; color: {{ product.quantity > 0 ? 'rgba(255,255,255,0.6)' : '#e74c3c' }};">
                        <i class="fa-solid fa-boxes-stacked"></i> {{ product.quantity }} kg
                    </span>
                </div>

                {# Rating #}
                {% if product.averageRating > 0 %}
                    <div style="margin-bottom: 0.75rem; font-size: 0.85rem;">
                        {% for i in 1..5 %}
                            <i class="fa-{{ i <= product.averageRating ? 'solid' : 'regular' }} fa-star" style="color: #f1c40f;"></i>
                        {% endfor %}
                        <span style="color: rgba(255,255,255,0.5); margin-left: 0.3rem;">({{ product.ratings|length }})</span>
                    </div>
                {% endif %}

                {# Expiry date #}
                {% if product.expiryDate %}
                    <p style="font-size: 0.8rem; color: rgba(255,255,255,0.5); margin-bottom: 0.75rem;">
                        <i class="fa-solid fa-calendar"></i> Expire: {{ product.expiryDate|date('d/m/Y') }}
                    </p>
                {% endif %}

                {# Add to cart #}
                <div style="margin-top: auto; padding-top: 1rem;">
                    {% if product.quantity > 0 %}
                        <form method="post" action="{{ path('app_marketplace_cart_add', {'id': product.id}) }}" style="display: flex; gap: 0.5rem;">
                            <input type="number" name="quantity" value="1" min="1" max="{{ product.quantity }}" class="form-control" style="width: 70px; text-align: center;">
                            <button type="submit" class="btn btn-primary" style="flex: 1;">
                                <i class="fa-solid fa-cart-plus"></i> Ajouter
                            </button>
                        </form>
                    {% else %}
                        <button class="btn" style="width: 100%; opacity: 0.5; cursor: not-allowed;" disabled>
                            <i class="fa-solid fa-ban"></i> Rupture de stock
                        </button>
                    {% endif %}
                </div>
            </div>
        {% endfor %}
    </div>
{% else %}
    <div style="text-align: center; padding: 4rem; color: rgba(255,255,255,0.6);">
        <i class="fa-solid fa-magnifying-glass" style="font-size: 4rem; opacity: 0.4; margin-bottom: 1rem; display: block;"></i>
        <h2>Aucun produit trouvé</h2>
        <p>Essayez de modifier vos critères de recherche.</p>
    </div>
{% endif %}
