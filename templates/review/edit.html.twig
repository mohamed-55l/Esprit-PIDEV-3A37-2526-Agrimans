{% extends 'base.html.twig' %}

{% block title %}Modifier l'évaluation{% endblock %}

{% block body %}
<section class="content-section" style="margin-top: 2rem;">
    <div class="glass-card" style="max-width: 800px; margin: 0 auto;">
        
        <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 2rem; border-bottom: 1px solid rgba(255,255,255,0.1); padding-bottom: 1.5rem;">
            <div>
                <h1 style="font-size: 1.8rem; display: flex; align-items: center; gap: 1rem;">
                    <i class="fa-solid fa-pen" style="color: var(--light-green);"></i> Éditer l'évaluation #{{ review.id }}
                </h1>
            </div>
            {{ include('review/_delete_form.html.twig') }}
        </div>

        {{ include('review/_form.html.twig', {'button_label': 'Mettre à jour'}) }}

    </div>
</section>
{% endblock %}
