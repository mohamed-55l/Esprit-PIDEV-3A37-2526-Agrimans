<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Créer un Administrateur | Agrimans Admin</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        :root { --primary:#198B61; --dark:#12181b; --dark-card:#1e2529; --text-main:#f8f9fa; --text-muted:#9ba4b5; --border:rgba(255,255,255,0.08); --danger:#e74c3c; --sidebar-width:260px; }
        * { margin:0; padding:0; box-sizing:border-box; font-family:'Inter',sans-serif; }
        body { background:var(--dark); color:var(--text-main); display:flex; min-height:100vh; }
        .sidebar { width:var(--sidebar-width); background:var(--dark-card); border-right:1px solid var(--border); position:fixed; height:100vh; display:flex; flex-direction:column; }
        .sidebar-header { padding:1.5rem 1rem; border-bottom:1px solid var(--border); display:flex; align-items:center; gap:.8rem; }
        .sidebar-header i { color:var(--danger); font-size:1.4rem; }
        .sidebar-nav { padding:1.2rem .8rem; flex:1; }
        .nav-item { display:flex; align-items:center; gap:.8rem; padding:.75rem 1rem; border-radius:10px; text-decoration:none; color:var(--text-muted); font-weight:500; font-size:.9rem; transition:all .25s; margin-bottom:.2rem; }
        .nav-item:hover, .nav-item.active { background:rgba(231,76,60,.1); color:var(--danger); }
        .nav-section { font-size:.72rem; text-transform:uppercase; letter-spacing:1px; color:var(--text-muted); padding:.8rem .5rem .4rem; font-weight:600; }
        .sidebar-footer { padding:1rem; border-top:1px solid var(--border); }
        .main { margin-left:var(--sidebar-width); flex:1; display:flex; flex-direction:column; min-height:100vh; }
        .topbar { height:72px; background:var(--dark-card); border-bottom:1px solid var(--border); display:flex; align-items:center; justify-content:space-between; padding:0 2rem; }
        .content { padding:2rem; display:flex; justify-content:center; }
        .form-card { background:var(--dark-card); border:1px solid var(--border); border-radius:18px; padding:2.5rem; width:100%; max-width:600px; }
        .form-card-header { display:flex; align-items:center; gap:1rem; margin-bottom:2rem; padding-bottom:1.5rem; border-bottom:1px solid var(--border); }
        .form-card-icon { width:50px; height:50px; border-radius:12px; background:rgba(231,76,60,.15); color:var(--danger); display:flex; align-items:center; justify-content:center; font-size:1.4rem; }
        .form-group { margin-bottom:1.3rem; }
        label { display:block; font-size:.85rem; font-weight:500; color:var(--text-muted); margin-bottom:.5rem; }
        input[type=text], input[type=email], input[type=password], input[type=tel] { width:100%; background:var(--dark); border:1px solid var(--border); color:var(--text-main); padding:.75rem 1rem; border-radius:10px; font-size:.9rem; transition:border-color .2s; }
        input:focus { outline:none; border-color:var(--danger); }
        .input-error { border-color:var(--danger) !important; }
        .error-msg { color:var(--danger); font-size:.8rem; margin-top:.4rem; display:flex; align-items:center; gap:.4rem; }
        .form-actions { display:flex; gap:1rem; margin-top:2rem; }
        .btn { display:inline-flex; align-items:center; gap:.5rem; padding:.65rem 1.4rem; border-radius:8px; border:none; font-size:.875rem; font-weight:500; cursor:pointer; text-decoration:none; transition:all .2s; }
        .btn-danger { background:var(--danger); color:white; flex:1; justify-content:center; }
        .btn-danger:hover { background:#c0392b; }
        .btn-outline { background:transparent; border:1px solid var(--border); color:var(--text-muted); }
        .btn-outline:hover { border-color:var(--primary); color:var(--primary); }
        .row { display:grid; grid-template-columns:1fr 1fr; gap:1rem; }
    </style>
</head>
<body>
    <aside class="sidebar">
        <div class="sidebar-header">
            <i class="fa-solid fa-shield-halved"></i>
            <span style="font-size:1.1rem;font-weight:700;color:white;">AGRIMANS <span style="color:var(--danger);font-size:.7rem;vertical-align:top;">ADMIN</span></span>
        </div>
        <div class="sidebar-nav">
            <a href="{{ path('admin_dashboard') }}" class="nav-item"><i class="fa-solid fa-gauge-high"></i> Tableau de Bord</a>
            <div class="nav-section">Administration</div>
            <a href="{{ path('app_user_management') }}" class="nav-item active"><i class="fa-solid fa-users"></i> Utilisateurs</a>
            <a href="{{ path('app_marketplace_index') }}" class="nav-item"><i class="fa-solid fa-store"></i> Boutique</a>
            <div class="nav-section">Équipements & Avis</div>
            <a href="{{ path('admin_equipement_index') }}" class="nav-item"><i class="fa-solid fa-tractor"></i> Équipements</a>
            <a href="{{ path('admin_review_index') }}" class="nav-item"><i class="fa-solid fa-star"></i> Avis & Reviews</a>
        </div>
        <div class="sidebar-footer">
            <a href="{{ path('app_home') }}" class="nav-item"><i class="fa-solid fa-arrow-left"></i> Retour au site</a>
        </div>
    </aside>

    <main class="main">
        <header class="topbar">
            <span style="font-size:1.1rem;font-weight:700;">Créer un Administrateur</span>
            <a href="{{ path('app_user_management') }}" class="btn btn-outline"><i class="fa-solid fa-arrow-left"></i> Retour</a>
        </header>
        <div class="content">
            <div class="form-card">
                <div class="form-card-header">
                    <div class="form-card-icon"><i class="fa-solid fa-user-shield"></i></div>
                    <div>
                        <h2 style="font-size:1.2rem;font-weight:700;">Nouvel Administrateur</h2>
                        <p style="color:var(--text-muted);font-size:.85rem;">Créer un compte avec les privilèges admin</p>
                    </div>
                </div>

                <form method="post" action="{{ path('app_create_admin') }}">
                    <div class="row">
                        <div class="form-group">
                            <label for="full_name"><i class="fa-solid fa-user"></i> Nom complet *</label>
                            <input type="text" id="full_name" name="full_name" placeholder="Nom et Prénom" class="{{ errors.full_name is defined ? 'input-error' : '' }}" required>
                            {% if errors.full_name is defined %}
                                <div class="error-msg"><i class="fa-solid fa-circle-exclamation"></i> {{ errors.full_name }}</div>
                            {% endif %}
                        </div>
                        <div class="form-group">
                            <label for="phone"><i class="fa-solid fa-phone"></i> Téléphone</label>
                            <input type="tel" id="phone" name="phone" placeholder="Ex: 20123456">
                        </div>
                    </div>

                    <div class="form-group">
                        <label for="email"><i class="fa-solid fa-envelope"></i> Adresse email *</label>
                        <input type="email" id="email" name="email" placeholder="admin@example.com" class="{{ errors.email is defined ? 'input-error' : '' }}" required>
                        {% if errors.email is defined %}
                            <div class="error-msg"><i class="fa-solid fa-circle-exclamation"></i> {{ errors.email }}</div>
                        {% endif %}
                    </div>

                    <div class="row">
                        <div class="form-group">
                            <label for="password"><i class="fa-solid fa-lock"></i> Mot de passe *</label>
                            <input type="password" id="password" name="password" placeholder="••••••••" class="{{ errors.password is defined ? 'input-error' : '' }}" required>
                            {% if errors.password is defined %}
                                <div class="error-msg"><i class="fa-solid fa-circle-exclamation"></i> {{ errors.password }}</div>
                            {% endif %}
                        </div>
                        <div class="form-group">
                            <label for="confirm"><i class="fa-solid fa-lock"></i> Confirmer *</label>
                            <input type="password" id="confirm" name="confirm" placeholder="••••••••" class="{{ errors.confirm is defined ? 'input-error' : '' }}" required>
                            {% if errors.confirm is defined %}
                                <div class="error-msg"><i class="fa-solid fa-circle-exclamation"></i> {{ errors.confirm }}</div>
                            {% endif %}
                        </div>
                    </div>

                    <div class="form-actions">
                        <a href="{{ path('app_user_management') }}" class="btn btn-outline">Annuler</a>
                        <button type="submit" class="btn btn-danger"><i class="fa-solid fa-user-shield"></i> Créer l'Administrateur</button>
                    </div>
                </form>
            </div>
        </div>
    </main>
</body>
</html>
