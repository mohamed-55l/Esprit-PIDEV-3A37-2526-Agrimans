<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Gestion des Utilisateurs | Agrimans Admin</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        :root {
            --primary: #198B61;
            --dark: #12181b;
            --dark-card: #1e2529;
            --text-main: #f8f9fa;
            --text-muted: #9ba4b5;
            --border: rgba(255,255,255,0.08);
            --danger: #e74c3c;
            --success: #2ecc71;
            --warning: #f1c40f;
            --sidebar-width: 260px;
        }
        * { margin:0; padding:0; box-sizing:border-box; font-family:'Inter',sans-serif; }
        body { background:var(--dark); color:var(--text-main); display:flex; min-height:100vh; }

        /* SIDEBAR */
        .sidebar { width:var(--sidebar-width); background:var(--dark-card); border-right:1px solid var(--border); position:fixed; height:100vh; display:flex; flex-direction:column; }
        .sidebar-header { padding:1.5rem 1rem; border-bottom:1px solid var(--border); display:flex; align-items:center; gap:.8rem; }
        .sidebar-header i { color:var(--danger); font-size:1.4rem; }
        .sidebar-nav { padding:1.2rem .8rem; flex:1; }
        .nav-item { display:flex; align-items:center; gap:.8rem; padding:.75rem 1rem; border-radius:10px; text-decoration:none; color:var(--text-muted); font-weight:500; font-size:.9rem; transition:all .25s; margin-bottom:.2rem; }
        .nav-item:hover, .nav-item.active { background:rgba(231,76,60,.1); color:var(--danger); }
        .nav-section { font-size:.72rem; text-transform:uppercase; letter-spacing:1px; color:var(--text-muted); padding:.8rem .5rem .4rem; font-weight:600; }
        .sidebar-footer { padding:1rem; border-top:1px solid var(--border); }

        /* MAIN */
        .main { margin-left:var(--sidebar-width); flex:1; display:flex; flex-direction:column; min-height:100vh; }
        .topbar { height:72px; background:var(--dark-card); border-bottom:1px solid var(--border); display:flex; align-items:center; justify-content:space-between; padding:0 2rem; }
        .topbar-title { font-size:1.2rem; font-weight:700; color:white; }
        .topbar-actions { display:flex; gap:.8rem; }

        .btn { display:inline-flex; align-items:center; gap:.5rem; padding:.55rem 1.2rem; border-radius:8px; border:none; font-size:.875rem; font-weight:500; cursor:pointer; text-decoration:none; transition:all .2s; }
        .btn-primary { background:var(--primary); color:white; }
        .btn-primary:hover { background:#147350; }
        .btn-danger { background:var(--danger); color:white; }
        .btn-danger:hover { background:#c0392b; }
        .btn-outline { background:transparent; border:1px solid var(--border); color:var(--text-muted); }
        .btn-outline:hover { border-color:var(--primary); color:var(--primary); }
        .btn-sm { padding:.35rem .8rem; font-size:.8rem; }
        .btn-warning { background:rgba(241,196,15,.15); color:var(--warning); border:1px solid rgba(241,196,15,.3); }
        .btn-warning:hover { background:rgba(241,196,15,.25); }

        /* CONTENT */
        .content { padding:2rem; }
        .page-header { display:flex; align-items:center; justify-content:space-between; margin-bottom:2rem; }
        .page-title { font-size:1.6rem; font-weight:700; }
        .page-subtitle { color:var(--text-muted); font-size:.9rem; margin-top:.2rem; }
        .header-btns { display:flex; gap:.8rem; }

        /* FLASH MESSAGES */
        .flash { padding:.85rem 1.2rem; border-radius:10px; margin-bottom:1.5rem; display:flex; align-items:center; gap:.8rem; font-size:.9rem; }
        .flash-success { background:rgba(46,204,113,.12); border:1px solid rgba(46,204,113,.3); color:#2ecc71; }
        .flash-error { background:rgba(231,76,60,.12); border:1px solid rgba(231,76,60,.3); color:var(--danger); }

        /* STATS */
        .stats-row { display:grid; grid-template-columns:repeat(3,1fr); gap:1.2rem; margin-bottom:2rem; }
        .stat-box { background:var(--dark-card); border:1px solid var(--border); border-radius:14px; padding:1.3rem 1.5rem; display:flex; align-items:center; gap:1rem; }
        .stat-icon { width:44px; height:44px; border-radius:10px; display:flex; align-items:center; justify-content:center; font-size:1.2rem; }
        .stat-icon.blue  { background:rgba(52,152,219,.12); color:#3498db; }
        .stat-icon.green { background:rgba(46,204,113,.12); color:var(--success); }
        .stat-icon.red   { background:rgba(231,76,60,.12);  color:var(--danger); }
        .stat-num  { font-size:1.8rem; font-weight:700; color:white; }
        .stat-lbl  { font-size:.8rem; color:var(--text-muted); }

        /* SEARCH BAR */
        .search-bar { position:relative; margin-bottom:1.5rem; }
        .search-bar input { width:100%; background:var(--dark-card); border:1px solid var(--border); color:var(--text-main); padding:.7rem 1rem .7rem 2.8rem; border-radius:10px; font-size:.9rem; transition:border-color .2s; }
        .search-bar input:focus { outline:none; border-color:var(--primary); }
        .search-bar i { position:absolute; left:1rem; top:50%; transform:translateY(-50%); color:var(--text-muted); }

        /* TABLE */
        .table-card { background:var(--dark-card); border:1px solid var(--border); border-radius:16px; overflow:hidden; }
        table { width:100%; border-collapse:collapse; }
        th { background:rgba(255,255,255,.03); padding:1rem 1.2rem; text-align:left; font-size:.8rem; text-transform:uppercase; letter-spacing:.5px; color:var(--text-muted); border-bottom:1px solid var(--border); }
        td { padding:1rem 1.2rem; border-bottom:1px solid var(--border); font-size:.9rem; vertical-align:middle; }
        tr:last-child td { border-bottom:none; }
        tr:hover td { background:rgba(255,255,255,.02); }

        .avatar-cell { display:flex; align-items:center; gap:.8rem; }
        .avatar { width:36px; height:36px; border-radius:50%; display:flex; align-items:center; justify-content:center; font-weight:700; font-size:.9rem; flex-shrink:0; }
        .avatar.admin { background:rgba(231,76,60,.2); color:var(--danger); }
        .avatar.user  { background:rgba(52,152,219,.2); color:#3498db; }

        .badge { display:inline-flex; align-items:center; gap:.4rem; padding:.3rem .8rem; border-radius:20px; font-size:.75rem; font-weight:600; }
        .badge-admin { background:rgba(231,76,60,.15); color:var(--danger); border:1px solid rgba(231,76,60,.3); }
        .badge-user  { background:rgba(52,152,219,.15); color:#3498db; border:1px solid rgba(52,152,219,.3); }

        .actions { display:flex; gap:.5rem; align-items:center; }
        .empty-state { text-align:center; padding:4rem; color:var(--text-muted); }
        .empty-state i { font-size:3rem; margin-bottom:1rem; opacity:.4; }
    </style>
</head>
<body>
    {% include 'admin/_sidebar.html.twig' with {active: 'users'} %}

    <!-- MAIN -->
    <main class="main">
        <header class="topbar">
            <div class="topbar-title"><i class="fa-solid fa-users" style="color:var(--danger);margin-right:.5rem;"></i> Gestion des Utilisateurs</div>
            <div class="topbar-actions">
                <a href="{{ path('app_create_user') }}" class="btn btn-outline"><i class="fa-solid fa-user-plus"></i> Nouvel Utilisateur</a>
                <a href="{{ path('app_create_admin') }}" class="btn btn-danger"><i class="fa-solid fa-user-shield"></i> Nouvel Admin</a>
            </div>
        </header>

        <div class="content">
            <!-- Flash messages -->
            {% for msg in app.flashes('success') %}
                <div class="flash flash-success"><i class="fa-solid fa-circle-check"></i> {{ msg }}</div>
            {% endfor %}
            {% for msg in app.flashes('error') %}
                <div class="flash flash-error"><i class="fa-solid fa-circle-xmark"></i> {{ msg }}</div>
            {% endfor %}

            <!-- Stats -->
            {% set total = users|length %}
            {% set admins = users|filter(u => u.role.value == 'ADMIN')|length %}
            {% set regular = total - admins %}
            <div class="stats-row">
                <div class="stat-box">
                    <div class="stat-icon blue"><i class="fa-solid fa-users"></i></div>
                    <div><div class="stat-num">{{ total }}</div><div class="stat-lbl">Total Utilisateurs</div></div>
                </div>
                <div class="stat-box">
                    <div class="stat-icon red"><i class="fa-solid fa-user-shield"></i></div>
                    <div><div class="stat-num">{{ admins }}</div><div class="stat-lbl">Administrateurs</div></div>
                </div>
                <div class="stat-box">
                    <div class="stat-icon green"><i class="fa-solid fa-user"></i></div>
                    <div><div class="stat-num">{{ regular }}</div><div class="stat-lbl">Utilisateurs</div></div>
                </div>
            </div>

            <!-- Search -->
            <div class="search-bar">
                <i class="fa-solid fa-search"></i>
                <input type="text" id="searchInput" placeholder="Rechercher par nom, email ou téléphone..." onkeyup="filterTable()">
            </div>

            <!-- Table -->
            <div class="table-card">
                <table id="usersTable">
                    <thead>
                        <tr>
                            <th>#</th>
                            <th>Utilisateur</th>
                            <th>Email</th>
                            <th>Téléphone</th>
                            <th>Rôle</th>
                            <th>Créé le</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% if users is empty %}
                            <tr><td colspan="7"><div class="empty-state"><i class="fa-solid fa-users-slash"></i><p>Aucun utilisateur trouvé.</p></div></td></tr>
                        {% else %}
                            {% for user in users %}
                            <tr>
                                <td style="color:var(--text-muted);font-size:.8rem;">{{ user.id }}</td>
                                <td>
                                    <div class="avatar-cell">
                                        <div class="avatar {{ user.role.value == 'ADMIN' ? 'admin' : 'user' }}">
                                            {{ user.fullName|slice(0,1)|upper }}
                                        </div>
                                        <span style="font-weight:500;">{{ user.fullName }}</span>
                                    </div>
                                </td>
                                <td style="color:var(--text-muted);">{{ user.email }}</td>
                                <td style="color:var(--text-muted);">{{ user.phone }}</td>
                                <td>
                                    <span class="badge {{ user.role.value == 'ADMIN' ? 'badge-admin' : 'badge-user' }}">
                                        <i class="fa-solid {{ user.role.value == 'ADMIN' ? 'fa-user-shield' : 'fa-user' }}"></i>
                                        {{ user.role.value }}
                                    </span>
                                </td>
                                <td style="color:var(--text-muted);font-size:.85rem;">
                                    {{ user.createdAt ? user.createdAt|date('d/m/Y') : '—' }}
                                </td>
                                <td>
                                    <div class="actions">
                                        <!-- Toggle rôle -->
                                        <form method="post" action="{{ path('app_user_toggle_role', {id: user.id}) }}" style="display:inline;">
                                            <input type="hidden" name="_token" value="{{ csrf_token('toggle_role_' ~ user.id) }}">
                                            <button type="submit" class="btn btn-warning btn-sm" title="{{ user.role.value == 'ADMIN' ? 'Rétrograder en Utilisateur' : 'Promouvoir en Admin' }}">
                                                <i class="fa-solid {{ user.role.value == 'ADMIN' ? 'fa-user-minus' : 'fa-user-shield' }}"></i>
                                                {{ user.role.value == 'ADMIN' ? 'Rétrograder' : 'Promouvoir' }}
                                            </button>
                                        </form>
                                        <!-- Supprimer -->
                                        <form method="post" action="{{ path('app_user_delete', {id: user.id}) }}" style="display:inline;" onsubmit="return confirm('Supprimer {{ user.fullName }} ?')">
                                            <input type="hidden" name="_token" value="{{ csrf_token('delete_user_' ~ user.id) }}">
                                            <button type="submit" class="btn btn-danger btn-sm" title="Supprimer">
                                                <i class="fa-solid fa-trash"></i>
                                            </button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                            {% endfor %}
                        {% endif %}
                    </tbody>
                </table>
            </div>
        </div>
    </main>

    <script>
        function filterTable() {
            const input = document.getElementById('searchInput').value.toLowerCase();
            const rows = document.querySelectorAll('#usersTable tbody tr');
            rows.forEach(row => {
                const text = row.textContent.toLowerCase();
                row.style.display = text.includes(input) ? '' : 'none';
            });
        }
    </script>
</body>
</html>
