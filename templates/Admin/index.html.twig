<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <title>Admin Dashboard - Agrimans</title>
    <!-- Add FontAwesome -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <!-- Add Chart.js -->
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <style>
        :root {
            --primary: #198b61;
            --primary-dark: #126345;
            --secondary: #f4f6f8;
            --dark: #121619;
            --dark-card: #1e2529;
            --text-main: #e4e6eb;
            --text-muted: #9ba4b5;
            --border-color: rgba(255, 255, 255, 0.08);
            --danger: #e74c3c;
            --success: #2ecc71;
            --sidebar-width: 260px;
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif;
        }

        body {
            background-color: var(--dark);
            color: var(--text-main);
            display: flex;
            min-height: 100vh;
            overflow-x: hidden;
        }

        /* Sidebar Styles */
        .sidebar {
            width: var(--sidebar-width);
            background-color: var(--dark-card);
            border-right: 1px solid var(--border-color);
            position: fixed;
            height: 100vh;
            display: flex;
            flex-direction: column;
            z-index: 100;
        }

        .sidebar-header {
            height: 80px;
            display: flex;
            align-items: center;
            padding: 0 2rem;
            border-bottom: 1px solid var(--border-color);
            gap: 10px;
        }

        .logo {
            font-size: 1.5rem;
            font-weight: 800;
            color: white;
            letter-spacing: 1px;
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .sidebar-nav {
            padding: 1.5rem 1rem;
            flex: 1;
            overflow-y: auto;
        }

        .nav-section-title {
            font-size: 0.75rem;
            text-transform: uppercase;
            letter-spacing: 1.5px;
            color: var(--text-muted);
            margin: 1.5rem 0 0.8rem 1rem;
            font-weight: 600;
        }

        .nav-item {
            display: flex;
            align-items: center;
            gap: 12px;
            padding: 0.8rem 1rem;
            color: var(--text-muted);
            text-decoration: none;
            border-radius: 10px;
            margin-bottom: 0.3rem;
            transition: all 0.3s ease;
            font-weight: 500;
        }

        .nav-item:hover, .nav-item.active {
            background-color: rgba(25, 139, 97, 0.1);
            color: var(--primary);
        }

        .nav-item i {
            width: 20px;
            text-align: center;
            font-size: 1.1rem;
        }

        .sidebar-footer {
            padding: 1.5rem;
            border-top: 1px solid var(--border-color);
        }

        /* Main Content Styles */
        .main-content {
            margin-left: var(--sidebar-width);
            flex: 1;
            display: flex;
            flex-direction: column;
            min-height: 100vh;
        }

        .topbar {
            height: 80px;
            padding: 0 2rem;
            display: flex;
            align-items: center;
            justify-content: space-between;
            background-color: var(--dark-card);
            border-bottom: 1px solid var(--border-color);
        }

        .topbar-search {
            position: relative;
            width: 300px;
        }

        .topbar-search input {
            width: 100%;
            background-color: var(--dark);
            border: 1px solid var(--border-color);
            color: var(--text-main);
            padding: 0.6rem 1rem 0.6rem 2.5rem;
            border-radius: 8px;
            font-size: 0.9rem;
            transition: all 0.3s ease;
        }

        .topbar-search input:focus {
            outline: none;
            border-color: var(--primary);
            box-shadow: 0 0 0 2px rgba(25, 139, 97, 0.2);
        }

        .topbar-search i {
            position: absolute;
            left: 1rem;
            top: 50%;
            transform: translateY(-50%);
            color: var(--text-muted);
        }

        .user-menu {
            display: flex;
            align-items: center;
            gap: 1.5rem;
        }

        .icon-btn {
            background: none;
            border: none;
            color: var(--text-muted);
            font-size: 1.2rem;
            cursor: pointer;
            position: relative;
            transition: color 0.3s ease;
        }

        .icon-btn:hover {
            color: var(--primary);
        }

        .user-profile {
            display: flex;
            align-items: center;
            gap: 1rem;
            padding: 0.4rem;
            border-radius: 30px;
            background-color: var(--dark);
            border: 1px solid var(--border-color);
            cursor: pointer;
        }

        .avatar {
            width: 35px;
            height: 35px;
            border-radius: 50%;
            background-color: var(--danger);
            display: flex;
            align-items: center;
            justify-content: center;
            font-weight: bold;
            color: white;
        }

        .user-info {
            display: flex;
            flex-direction: column;
            padding-right: 1rem;
        }

        .user-name {
            font-size: 0.9rem;
            font-weight: 600;
        }

        .user-role {
            font-size: 0.75rem;
            color: var(--text-muted);
        }

        /* Dashboard Container */
        .dashboard-container {
            padding: 2rem;
            flex: 1;
        }

        .page-header {
            margin-bottom: 2rem;
        }

        .page-title {
            font-size: 1.8rem;
            font-weight: 700;
            color: white;
            margin-bottom: 0.5rem;
        }

        .page-subtitle {
            color: var(--text-muted);
            font-size: 0.95rem;
        }

        /* Stat Cards */
        .stats-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
            gap: 1.5rem;
            margin-bottom: 2rem;
        }

        .stat-card {
            background: linear-gradient(145deg, var(--dark-card), #161c20);
            border: 1px solid var(--border-color);
            border-radius: 16px;
            padding: 1.5rem;
            display: flex;
            flex-direction: column;
            position: relative;
            overflow: hidden;
            transition: transform 0.3s ease, box-shadow 0.3s ease;
        }

        .stat-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 10px 20px rgba(0,0,0,0.2);
            border-color: rgba(231, 76, 60, 0.4);
        }

        .stat-icon {
            width: 48px;
            height: 48px;
            border-radius: 12px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.5rem;
            margin-bottom: 1rem;
        }

        .stat-icon.green { background-color: rgba(46, 204, 113, 0.1); color: var(--success); }
        .stat-icon.blue { background-color: rgba(52, 152, 219, 0.1); color: #3498db; }
        .stat-icon.red { background-color: rgba(231, 76, 60, 0.1); color: var(--danger); }
        .stat-icon.purple { background-color: rgba(155, 89, 182, 0.1); color: #9b59b6; }

        .stat-value {
            font-size: 2.2rem;
            font-weight: 700;
            margin-bottom: 0.2rem;
            color: white;
        }

        .stat-label {
            color: var(--text-muted);
            font-size: 0.9rem;
            font-weight: 500;
        }

        /* Table */
        .table-container {
            background: var(--dark-card);
            border: 1px solid var(--border-color);
            border-radius: 16px;
            padding: 1.5rem;
            overflow-x: auto;
        }
        table {
            width: 100%;
            border-collapse: collapse;
            color: var(--text-light);
        }
        th, td {
            padding: 12px 15px;
            text-align: left;
            border-bottom: 1px solid var(--border-color);
        }
        th {
            background-color: rgba(255,255,255,0.02);
            font-weight: 600;
            color: var(--text-muted);
            text-transform: uppercase;
            font-size: 0.8rem;
            letter-spacing: 1px;
        }
        tr:hover td {
            background-color: rgba(255,255,255,0.01);
        }
        .btn {
            padding: 6px 12px;
            border-radius: 6px;
            text-decoration: none;
            font-size: 0.9rem;
            display: inline-block;
            margin-right: 5px;
            border: none;
            cursor: pointer;
            transition: all 0.2s;
        }
        .btn.update { background-color: rgba(52, 152, 219, 0.15); color: #3498db; }
        .btn.update:hover { background-color: rgba(52, 152, 219, 0.3); }
        .btn.delete { background-color: rgba(231, 76, 60, 0.15); color: #e74c3c; }
        .btn.delete:hover { background-color: rgba(231, 76, 60, 0.3); }
    </style>
</head>
<body>
    <!-- Sidebar -->
    <aside class="sidebar">
        <div class="sidebar-header">
            <div class="logo">
                <i class="fa-solid fa-leaf" style="color: var(--primary-color);"></i>
                Agrimans
            </div>
        </div>

        <div class="sidebar-nav">
            <div class="nav-section-title">Principal</div>
            <a href="{{ path('admin_dashboard') }}" class="nav-item active">
                <i class="fa-solid fa-house"></i>
                Dashboard
            </a>
            
            <div class="nav-section-title">Utilisateurs</div>
            <a href="#" class="nav-item">
                <i class="fa-solid fa-users"></i>
                Gestion Utilisateurs
            </a>
            <a href="{{ path('app_create_admin') }}" class="nav-item">
                <i class="fa-solid fa-user-shield"></i>
                Créer Admin
            </a>
            <a href="{{ path('app_create_user') }}" class="nav-item">
                <i class="fa-solid fa-user-plus"></i>
                Créer Utilisateur
            </a>

            <div class="nav-section-title">Modules</div>
            <a href="#" class="nav-item">
                <i class="fa-solid fa-tractor"></i>
                Équipements (À venir)
            </a>
            <a href="#" class="nav-item">
                <i class="fa-solid fa-store"></i>
                Boutique (À venir)
            </a>
        </div>

        <div class="sidebar-footer">
            <a href="{{ path('app_home') }}" class="nav-item" style="color: var(--text-muted);">
                <i class="fa-solid fa-arrow-left"></i>
                Retour au site
            </a>
        </div>
    </aside>

    <!-- Main Content -->
    <main class="main-content">
        <!-- Topbar -->
        <header class="topbar">
            <div class="topbar-search">
                <i class="fa-solid fa-search"></i>
                <input type="text" placeholder="Rechercher dans l'admin...">
            </div>

            <div class="user-menu">
                <div class="user-profile">
                    <div class="avatar">
                        A
                    </div>
                    <div class="user-info">
                        <span class="user-name">Administrateur</span>
                        <span class="user-role" style="color: var(--danger);">Super Admin</span>
                    </div>
                </div>
                <a href="{{ path('app_logout') }}" class="icon-btn" style="margin-left: 0.5rem;" title="Déconnexion">
                    <i class="fa-solid fa-sign-out-alt"></i>
                </a>
            </div>
        </header>

        <!-- Dashboard Content -->
        <div class="dashboard-container">
            <div class="page-header">
                <h1 class="page-title">Dashboard Administrateur</h1>
                <p class="page-subtitle">Gérez l'application et administrez les utilisateurs.</p>
            </div>

            <!-- Stat Cards Grid -->
            <div class="stats-grid">
                <div class="stat-card">
                    <div class="stat-icon blue">
                        <i class="fa-solid fa-users"></i>
                    </div>
                    <div class="stat-value">{{ stats.total_users|default(0) }}</div>
                    <div class="stat-label">Utilisateurs Inscrits</div>
                </div>

                <div class="stat-card">
                    <div class="stat-icon green">
                        <i class="fa-solid fa-bag-shopping"></i>
                    </div>
                    <div class="stat-value">{{ stats.total_products|default('—') }}</div>
                    <div class="stat-label">Produits en Boutique</div>
                </div>

                <div class="stat-card">
                    <div class="stat-icon" style="background:rgba(25,139,97,0.12);color:#2ecc71;">
                        <i class="fa-solid fa-tractor"></i>
                    </div>
                    <div class="stat-value">{{ stats.total_equipements|default(0) }}</div>
                    <div class="stat-label">Équipements</div>
                </div>

                <div class="stat-card">
                    <div class="stat-icon" style="background:rgba(241,196,15,0.12);color:#f1c40f;">
                        <i class="fa-solid fa-star"></i>
                    </div>
                    <div class="stat-value">{{ stats.total_reviews|default(0) }}</div>
                    <div class="stat-label">Avis Utilisateurs</div>
                </div>
            </div>

            <!-- Main Actions & Table -->
            <div class="table-container">
                <div class="card-header" style="margin-bottom: 20px; display: flex; justify-content: space-between; align-items: center;">
                    <h3 class="card-title">Liste des Utilisateurs</h3>
                    <div>
                        <a href="{{ path('app_create_admin') }}" class="btn update"><i class="fa-solid fa-plus"></i> Admin</a>
                        <a href="{{ path('app_create_user') }}" class="btn update" style="background: #2ecc71;"><i class="fa-solid fa-plus"></i> Utilisateur</a>
                    </div>
                </div>
                
                <table>
                    <thead>
                        <tr>
                            <th>ID</th>
                            <th>Nom</th>
                            <th>Email</th>
                            <th>Phone</th>
                            <th>Role</th>
                            <th>Date Création</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                    {% for user in users %}
                        <tr>
                            <td>{{ user.id }}</td>
                            <td>{{ user.fullName }}</td>
                            <td>{{ user.email }}</td>
                            <td>{{ user.phone }}</td>
                            <td>
                                {% set r = user.role.value is defined ? user.role.value : user.role %}
                                <span style="padding: 4px 8px; border-radius: 4px; font-size: 0.8rem; background: {{ r == 'ADMIN' ? 'rgba(231, 76, 60, 0.2)' : 'rgba(52, 152, 219, 0.2)' }}; color: {{ r == 'ADMIN' ? '#e74c3c' : '#3498db' }};">
                                    {{ r }}
                                </span>
                            </td>
                            <td>{{ user.createdAt|date('d/m/Y H:i') }}</td>
                            <td>
                                <a href="{{ path('user_update', {id: user.id}) }}" class="btn update"><i class="fa-solid fa-pen"></i></a>
                                <a href="{{ path('user_delete', {id: user.id}) }}" class="btn delete" onclick="return confirm('Êtes-vous sûr de vouloir supprimer cet utilisateur ?')"><i class="fa-solid fa-trash"></i></a>
                            </td>
                        </tr>
                    {% else %}
                        <tr>
                            <td colspan="7" style="text-align: center; padding: 20px;">Aucun utilisateur trouvé dans la base de données.</td>
                        </tr>
                    {% endfor %}
                    </tbody>
                </table>
            </div>

        </div>
    </main>
</body>
</html>
