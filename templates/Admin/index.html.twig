<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Dashboard Administrateur | Agrimans</title>
    
    <!-- Fonts & Icons -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <!-- Chart.js -->
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

    <style>
        :root {
            --primary: #198B61;
            --dark: #12181b;
            --dark-card: #1e2529;
            --text-main: #f8f9fa;
            --text-muted: #9ba4b5;
            --border: rgba(255,255,255,0.08);
            --danger: #e74c3c;
            --warning: #f1c40f;
            --success: #2ecc71;
            --sidebar-width: 260px;
        }
        * { margin:0; padding:0; box-sizing:border-box; font-family:'Inter',sans-serif; }
        body { background:var(--dark); color:var(--text-main); display:flex; min-height:100vh; }

        /* ── SIDEBAR (version compacte unifiée) ── */
        .sidebar { width:var(--sidebar-width); background:var(--dark-card); border-right:1px solid var(--border); position:fixed; height:100vh; display:flex; flex-direction:column; z-index:100; }
        .sidebar-header { padding:1.2rem 1rem; border-bottom:1px solid var(--border); display:flex; align-items:center; gap:.8rem; }
        .sidebar-header i { color:var(--danger); font-size:1.4rem; }
        .sidebar-header span { font-size:1.05rem; font-weight:700; color:white; }
        .sidebar-header sup { color:var(--danger); font-size:.6rem; vertical-align:top; }
        .sidebar-nav { padding:1rem .8rem; flex:1; overflow-y:auto; }
        .nav-item { display:flex; align-items:center; gap:.8rem; padding:.7rem 1rem; border-radius:10px; text-decoration:none; color:var(--text-muted); font-weight:500; font-size:.875rem; transition:all .25s; margin-bottom:.2rem; }
        .nav-item:hover, .nav-item.active { background:rgba(231,76,60,.1); color:var(--danger); }
        .nav-item i { width:18px; text-align:center; font-size:1rem; }
        .nav-section { font-size:.68rem; text-transform:uppercase; letter-spacing:1px; color:var(--text-muted); padding:.9rem .5rem .3rem; font-weight:600; }
        .sidebar-footer { padding:.8rem; border-top:1px solid var(--border); }
        .nav-item-logout:hover { background:rgba(231,76,60,.15); color:var(--danger); }

        /* ── MAIN ── */
        .main-content { margin-left:var(--sidebar-width); flex:1; display:flex; flex-direction:column; min-height:100vh; }
        .topbar { height:72px; padding:0 2rem; display:flex; align-items:center; justify-content:space-between; background:var(--dark-card); border-bottom:1px solid var(--border); }

        .topbar-search {
            position: relative;
            width: 300px;
        }

        .topbar-search input {
            width: 100%;
            background-color: var(--dark);
            border: 1px solid var(--border-color);
            color: var(--text-main);
            padding: 0.6rem 1rem 0.6rem 2.5rem;
            border-radius: 8px;
            font-size: 0.9rem;
            transition: all 0.3s ease;
        }

        .topbar-search input:focus {
            outline: none;
            border-color: var(--primary);
            box-shadow: 0 0 0 2px rgba(25, 139, 97, 0.2);
        }

        .topbar-search i {
            position: absolute;
            left: 1rem;
            top: 50%;
            transform: translateY(-50%);
            color: var(--text-muted);
        }

        .user-menu {
            display: flex;
            align-items: center;
            gap: 1.5rem;
        }

        .icon-btn {
            background: none;
            border: none;
            color: var(--text-muted);
            font-size: 1.2rem;
            cursor: pointer;
            position: relative;
            transition: color 0.3s ease;
        }

        .icon-btn:hover {
            color: var(--primary);
        }

        .user-profile {
            display: flex;
            align-items: center;
            gap: 1rem;
            padding: 0.4rem;
            border-radius: 30px;
            background-color: var(--dark);
            border: 1px solid var(--border-color);
            cursor: pointer;
        }

        .avatar {
            width: 35px;
            height: 35px;
            border-radius: 50%;
            background-color: var(--danger);
            display: flex;
            align-items: center;
            justify-content: center;
            font-weight: bold;
            color: white;
        }

        .user-info {
            display: flex;
            flex-direction: column;
            padding-right: 1rem;
        }

        .user-name {
            font-size: 0.9rem;
            font-weight: 600;
        }

        .user-role {
            font-size: 0.75rem;
            color: var(--text-muted);
        }

        /* Dashboard Container */
        .dashboard-container {
            padding: 2rem;
            flex: 1;
        }

        .page-header {
            margin-bottom: 2rem;
        }

        .page-title {
            font-size: 1.8rem;
            font-weight: 700;
            color: white;
            margin-bottom: 0.5rem;
        }

        .page-subtitle {
            color: var(--text-muted);
            font-size: 0.95rem;
        }

        /* Stat Cards */
        .stats-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
            gap: 1.5rem;
            margin-bottom: 2rem;
        }

        .stat-card {
            background: linear-gradient(145deg, var(--dark-card), #161c20);
            border: 1px solid var(--border-color);
            border-radius: 16px;
            padding: 1.5rem;
            display: flex;
            flex-direction: column;
            position: relative;
            overflow: hidden;
            transition: transform 0.3s ease, box-shadow 0.3s ease;
        }

        .stat-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 10px 20px rgba(0,0,0,0.2);
            border-color: rgba(231, 76, 60, 0.4); /* Danger color for admin hover */
        }

        .stat-icon {
            width: 48px;
            height: 48px;
            border-radius: 12px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.5rem;
            margin-bottom: 1rem;
        }

        .stat-icon.green { background-color: rgba(46, 204, 113, 0.1); color: var(--success); }
        .stat-icon.blue { background-color: rgba(52, 152, 219, 0.1); color: #3498db; }
        .stat-icon.red { background-color: rgba(231, 76, 60, 0.1); color: var(--danger); }
        .stat-icon.purple { background-color: rgba(155, 89, 182, 0.1); color: #9b59b6; }

        .stat-value {
            font-size: 2.2rem;
            font-weight: 700;
            margin-bottom: 0.2rem;
            color: white;
        }

        .stat-label {
            color: var(--text-muted);
            font-size: 0.9rem;
            font-weight: 500;
        }

        /* Charts Section */
        .charts-container {
            display: grid;
            grid-template-columns: 2fr 1fr;
            gap: 1.5rem;
            margin-bottom: 2rem;
        }

        .chart-card {
            background-color: var(--dark-card);
            border: 1px solid var(--border-color);
            border-radius: 16px;
            padding: 1.5rem;
        }

        .card-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 1.5rem;
        }

        .card-title {
            font-size: 1.1rem;
            font-weight: 600;
            color: white;
        }

        /* Quick Actions Grid */
        .actions-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 1rem;
        }

        .action-btn {
            background-color: rgba(255,255,255,0.03);
            border: 1px solid var(--border-color);
            border-radius: 12px;
            padding: 1rem;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            gap: 0.8rem;
            color: var(--text-main);
            text-decoration: none;
            transition: all 0.3s ease;
            text-align: center;
            font-size: 0.9rem;
        }

        .action-btn i {
            font-size: 1.5rem;
            color: var(--danger);
        }

        .action-btn:hover {
            background-color: rgba(231, 76, 60, 0.1);
            border-color: var(--danger);
            transform: translateY(-2px);
        }

        /* Pagination Styles */
        .pagination {
            display: flex;
            list-style: none;
            padding: 0;
            margin: 0;
            gap: 5px;
        }
        .pagination li {
            display: inline-block;
        }
        .pagination li a, .pagination li span {
            color: var(--text-main);
            background-color: var(--dark-card);
            border: 1px solid var(--border-color);
            padding: 0.5rem 0.75rem;
            border-radius: 5px;
            text-decoration: none;
            font-size: 0.9rem;
            transition: all 0.2s ease;
        }
        .pagination li a:hover {
            background-color: var(--danger);
            border-color: var(--danger);
            color: white;
        }
        .pagination li.active span {
            background-color: var(--danger);
            border-color: var(--danger);
            color: white;
        }
        .pagination li.disabled span {
            color: var(--text-muted);
            opacity: 0.5;
            cursor: not-allowed;
        }

        @media (max-width: 992px) {
            .charts-container { grid-template-columns: 1fr; }
        }
    </style>
</head>
<body>

    {% include 'admin/_sidebar.html.twig' with {active: 'dashboard'} %}

    <!-- Main Content -->
    <main class="main-content">
        <!-- Topbar -->
        <header class="topbar">
            <div class="topbar-search">
                <i class="fa-solid fa-search"></i>
                <input type="text" placeholder="Rechercher dans l'admin...">
            </div>

            <div class="user-menu">
                <div class="user-profile">
                    <div class="avatar">
                        {{ app.user ? app.user.userIdentifier|slice(0,1)|upper : 'A' }}
                    </div>
                    <div class="user-info">
                        <span class="user-name">{{ app.user ? app.user.userIdentifier : 'Administrateur' }}</span>
                        <span class="user-role" style="color: var(--danger);">Super Admin</span>
                    </div>
                    <i class="fa-solid fa-chevron-down" style="color: var(--text-muted); font-size: 0.8rem;"></i>
                </div>
                <a href="{{ path('app_logout') }}" class="icon-btn" style="margin-left: 0.5rem;" title="Déconnexion">
                    <i class="fa-solid fa-sign-out-alt"></i>
                </a>
            </div>
        </header>

        <!-- Dashboard Content -->
        <div class="dashboard-container">
            <div class="page-header">
                <h1 class="page-title">{% if view_mode is defined and view_mode == 'parcelles_cultures' %}Visualisation Parcelle & Culture{% else %}Dashboard Administrateur{% endif %}</h1>
                <p class="page-subtitle">{% if view_mode is defined and view_mode == 'parcelles_cultures' %}Consultez les données des parcelles et cultures en lecture seule.{% else %}Gérez l'application, surveillez l'activité et administrez les utilisateurs.{% endif %}</p>
            </div>

            <!-- Stat Cards Grid (Always visible) -->
            <div class="stats-grid">
                <div class="stat-card">
                    <div class="stat-icon blue">
                        <i class="fa-solid fa-users"></i>
                    </div>
                    <div class="stat-value">{{ stats.total_users|default(0) }}</div>
                    <div class="stat-label">Utilisateurs Inscrits</div>
                </div>

                <div class="stat-card">
                    <div class="stat-icon green">
                        <i class="fa-solid fa-bag-shopping"></i>
                    </div>
                    <div class="stat-value">{{ stats.total_products|default(0) }}</div>
                    <div class="stat-label">Produits en Boutique</div>
                </div>

                <div class="stat-card">
                    <div class="stat-icon purple">
                        <i class="fa-solid fa-shopping-cart"></i>
                    </div>
                    <div class="stat-value">{{ stats.total_orders|default(0) }}</div>
                    <div class="stat-label">Commandes Marketplace</div>
                </div>

                <div class="stat-card" style="cursor:pointer;" onclick="location.href='{{ path('admin_equipement_index') }}'">
                    <div class="stat-icon" style="background:rgba(25,139,97,0.12);color:#2ecc71;">
                        <i class="fa-solid fa-tractor"></i>
                    </div>
                    <div class="stat-value">{{ stats.total_equipements|default(0) }}</div>
                    <div class="stat-label">Équipements</div>
                </div>

                <div class="stat-card" style="cursor:pointer;" onclick="location.href='{{ path('admin_review_index') }}'">
                    <div class="stat-icon" style="background:rgba(241,196,15,0.12);color:#f1c40f;">
                        <i class="fa-solid fa-star"></i>
                    </div>
                    <div class="stat-value">{{ stats.total_reviews|default(0) }}</div>
                    <div class="stat-label">Avis Utilisateurs</div>
                </div>
            </div>

            {% if view_mode is defined and view_mode == 'parcelles_cultures' %}
                <div class="row" style="display:flex; gap:1.5rem;">
                    <div class="col-md-6">
                        <div class="chart-card">
                            <div class="card-header">
                                <h3 class="card-title">Parcelles ({{ parcelles.getTotalItemCount }})</h3>
                            </div>
                            <div class="table-responsive">
                                <table class="table table-striped" style="color: var(--text-main);">
                                    <thead>
                                        <tr>
                                            <th>ID</th>
                                            <th>Nom</th>
                                            <th>Superficie (ha)</th>
                                            <th>Localisation</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        {% for parcelle in parcelles %}
                                            <tr>
                                                <td>{{ parcelle.id }}</td>
                                                <td>{{ parcelle.nom }}</td>
                                                <td>{{ parcelle.superficie }}</td>
                                                <td>{{ parcelle.localisation }}</td>
                                            </tr>
                                        {% else %}
                                            <tr>
                                                <td colspan="4" class="text-center" style="color: var(--text-muted);">Aucune parcelle trouvée</td>
                                            </tr>
                                        {% endfor %}
                                    </tbody>
                                </table>
                            </div>
                            {% if parcelles.getTotalItemCount > 0 %}
                            <div style="padding: 1rem; border-top: 1px solid rgba(255,255,255,0.08); display: flex; justify-content: center;">
                                {{ knp_pagination_render(parcelles) }}
                            </div>
                            {% endif %}
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="chart-card">
                            <div class="card-header">
                                <h3 class="card-title">Cultures ({{ cultures.getTotalItemCount }})</h3>
                            </div>
                            <div class="table-responsive">
                                <table class="table table-striped" style="color: var(--text-main);">
                                    <thead>
                                        <tr>
                                            <th>ID</th>
                                            <th>Nom</th>
                                            <th>Type Culture</th>
                                            <th>État Culture</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        {% for culture in cultures %}
                                            <tr>
                                                <td>{{ culture.id }}</td>
                                                <td>{{ culture.nom }}</td>
                                                <td>{{ culture.type_culture }}</td>
                                                <td>{{ culture.etat_culture }}</td>
                                            </tr>
                                        {% else %}
                                            <tr>
                                                <td colspan="4" class="text-center" style="color: var(--text-muted);">Aucune culture trouvée</td>
                                            </tr>
                                        {% endfor %}
                                    </tbody>
                                </table>
                            </div>
                            {% if cultures.getTotalItemCount > 0 %}
                            <div style="padding: 1rem; border-top: 1px solid rgba(255,255,255,0.08); display: flex; justify-content: center;">
                                {{ knp_pagination_render(cultures) }}
                            </div>
                            {% endif %}
                        </div>
                    </div>
                </div>
            {% else %}
                <!-- Main Charts & Actions -->
            <div class="charts-container">
                <div class="chart-card">
                    <div class="card-header">
                        <h3 class="card-title">Évolution des Inscriptions</h3>
                    </div>
                    <!-- Chart Canvas -->
                    <div style="height: 300px; width: 100%;">
                        <canvas id="adminChart"></canvas>
                    </div>
                </div>

                <div class="chart-card">
                    <div class="card-header">
                        <h3 class="card-title">Actions Rapides</h3>
                    </div>
                    <div class="actions-grid">
                        <a href="{{ path('app_create_admin') }}" class="action-btn">
                            <i class="fa-solid fa-user-shield"></i>
                            <span>Créer Admin</span>
                        </a>
                        <a href="{{ path('app_create_user') }}" class="action-btn">
                            <i class="fa-solid fa-user-plus"></i>
                            <span>Créer Utilisateur</span>
                        </a>
                        <a href="{{ path('admin_equipement_index') }}" class="action-btn">
                            <i class="fa-solid fa-tractor"></i>
                            <span>Gérer Équipements</span>
                        </a>
                        <a href="{{ path('admin_review_index') }}" class="action-btn">
                            <i class="fa-solid fa-star"></i>
                            <span>Gérer les Avis</span>
                        </a>
                    </div>
                </div>
            </div>

            <!-- NOUVEAUX GRAPHIQUES (ÉQUIPEMENTS & REVIEWS) -->
            <div class="charts-container" style="grid-template-columns: 1fr 1fr;">
                <div class="chart-card">
                    <div class="card-header">
                        <h3 class="card-title"><i class="fa-solid fa-tractor" style="color: #2ecc71;"></i> Disponibilité des Équipements</h3>
                    </div>
                    <div style="height: 300px; width: 100%; display: flex; justify-content: center;">
                        <canvas id="equipChart"></canvas>
                    </div>
                </div>

                <div class="chart-card">
                    <div class="card-header">
                        <h3 class="card-title"><i class="fa-solid fa-star" style="color: #f1c40f;"></i> Répartition des Notes (Avis)</h3>
                    </div>
                    <div style="height: 300px; width: 100%;">
                        <canvas id="reviewChart"></canvas>
                    </div>
                </div>
            </div><!-- end charts-container marketplace -->

            <!-- ══════════════════════════════════════════════════════════════
                 SECTION : GESTION DES ÉQUIPEMENTS (intégrée au dashboard)
            ════════════════════════════════════════════════════════════════ -->
            <div style="margin-top:2.5rem;">

                <!-- Header section -->
                <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:1.5rem;">
                    <div>
                        <h2 style="font-size:1.4rem; font-weight:700; color:white; margin:0;">
                            <i class="fa-solid fa-tractor" style="color:#2ecc71; margin-right:10px;"></i>Gestion des Équipements
                        </h2>
                        <p style="color:var(--text-muted); font-size:0.85rem; margin:0.3rem 0 0;">Gérez, assignez et surveillez le parc matériel agricole.</p>
                    </div>
                    <a href="{{ path('admin_equipement_new') }}" style="display:inline-flex; align-items:center; gap:6px; padding:0.6rem 1.2rem; background:var(--primary); color:#fff; border-radius:10px; font-size:0.9rem; font-weight:600; text-decoration:none; transition:all 0.2s;" onmouseover="this.style.background='#147350'" onmouseout="this.style.background='#198B61'">
                        <i class="fa-solid fa-plus"></i> Nouvel Équipement
                    </a>
                </div>

                <!-- Stats rapides équipements -->
                <div style="display:grid; grid-template-columns:repeat(auto-fit, minmax(160px,1fr)); gap:1rem; margin-bottom:1.5rem;">
                    <div style="background:var(--dark-card); border:1px solid var(--border); border-radius:12px; padding:1rem 1.2rem; display:flex; align-items:center; gap:0.8rem;">
                        <div style="width:38px;height:38px;border-radius:9px;background:rgba(46,204,113,0.12);color:#2ecc71;display:flex;align-items:center;justify-content:center;font-size:1.1rem;flex-shrink:0;">
                            <i class="fa-solid fa-tractor"></i>
                        </div>
                        <div>
                            <div style="font-size:1.6rem;font-weight:700;color:white;line-height:1;">{{ equip_statistics.total|default(0) }}</div>
                            <div style="font-size:0.78rem;color:var(--text-muted);">Total</div>
                        </div>
                    </div>
                    {% for dispo, count in equip_statistics.repartition|default([]) %}
                    <div style="background:var(--dark-card); border:1px solid var(--border); border-radius:12px; padding:1rem 1.2rem; display:flex; align-items:center; gap:0.8rem;">
                        <div style="width:38px;height:38px;border-radius:9px;background:rgba(241,196,15,0.12);color:#f1c40f;display:flex;align-items:center;justify-content:center;font-size:1.1rem;flex-shrink:0;">
                            <i class="fa-solid fa-tag"></i>
                        </div>
                        <div>
                            <div style="font-size:1.6rem;font-weight:700;color:white;line-height:1;">{{ count }}</div>
                            <div style="font-size:0.78rem;color:var(--text-muted);">{{ dispo }}</div>
                        </div>
                    </div>
                    {% endfor %}
                </div>

                <!-- Alerte qualité -->
                {% set alert_equipements = [] %}
                {% for eq in equipements %}
                    {% set negative_count = 0 %}
                    {% for review in eq.reviews %}
                        {% if review.commentaire|sentiment == 'Négatif' %}
                            {% set negative_count = negative_count + 1 %}
                        {% endif %}
                    {% endfor %}
                    {% if negative_count >= 3 %}
                        {% set alert_equipements = alert_equipements|merge([{'eq': eq, 'count': negative_count}]) %}
                    {% endif %}
                {% endfor %}
                {% if alert_equipements|length > 0 %}
                <div style="background:rgba(231,76,60,0.08); border-left:4px solid var(--danger); padding:1.2rem 1.5rem; border-radius:0 12px 12px 0; margin-bottom:1.5rem;">
                    <h4 style="color:var(--danger); font-size:1rem; margin-bottom:0.8rem;">
                        <i class="fa-solid fa-triangle-exclamation"></i> Alerte Qualité — {{ alert_equipements|length }} équipement(s) à surveiller
                    </h4>
                    <div style="display:flex; flex-direction:column; gap:0.4rem;">
                        {% for alert in alert_equipements %}
                        <div style="display:flex; justify-content:space-between; align-items:center; background:rgba(0,0,0,0.15); padding:0.6rem 1rem; border-radius:8px;">
                            <span style="color:white; font-weight:600;">{{ alert.eq.nom }} <span style="color:var(--text-muted); font-weight:400;">({{ alert.eq.type }})</span></span>
                            <span style="color:var(--danger); font-weight:700; font-size:0.85rem;">{{ alert.count }} avis négatifs <i class="fa-solid fa-thumbs-down"></i></span>
                        </div>
                        {% endfor %}
                    </div>
                </div>
                {% endif %}

                <!-- Tableau équipements -->
                <div style="background:var(--dark-card); border:1px solid var(--border); border-radius:16px; overflow:hidden;">
                    <div style="overflow-x:auto;">
                        <table style="width:100%; border-collapse:collapse;">
                            <thead>
                                <tr style="background:rgba(255,255,255,0.03);">
                                    <th style="padding:0.9rem 1.2rem; text-align:left; font-size:0.75rem; text-transform:uppercase; letter-spacing:.8px; color:var(--text-muted); font-weight:600; border-bottom:1px solid var(--border);">#</th>
                                    <th style="padding:0.9rem 1.2rem; text-align:left; font-size:0.75rem; text-transform:uppercase; letter-spacing:.8px; color:var(--text-muted); font-weight:600; border-bottom:1px solid var(--border);">Nom</th>
                                    <th style="padding:0.9rem 1.2rem; text-align:left; font-size:0.75rem; text-transform:uppercase; letter-spacing:.8px; color:var(--text-muted); font-weight:600; border-bottom:1px solid var(--border);">Catégorie</th>
                                    <th style="padding:0.9rem 1.2rem; text-align:left; font-size:0.75rem; text-transform:uppercase; letter-spacing:.8px; color:var(--text-muted); font-weight:600; border-bottom:1px solid var(--border);">Prix</th>
                                    <th style="padding:0.9rem 1.2rem; text-align:center; font-size:0.75rem; text-transform:uppercase; letter-spacing:.8px; color:var(--text-muted); font-weight:600; border-bottom:1px solid var(--border);">Capacité</th>
                                    <th style="padding:0.9rem 1.2rem; text-align:left; font-size:0.75rem; text-transform:uppercase; letter-spacing:.8px; color:var(--text-muted); font-weight:600; border-bottom:1px solid var(--border);">Statut</th>
                                    <th style="padding:0.9rem 1.2rem; text-align:left; font-size:0.75rem; text-transform:uppercase; letter-spacing:.8px; color:var(--text-muted); font-weight:600; border-bottom:1px solid var(--border);">Assigné à</th>
                                    <th style="padding:0.9rem 1.2rem; text-align:right; font-size:0.75rem; text-transform:uppercase; letter-spacing:.8px; color:var(--text-muted); font-weight:600; border-bottom:1px solid var(--border);">Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                            {% for eq in equipements %}
                                <tr style="border-bottom:1px solid rgba(255,255,255,0.04); transition:background 0.2s;" onmouseover="this.style.background='rgba(255,255,255,0.02)'" onmouseout="this.style.background=''">
                                    <td style="padding:0.9rem 1.2rem; font-size:0.88rem; color:var(--text-muted);">{{ eq.id }}</td>
                                    <td style="padding:0.9rem 1.2rem; font-size:0.88rem;"><strong style="color:white;">{{ eq.nom }}</strong></td>
                                    <td style="padding:0.9rem 1.2rem; font-size:0.88rem; color:var(--text-muted);">{{ eq.type }}</td>
                                    <td style="padding:0.9rem 1.2rem; font-size:0.88rem; font-weight:600; color:#2ecc71;">{{ eq.prix|number_format(2, ',', ' ') }} DT</td>
                                    <td style="padding:0.9rem 1.2rem; font-size:0.88rem; text-align:center;">
                                        {% if eq.capaciteRendement %}
                                            <span style="color:#667eea; font-weight:700;">{{ eq.capaciteRendement }} Ha/h</span>
                                        {% else %}
                                            <span style="color:var(--text-muted); font-style:italic;">—</span>
                                        {% endif %}
                                    </td>
                                    <td style="padding:0.9rem 1.2rem; font-size:0.88rem;">
                                        {% if eq.disponibilite == 'Disponible' %}
                                            <span style="display:inline-flex;align-items:center;gap:5px;padding:0.25rem 0.7rem;border-radius:20px;font-size:0.78rem;font-weight:600;background:rgba(46,204,113,0.12);color:#2ecc71;border:1px solid rgba(46,204,113,0.25);">
                                                <i class="fa-solid fa-check-circle"></i> Disponible
                                            </span>
                                        {% elseif eq.disponibilite == 'Indisponible' %}
                                            <span style="display:inline-flex;align-items:center;gap:5px;padding:0.25rem 0.7rem;border-radius:20px;font-size:0.78rem;font-weight:600;background:rgba(231,76,60,0.12);color:#e74c3c;border:1px solid rgba(231,76,60,0.25);">
                                                <i class="fa-solid fa-times-circle"></i> Indisponible
                                            </span>
                                        {% else %}
                                            <span style="display:inline-flex;align-items:center;gap:5px;padding:0.25rem 0.7rem;border-radius:20px;font-size:0.78rem;font-weight:600;background:rgba(241,196,15,0.12);color:#f1c40f;border:1px solid rgba(241,196,15,0.25);">
                                                <i class="fa-solid fa-wrench"></i> {{ eq.disponibilite }}
                                            </span>
                                        {% endif %}
                                    </td>
                                    <td style="padding:0.9rem 1.2rem; font-size:0.88rem;">
                                        {% if eq.user %}
                                            <span style="display:inline-flex;align-items:center;gap:6px;padding:0.25rem 0.65rem;background:rgba(25,139,97,0.1);border:1px solid rgba(25,139,97,0.25);border-radius:20px;font-size:0.82rem;color:var(--primary);">
                                                <i class="fa-solid fa-user"></i> {{ eq.user.fullName }}
                                            </span>
                                        {% else %}
                                            <span style="color:var(--text-muted);font-style:italic;font-size:0.85rem;"><i class="fa-solid fa-user-slash"></i> Non assigné</span>
                                        {% endif %}
                                    </td>
                                    <td style="padding:0.9rem 1.2rem;">
                                        <div style="display:flex; gap:0.4rem; justify-content:flex-end;">
                                            <a href="{{ path('admin_equipement_assign', {id: eq.id}) }}" style="display:inline-flex;align-items:center;gap:5px;padding:0.35rem 0.7rem;border-radius:7px;font-size:0.8rem;font-weight:500;text-decoration:none;background:#2980b9;color:#fff;transition:all 0.2s;" title="Assigner">
                                                <i class="fa-solid fa-user-plus"></i>
                                            </a>
                                            <a href="{{ path('admin_equipement_edit', {id: eq.id}) }}" style="display:inline-flex;align-items:center;gap:5px;padding:0.35rem 0.7rem;border-radius:7px;font-size:0.8rem;font-weight:500;text-decoration:none;background:#e67e22;color:#fff;transition:all 0.2s;" title="Modifier">
                                                <i class="fa-solid fa-pen"></i>
                                            </a>
                                            <form method="post" action="{{ path('admin_equipement_delete', {id: eq.id}) }}" onsubmit="return confirm('Supprimer cet équipement ?');" style="display:inline;">
                                                <input type="hidden" name="_token" value="{{ csrf_token('delete_eq_' ~ eq.id) }}">
                                                <button style="display:inline-flex;align-items:center;gap:5px;padding:0.35rem 0.7rem;border-radius:7px;font-size:0.8rem;font-weight:500;background:#e74c3c;color:#fff;border:none;cursor:pointer;transition:all 0.2s;" title="Supprimer">
                                                    <i class="fa-solid fa-trash"></i>
                                                </button>
                                            </form>
                                        </div>
                                    </td>
                                </tr>
                            {% else %}
                                <tr>
                                    <td colspan="8" style="text-align:center;padding:3rem;color:var(--text-muted);">
                                        <i class="fa-solid fa-box-open" style="font-size:2.5rem;margin-bottom:1rem;opacity:0.4;display:block;"></i>
                                        Aucun équipement enregistré.
                                    </td>
                                </tr>
                            {% endfor %}
                            </tbody>
                        </table>
                    </div>
                    <!-- Footer avec lien vers la page dédiée -->
                    <div style="padding:1rem 1.5rem; border-top:1px solid var(--border); display:flex; justify-content:flex-end;">
                        <a href="{{ path('admin_equipement_index') }}" style="font-size:0.85rem; color:var(--text-muted); text-decoration:none; display:flex; align-items:center; gap:6px; transition:color 0.2s;" onmouseover="this.style.color='white'" onmouseout="this.style.color=''">
                            <i class="fa-solid fa-arrow-right"></i> Voir la page dédiée
                        </a>
                    </div>
                </div>

            </div><!-- end section équipements -->

        </div><!-- end dashboard-container -->
    {% endif %}

    </main>

    <!-- Chart Config -->
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            const ctx = document.getElementById('adminChart');
            if (!ctx) return;
            
            // Gradient for chart line
            let gradient = ctx.getContext('2d').createLinearGradient(0, 0, 0, 400);
            gradient.addColorStop(0, 'rgba(52, 152, 219, 0.5)');
            gradient.addColorStop(1, 'rgba(52, 152, 219, 0.0)');

            new Chart(ctx.getContext('2d'), {
                type: 'bar',
                data: {
                    labels: ['Jan', 'Fév', 'Mar', 'Avr', 'Mai', 'Juin'],
                    datasets: [{
                        label: 'Nouveaux Utilisateurs',
                        data: [5, 12, 8, 15, 22, 18],
                        backgroundColor: '#3498db',
                        borderRadius: 6,
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: {
                        legend: { display: false },
                        tooltip: {
                            backgroundColor: '#1e2529',
                            titleColor: '#fff',
                            bodyColor: '#fff',
                            borderColor: 'rgba(255,255,255,0.1)',
                            borderWidth: 1,
                            padding: 10,
                            displayColors: false
                        }
                    },
                    scales: {
                        y: {
                            beginAtZero: true,
                            grid: {
                                color: 'rgba(255, 255, 255, 0.05)',
                                drawBorder: false
                            },
                            ticks: { color: '#9ba4b5' }
                        },
                        x: {
                            grid: { display: false },
                            ticks: { color: '#9ba4b5' }
                        }
                    }
                }
            });

            {% if chartEquipement is defined %}
            // Graphique Equipements (Pie)
            const equipCtx = document.getElementById('equipChart');
            if (equipCtx) {
                new Chart(equipCtx.getContext('2d'), {
                    type: 'pie',
                    data: {{ chartEquipement.createView().data|json_encode|raw }},
                    options: {{ chartEquipement.createView().options|json_encode|raw }}
                });
            }
            {% endif %}

            {% if chartReview is defined %}
            // Graphique Notes (Bar)
            const reviewCtx = document.getElementById('reviewChart');
            if (reviewCtx) {
                new Chart(reviewCtx.getContext('2d'), {
                    type: 'bar',
                    data: {{ chartReview.createView().data|json_encode|raw }},
                    options: {{ chartReview.createView().options|json_encode|raw }}
                });
            }
            {% endif %}

            {% if chartMarketplace is defined %}
            // Graphique Commandes Marketplace (Doughnut)
            const marketplaceCtx = document.getElementById('marketplaceChart');
            if (marketplaceCtx) {
                new Chart(marketplaceCtx.getContext('2d'), {
                    type: 'doughnut',
                    data: {{ chartMarketplace.createView().data|json_encode|raw }},
                    options: {{ chartMarketplace.createView().options|json_encode|raw }}
                });
            }
            {% endif %}
        });
    </script>
</body>
</html>
