<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <title>Admin Dashboard</title>

    <link rel="stylesheet" href="{{ asset('styles/dashboard.css') }}">
</head>
<body>

<div class="container">

    <div class="card">

        <!-- LEFT CONTENT -->
        <div class="content-box">

            <div class="header">
                <h1>🌿 Admin Dashboard</h1>
                <a href="{{ path('app_logout') }}" class="logout-btn">Logout</a>
            </div>

            <p class="subtitle">Bienvenue ADMIN 👑</p>

            <h2>Liste des utilisateurs</h2>

            <table>
                <thead>
                    <tr>
                        <th>ID</th>
                        <th>Nom</th>
                        <th>Email</th>
                        <th>Phone</th>
                        <th>Role</th>
                        <th>Created At</th>
                        <th>Actions</th>
                    </tr>
                </thead>

                <tbody>
                {% for user in users %}
                    <tr>
                        <td>{{ user.id }}</td>
                        <td>{{ user.fullName }}</td>
                        <td>{{ user.email }}</td>
                        <td>{{ user.phone }}</td>
                        <td>{{ user.role.value }}</td>
                        <td>{{ user.createdAt|date('d/m/Y H:i') }}</td>
                        <td>
                            <a href="{{ path('user_update', {id: user.id}) }}" class="btn update">
                                Modifier
                            </a>

                            <a href="{{ path('user_delete', {id: user.id}) }}"
                               class="btn delete"
                               onclick="return confirm('Supprimer ?')">
                                Supprimer
                            </a>
                        </td>
                    </tr>
                {% else %}
                    <tr>
                        <td colspan="6">Aucun utilisateur</td>
                    </tr>
                {% endfor %}
                </tbody>

            </table>

        </div>

       

    </div>

</div>

</body>
</html>