<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Gestion des Garages | Admin Agrimans</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    
    <!-- Leaflet CSS & JS -->
    <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" integrity="sha256-p4NxAoJBhIIN+hmNHrzRCf9tD/miZyoHS5obTRR9BMY=" crossorigin=""/>
    <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js" integrity="sha256-20nQCchB9co0qIjJZRGuk2/Z9VM+kNiyxNV1lvTlZBo=" crossorigin=""></script>

    <style>
        :root {
            --primary: #198B61;
            --secondary: #2C3E50;
            --dark: #12181b;
            --dark-card: #1e2529;
            --text-main: #f8f9fa;
            --text-muted: #9ba4b5;
            --border: rgba(255,255,255,0.08);
            --danger: #e74c3c;
            --success: #2ecc71;
            --warning: #f1c40f;
            --sidebar-width: 260px;
        }
        * { margin:0; padding:0; box-sizing:border-box; font-family:'Inter',sans-serif; }
        body { background:var(--dark); color:var(--text-main); display:flex; min-height:100vh; }

        /* SIDEBAR */
        .sidebar { width:var(--sidebar-width); background:var(--dark-card); border-right:1px solid var(--border); display:flex; flex-direction:column; position:fixed; height:100vh; }
        .sidebar-header { padding:1.5rem; display:flex; align-items:center; gap:1rem; border-bottom:1px solid var(--border); }
        .sidebar-nav { padding:1.5rem 1rem; flex:1; overflow-y:auto; }
        .nav-section { text-transform:uppercase; font-size:0.72rem; color:var(--text-muted); letter-spacing:1px; margin:1.2rem 0 0.6rem; padding-left:0.5rem; font-weight:600; }
        .nav-item { display:flex; align-items:center; gap:1rem; padding:0.75rem 1rem; color:var(--text-muted); text-decoration:none; border-radius:10px; margin-bottom:0.25rem; transition:all 0.25s; font-weight:500; font-size:0.9rem; }
        .nav-item:hover, .nav-item.active { background:rgba(25,139,97,0.12); color:var(--primary); }
        .nav-item.active-danger { background:rgba(231,76,60,0.12); color:var(--danger); }
        .nav-item i { width:20px; text-align:center; }
        .sidebar-footer { padding:1.5rem; border-top:1px solid var(--border); }

        /* MAIN */
        .main { margin-left:var(--sidebar-width); flex:1; }
        .topbar { height:70px; padding:0 2rem; display:flex; align-items:center; justify-content:space-between; background:var(--dark-card); border-bottom:1px solid var(--border); }
        .topbar-title { font-size:1.1rem; font-weight:600; }
        .topbar-actions { display:flex; gap:0.75rem; }

        /* CONTENT */
        .content { padding:2rem; }

        /* TABLE */
        .table-card { background:var(--dark-card); border:1px solid var(--border); border-radius:16px; overflow:hidden; margin-bottom: 2rem;}
        .table-scroll { overflow-x:auto; }
        table { width:100%; border-collapse:collapse; }
        thead tr { background:rgba(255,255,255,0.03); }
        th { padding:1rem 1.2rem; text-align:left; font-size:0.78rem; text-transform:uppercase; letter-spacing:.8px; color:var(--text-muted); font-weight:600; border-bottom:1px solid var(--border); }
        td { padding:1rem 1.2rem; border-bottom:1px solid rgba(255,255,255,0.04); font-size:0.9rem; vertical-align:middle; }
        tbody tr:last-child td { border-bottom:none; }
        tbody tr:hover { background:rgba(255,255,255,0.02); }

        /* BUTTONS */
        .btn { display:inline-flex; align-items:center; gap:6px; padding:0.5rem 1rem; border-radius:8px; font-size:0.85rem; font-weight:500; text-decoration:none; cursor:pointer; border:none; transition:all 0.2s; }
        .btn-primary { background:var(--primary); color:#fff; }
        .btn-primary:hover { background:#147350; transform:translateY(-1px); }
        .btn-warning { background:#e67e22; color:#fff; }
        .btn-warning:hover { background:#d35400; }
        .btn-danger  { background:var(--danger); color:#fff; }
        .btn-danger:hover { background:#c0392b; }
        .btn-sm { padding:0.35rem 0.75rem; font-size:0.8rem; }
        .action-group { display:flex; gap:0.4rem; }

        /* FLASH */
        .flash { padding:0.9rem 1.2rem; border-radius:10px; margin-bottom:1.5rem; font-size:0.9rem; }
        .flash-success { background:rgba(46,204,113,0.12); border:1px solid rgba(46,204,113,0.3); color:var(--success); }

        .equipement-badge { background: rgba(52, 152, 219, 0.15); color: #3498db; padding: 2px 8px; border-radius: 12px; font-size: 0.75rem; margin-right: 4px; display: inline-block; margin-bottom: 4px; border: 1px solid rgba(52, 152, 219, 0.3);}
    </style>
</head>
<body>

{% include 'admin/_sidebar.html.twig' with {active: 'garages'} %}

<main class="main">
    <header class="topbar">
        <div class="topbar-title">
            <i class="fa-solid fa-warehouse" style="color:var(--primary);margin-right:8px;"></i>
            Gestion des Garages
        </div>
        <div class="topbar-actions">
            <a href="{{ path('admin_garage_new') }}" class="btn btn-primary">
                <i class="fa-solid fa-plus"></i> Nouveau Garage
            </a>
        </div>
    </header>

    <div class="content">
        {% for msg in app.flashes('success') %}
            <div class="flash flash-success"><i class="fa-solid fa-check-circle"></i> {{ msg }}</div>
        {% endfor %}

        <!-- CARTE DES GARAGES (ADMIN) -->
        <div style="background: rgba(255,255,255,0.02); border: 1px solid rgba(255,255,255,0.08); border-radius: 15px; padding: 1.5rem; margin-bottom: 2.5rem;">
            <h3 style="margin-bottom: 1rem; font-size: 1.2rem;">
                <i class="fa-solid fa-map-location-dot" style="color: #3498db; margin-right: 10px;"></i> Localisation Globale des Garages
            </h3>
            <div id="adminGaragesMap" style="height: 400px; width: 100%; border-radius: 12px; border: 1px solid rgba(255,255,255,0.1); z-index: 1;"></div>
        </div>

        <div class="table-card">
            <div class="table-scroll">
                <table>
                    <thead>
                        <tr>
                            <th>#</th>
                            <th>Nom</th>
                            <th>Adresse</th>
                            <th>Responsable</th>
                            <th>Capacité</th>
                            <th>Équipements Assignés</th>
                            <th style="text-align:right;">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                    {% for garage in garages %}
                        <tr>
                            <td style="color:var(--text-muted);">{{ garage.id }}</td>
                            <td><strong>{{ garage.nom }}</strong></td>
                            <td>{{ garage.adresse|default('N/A') }}</td>
                            <td>{{ garage.responsable|default('N/A') }} <br><small style="color: var(--text-muted)">{{ garage.telephone }}</small></td>
                            <td>
                                <span style="font-weight: bold; color: {{ garage.equipements|length >= garage.capacite ? 'var(--danger)' : 'var(--success)' }}">
                                    {{ garage.equipements|length }}
                                </span> / {{ garage.capacite|default('∞') }}
                            </td>
                            <td>
                                {% for eq in garage.equipements %}
                                    <span class="equipement-badge">{{ eq.nom }}</span>
                                {% else %}
                                    <span style="color: var(--text-muted); font-size: 0.8rem; font-style: italic;">Aucun équipement</span>
                                {% endfor %}
                            </td>
                            <td>
                                <div class="action-group" style="justify-content:flex-end;">
                                    <a href="{{ path('admin_garage_edit', {id: garage.id}) }}" class="btn btn-warning btn-sm" title="Modifier">
                                        <i class="fa-solid fa-pen"></i>
                                    </a>
                                    <form method="post" action="{{ path('admin_garage_delete', {id: garage.id}) }}" onsubmit="return confirm('Supprimer ce garage ?');" style="display:inline;">
                                        <input type="hidden" name="_token" value="{{ csrf_token('delete_gar_' ~ garage.id) }}">
                                        <button class="btn btn-danger btn-sm" title="Supprimer"><i class="fa-solid fa-trash"></i></button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    {% else %}
                        <tr>
                            <td colspan="7" style="text-align:center;padding:3rem;color:var(--text-muted);">
                                <i class="fa-solid fa-warehouse" style="font-size:2.5rem;margin-bottom:1rem;opacity:0.4;display:block;"></i>
                                Aucun garage enregistré.
                            </td>
                        </tr>
                    {% endfor %}
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</main>

<script>
    document.addEventListener("DOMContentLoaded", function() {
        const mapContainer = document.getElementById('adminGaragesMap');
        if (!mapContainer) return;

        var map = L.map('adminGaragesMap').setView([36.8065, 10.1815], 6);

        L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
            attribution: '&copy; OpenStreetMap contributors'
        }).addTo(map);

        var bounds = [];
        
        {% for garage in garages %}
            {% if garage.latitude and garage.longitude %}
                var lat = {{ garage.latitude|number_format(6, '.', '') }};
                var lng = {{ garage.longitude|number_format(6, '.', '') }};
                var marker = L.marker([lat, lng]).addTo(map);
                
                var popupContent = `
                    <div style="color: #333; font-family: 'Inter', sans-serif; min-width: 220px;">
                        <h4 style="margin: 0 0 5px 0; color: #198B61; font-weight: 700;">{{ garage.nom|escape('js') }}</h4>
                        <p style="margin: 0 0 5px 0; font-size: 13px;"><strong>Responsable:</strong> {{ garage.responsable|escape('js')|default('N/A') }}</p>
                        <p style="margin: 0 0 5px 0; font-size: 13px;"><strong>Tél:</strong> {{ garage.telephone|escape('js')|default('N/A') }}</p>
                        <p style="margin: 0 0 5px 0; font-size: 13px;"><strong>Équipements:</strong> {{ garage.equipements|length }} / {{ garage.capacite|default('∞') }}</p>
                        <!-- Div for Weather Info -->
                        <div id="weather-garage-{{ garage.id }}" style="margin-top: 10px; font-size: 12px; color: #7f8c8d;">
                            <i class="fa-solid fa-cloud"></i> Charger la météo locale...
                        </div>
                    </div>
                `;
                marker.bindPopup(popupContent);
                bounds.push([lat, lng]);

                // Event listener to fetch weather when popup opens
                marker.on('popupopen', async function(e) {
                    var popup = e.popup;
                    if (popup._weatherFetched) return;
                    
                    setTimeout(async () => {
                        var weatherDiv = document.getElementById('weather-garage-{{ garage.id }}');
                        if (weatherDiv) {
                            weatherDiv.innerHTML = '<i class="fa-solid fa-spinner fa-spin"></i> Récupération météo...';
                            try {
                                const response = await fetch(`https://api.open-meteo.com/v1/forecast?latitude=${lat}&longitude=${lng}&current_weather=true`);
                                const data = await response.json();
                                const weather = data.current_weather;
                                
                                let icon = 'fa-sun';
                                let color = '#f1c40f';
                                let impactHtml = '';
                                
                                if (weather.weathercode >= 61 && weather.weathercode <= 65) {
                                    icon = 'fa-cloud-rain'; color = '#3498db';
                                    impactHtml = '<div style="margin-top:5px; padding:5px; background:rgba(52,152,219,0.1); border-left:3px solid #3498db; font-size:11px; color:#2980b9;">⚠️ <strong>Pluie :</strong> Risque d\'oxydation. Vérifiez l\'étanchéité du garage.</div>';
                                } else if (weather.weathercode >= 71 && weather.weathercode <= 75) {
                                    icon = 'fa-snowflake'; color = '#00cec9';
                                    impactHtml = '<div style="margin-top:5px; padding:5px; background:rgba(0,206,201,0.1); border-left:3px solid #00cec9; font-size:11px; color:#01a3a4;">❄️ <strong>Neige :</strong> Chauffage recommandé pour protéger les moteurs.</div>';
                                } else if (weather.weathercode >= 95) {
                                    icon = 'fa-bolt'; color = '#8e44ad';
                                    impactHtml = '<div style="margin-top:5px; padding:5px; background:rgba(142,68,173,0.1); border-left:3px solid #8e44ad; font-size:11px; color:#8e44ad;">⚡ <strong>Orage :</strong> Sécurisez le réseau électrique.</div>';
                                } else if (weather.temperature > 35) {
                                    icon = 'fa-temperature-high'; color = '#e74c3c';
                                    impactHtml = '<div style="margin-top:5px; padding:5px; background:rgba(231,76,60,0.1); border-left:3px solid #e74c3c; font-size:11px; color:#c0392b;">🔥 <strong>Chaleur extrême :</strong> Risque de surchauffe. Assurez la ventilation du garage.</div>';
                                } else {
                                    icon = 'fa-cloud-sun'; color = '#f39c12';
                                    impactHtml = '<div style="margin-top:5px; padding:5px; background:rgba(46,204,113,0.1); border-left:3px solid #2ecc71; font-size:11px; color:#27ae60;">✅ Conditions météo optimales pour le stockage.</div>';
                                }

                                weatherDiv.innerHTML = `
                                    <div style="display:flex; align-items:center; gap:8px; margin-top:8px; padding-top:8px; border-top:1px solid #eee;">
                                        <i class="fa-solid ${icon}" style="font-size:1.4rem; color:${color};"></i>
                                        <div>
                                            <strong style="font-size:14px; color:#2c3e50;">${weather.temperature}°C</strong>
                                            <div style="font-size:11px; color:#7f8c8d;">Vent: ${weather.windspeed} km/h</div>
                                        </div>
                                    </div>
                                    ${impactHtml}
                                `;
                                popup._weatherFetched = true;
                            } catch (err) {
                                weatherDiv.innerHTML = '<span style="color:#e74c3c; font-size:11px;">❌ Erreur météo</span>';
                            }
                        }
                    }, 100);
                });
            {% endif %}
        {% endfor %}

        if (bounds.length > 0) {
            map.fitBounds(bounds, { padding: [50, 50] });
        }
    });
</script>

</body>
</html>
