{% extends 'base.html.twig' %}

{% block title %}{{ animal.name }} — Détail{% endblock %}

{% block body %}
<section class="content-section" style="margin-top: 2rem;">

    <div style="margin-bottom:1.5rem;">
        <a href="{{ path('waad_animal_index') }}" class="btn btn-secondary"><i class="fa-solid fa-arrow-left"></i> Retour au cheptel</a>
    </div>

    {% for message in app.flashes('success') %}
        <div style="background:rgba(29,185,84,0.15); border:1px solid #1db954; color:#1db954; padding:0.75rem 1rem; border-radius:8px; margin-bottom:1rem;">
            <i class="fa-solid fa-circle-check"></i> {{ message }}
        </div>
    {% endfor %}
    {% for message in app.flashes('error') %}
        <div style="background:rgba(231,76,60,0.15); border:1px solid #e74c3c; color:#e74c3c; padding:0.75rem 1rem; border-radius:8px; margin-bottom:1rem;">
            <i class="fa-solid fa-circle-xmark"></i> {{ message }}
        </div>
    {% endfor %}

    {# Animal Card #}
    <div style="background:rgba(255,255,255,0.04); border:1px solid rgba(255,255,255,0.08); border-radius:12px; padding:1.5rem; margin-bottom:2rem;">
        <div style="display:flex; justify-content:space-between; align-items:flex-start; margin-bottom:1.5rem;">
            <div>
                <h2 style="margin:0 0 0.25rem 0; font-size:1.8rem;">
                    <i class="fa-solid fa-cow" style="color:#198B61; margin-right:0.5rem;"></i>{{ animal.name }}
                </h2>
                <span style="color:rgba(255,255,255,0.5); font-size:0.9rem;">Ajouté le {{ animal.dateAdded ? animal.dateAdded|date('d/m/Y') : '-' }}</span>
            </div>
            <div style="display:flex; gap:0.5rem;">
                <button onclick="document.getElementById('modalEditAnimal').style.display='flex'" class="btn btn-primary">
                    <i class="fa-solid fa-pen"></i> Modifier
                </button>
            </div>
        </div>
        <div style="display:grid; grid-template-columns: repeat(3, 1fr); gap:1rem;">
            <div style="background:rgba(255,255,255,0.03); border-radius:8px; padding:1rem;">
                <div style="color:rgba(255,255,255,0.5); font-size:0.8rem; margin-bottom:0.25rem;">TYPE</div>
                <div style="font-weight:600;">{{ animal.type }}</div>
            </div>
            <div style="background:rgba(255,255,255,0.03); border-radius:8px; padding:1rem;">
                <div style="color:rgba(255,255,255,0.5); font-size:0.8rem; margin-bottom:0.25rem;">RACE</div>
                <div>{{ animal.breed ?? '-' }}</div>
            </div>
            <div style="background:rgba(255,255,255,0.03); border-radius:8px; padding:1rem;">
                <div style="color:rgba(255,255,255,0.5); font-size:0.8rem; margin-bottom:0.25rem;">ÂGE</div>
                <div>{{ animal.age ? animal.age ~ ' ans' : '-' }}</div>
            </div>
            <div style="background:rgba(255,255,255,0.03); border-radius:8px; padding:1rem;">
                <div style="color:rgba(255,255,255,0.5); font-size:0.8rem; margin-bottom:0.25rem;">POIDS</div>
                <div>{{ animal.weight ? animal.weight ~ ' kg' : '-' }}</div>
            </div>
            <div style="background:rgba(255,255,255,0.03); border-radius:8px; padding:1rem;">
                <div style="color:rgba(255,255,255,0.5); font-size:0.8rem; margin-bottom:0.25rem;">SANTÉ</div>
                <div>
                    {% if animal.healthStatus == 'healthy' %}
                        <span class="badge badge-success"><i class="fa-solid fa-heart-pulse"></i> Sain</span>
                    {% elseif animal.healthStatus == 'sick' %}
                        <span class="badge badge-danger"><i class="fa-solid fa-virus"></i> Malade</span>
                    {% elseif animal.healthStatus == 'recovering' %}
                        <span class="badge badge-warning"><i class="fa-solid fa-kit-medical"></i> Convalescent</span>
                    {% else %}-{% endif %}
                </div>
            </div>
            <div style="background:rgba(255,255,255,0.03); border-radius:8px; padding:1rem;">
                <div style="color:rgba(255,255,255,0.5); font-size:0.8rem; margin-bottom:0.25rem;">PRODUCTION</div>
                <div>{{ animal.productionType ?? '-' }}</div>
            </div>
        </div>
    </div>

    {# Feeding History #}
    <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:1rem;">
        <div>
            <h3 style="margin:0 0 0.25rem 0;"><i class="fa-solid fa-bowl-food" style="color:#198B61;"></i> Historique d'alimentation</h3>
            <p style="color:rgba(255,255,255,0.5); margin:0; font-size:0.85rem;">Enregistrements d'alimentation pour {{ animal.name }}</p>
        </div>
        <button onclick="document.getElementById('modalAddFeeding').style.display='flex'" class="hero-btn-primary" style="font-size:0.85rem;">
            + Ajouter alimentation
        </button>
    </div>

    <div class="table-wrapper">
        <table class="styled-table">
            <thead>
                <tr>
                    <th>Nourriture</th>
                    <th>Quantité</th>
                    <th>Date</th>
                    <th>Notes</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
            {% for feeding in animal.animalNourritures %}
                <tr>
                    <td><strong>{{ feeding.nourriture.name }}</strong></td>
                    <td>{{ feeding.quantityFed }} {{ feeding.nourriture.unit ?? '' }}</td>
                    <td>{{ feeding.feedingDate ? feeding.feedingDate|date('d/m/Y H:i') : '-' }}</td>
                    <td style="color:rgba(255,255,255,0.6);">{{ feeding.notes ?? '-' }}</td>
                    <td style="display:flex; gap:0.5rem; justify-content:flex-end;">
                        <button onclick="document.getElementById('modalEditFeeding{{ feeding.id }}').style.display='flex'" class="btn btn-primary" title="Modifier"><i class="fa-solid fa-pen"></i></button>
                        <button onclick="document.getElementById('modalDeleteFeeding{{ feeding.id }}').style.display='flex'" class="btn" style="background:#e74c3c;color:white;" title="Supprimer"><i class="fa-solid fa-trash"></i></button>
                    </td>
                </tr>
            {% else %}
                <tr>
                    <td colspan="5" style="text-align:center; padding:2rem; color:rgba(255,255,255,0.5);">
                        <i class="fa-solid fa-bowl-food" style="font-size:2rem; opacity:0.4; display:block; margin-bottom:0.5rem;"></i>
                        Aucun enregistrement d'alimentation.
                    </td>
                </tr>
            {% endfor %}
            </tbody>
        </table>
    </div>
</section>

{# EDIT ANIMAL MODAL #}
<div id="modalEditAnimal" style="display:none; position:fixed; inset:0; background:rgba(0,0,0,0.75); z-index:1000; align-items:center; justify-content:center;">
    <div style="background:#1C2D21; border:1px solid rgba(255,255,255,0.1); border-radius:12px; padding:2rem; width:620px; max-height:90vh; overflow-y:auto;">
        <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:1.5rem;">
            <h3 style="margin:0;"><i class="fa-solid fa-pen" style="color:#198B61;"></i> Modifier {{ animal.name }}</h3>
            <button onclick="document.getElementById('modalEditAnimal').style.display='none'" style="background:none;border:none;color:white;font-size:1.5rem;cursor:pointer;">&times;</button>
        </div>
        {{ include('Waad/animal/_form.html.twig', {form: editForm}) }}
    </div>
</div>

{# ADD FEEDING MODAL #}
<div id="modalAddFeeding" style="display:none; position:fixed; inset:0; background:rgba(0,0,0,0.75); z-index:1000; align-items:center; justify-content:center;">
    <div style="background:#1C2D21; border:1px solid rgba(255,255,255,0.1); border-radius:12px; padding:2rem; width:500px; max-height:90vh; overflow-y:auto;">
        <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:1.5rem;">
            <h3 style="margin:0;"><i class="fa-solid fa-plus-circle" style="color:#198B61;"></i> Ajouter alimentation</h3>
            <button onclick="document.getElementById('modalAddFeeding').style.display='none'" style="background:none;border:none;color:white;font-size:1.5rem;cursor:pointer;">&times;</button>
        </div>
        {{ include('Waad/animal_nourriture/_form.html.twig', {feedingForm: addFeedingForm}) }}
    </div>
</div>

{# EDIT & DELETE FEEDING MODALS #}
{% for feeding in animal.animalNourritures %}
<div id="modalEditFeeding{{ feeding.id }}" style="display:none; position:fixed; inset:0; background:rgba(0,0,0,0.75); z-index:1000; align-items:center; justify-content:center;">
    <div style="background:#1C2D21; border:1px solid rgba(255,255,255,0.1); border-radius:12px; padding:2rem; width:500px; max-height:90vh; overflow-y:auto;">
        <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:1.5rem;">
            <h3 style="margin:0;"><i class="fa-solid fa-pen" style="color:#198B61;"></i> Modifier alimentation</h3>
            <button onclick="document.getElementById('modalEditFeeding{{ feeding.id }}').style.display='none'" style="background:none;border:none;color:white;font-size:1.5rem;cursor:pointer;">&times;</button>
        </div>
        {{ include('Waad/animal_nourriture/_form.html.twig', {feedingForm: editFeedingForms[feeding.id]}) }}
    </div>
</div>

<div id="modalDeleteFeeding{{ feeding.id }}" style="display:none; position:fixed; inset:0; background:rgba(0,0,0,0.75); z-index:1000; align-items:center; justify-content:center;">
    <div style="background:#1C2D21; border:1px solid rgba(255,255,255,0.1); border-radius:12px; padding:2rem; width:420px;">
        <h3 style="margin-bottom:1rem;"><i class="fa-solid fa-triangle-exclamation" style="color:#e74c3c;"></i> Supprimer cet enregistrement ?</h3>
        <p style="color:rgba(255,255,255,0.7); margin-bottom:1.5rem;">Cette action est irréversible.</p>
        <div style="display:flex; gap:1rem; justify-content:flex-end;">
            <button onclick="document.getElementById('modalDeleteFeeding{{ feeding.id }}').style.display='none'" class="btn btn-secondary">Annuler</button>
            <form action="{{ path('waad_feeding_delete', {animalId: animal.id, id: feeding.id}) }}" method="POST" style="display:inline;">
                <button type="submit" class="btn" style="background:#e74c3c;color:white;">Supprimer</button>
            </form>
        </div>
    </div>
</div>
{% endfor %}
{% endblock %}
