{% extends 'base.html.twig' %}

{% block title %}Gestion des Animaux{% endblock %}

{% block body %}
<section class="content-section" style="margin-top: 2rem;">
    <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 2rem;">
        <div>
            <h2 style="font-size: 2rem; margin-bottom: 0.5rem;">Panel des Animaux</h2>
            <p style="color: rgba(255,255,255,0.7);">Gérez, suivez et surveillez le cheptel de votre exploitation.</p>
        </div>
        <button onclick="document.getElementById('modalAddAnimal').style.display='flex'" class="hero-btn-primary" style="font-size: 0.9rem;">
            + Ajouter Animal
        </button>
    </div>

    {% for message in app.flashes('success') %}
        <div style="background:rgba(29,185,84,0.15); border:1px solid #1db954; color:#1db954; padding:0.75rem 1rem; border-radius:8px; margin-bottom:1rem;">
            <i class="fa-solid fa-circle-check"></i> {{ message }}
        </div>
    {% endfor %}
    {% for message in app.flashes('error') %}
        <div style="background:rgba(231,76,60,0.15); border:1px solid #e74c3c; color:#e74c3c; padding:0.75rem 1rem; border-radius:8px; margin-bottom:1rem;">
            <i class="fa-solid fa-circle-xmark"></i> {{ message }}
        </div>
    {% endfor %}

    <div class="table-wrapper">
        <table class="styled-table">
            <thead>
                <tr>
                    <th>ID</th>
                    <th>Nom</th>
                    <th>Type</th>
                    <th>Race</th>
                    <th>Santé</th>
                    <th>Production</th>
                    <th>Statut</th>
                    <th>Actions Rapides</th>
                </tr>
            </thead>
            <tbody>
            {% for animal in animals %}
                <tr>
                    <td style="color: rgba(255,255,255,0.5);">#{{ animal.id }}</td>
                    <td><strong>{{ animal.name }}</strong></td>
                    <td>{{ animal.type }}</td>
                    <td>{{ animal.breed ?? '-' }}</td>
                    <td>
                        {% if animal.healthStatus == 'healthy' %}
                            <span class="badge badge-success"><i class="fa-solid fa-heart-pulse"></i> Sain</span>
                        {% elseif animal.healthStatus == 'sick' %}
                            <span class="badge badge-danger"><i class="fa-solid fa-virus"></i> Malade</span>
                        {% elseif animal.healthStatus == 'recovering' %}
                            <span class="badge badge-warning"><i class="fa-solid fa-kit-medical"></i> Convalescent</span>
                        {% else %}
                            <span style="color:rgba(255,255,255,0.4);">-</span>
                        {% endif %}
                    </td>
                    <td>{{ animal.productionType ?? '-' }}</td>
                    <td>
                        {% if animal.isActive %}
                            <span class="badge badge-success"><i class="fa-solid fa-check-circle"></i> Actif</span>
                        {% else %}
                            <span class="badge badge-danger"><i class="fa-solid fa-times-circle"></i> Inactif</span>
                        {% endif %}
                    </td>
                    <td style="display:flex; gap:0.5rem; justify-content: flex-end;">
                        <a href="{{ path('waad_animal_show', {id: animal.id}) }}" class="btn btn-secondary" title="Détails"><i class="fa-solid fa-eye"></i></a>
                        <button onclick="document.getElementById('modalEdit{{ animal.id }}').style.display='flex'" class="btn btn-primary" title="Éditer"><i class="fa-solid fa-pen"></i></button>
                        <button onclick="document.getElementById('modalDelete{{ animal.id }}').style.display='flex'" class="btn" style="background:#e74c3c; color:white;" title="Supprimer"><i class="fa-solid fa-trash"></i></button>
                    </td>
                </tr>
            {% else %}
                <tr>
                    <td colspan="8" style="text-align:center; padding:3rem; color:rgba(255,255,255,0.6);">
                        <i class="fa-solid fa-cow" style="font-size:3rem; margin-bottom:1rem; opacity:0.5; display:block;"></i>
                        Aucun animal enregistré pour le moment.
                    </td>
                </tr>
            {% endfor %}
            </tbody>
        </table>
    </div>
</section>

{# ADD MODAL #}
<div id="modalAddAnimal" style="display:none; position:fixed; inset:0; background:rgba(0,0,0,0.75); z-index:1000; align-items:center; justify-content:center;">
    <div style="background:#1C2D21; border:1px solid rgba(255,255,255,0.1); border-radius:12px; padding:2rem; width:620px; max-height:90vh; overflow-y:auto;">
        <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:1.5rem;">
            <h3 style="margin:0;"><i class="fa-solid fa-plus-circle" style="color:#198B61;"></i> Ajouter un Animal</h3>
            <button onclick="document.getElementById('modalAddAnimal').style.display='none'" style="background:none;border:none;color:white;font-size:1.5rem;cursor:pointer;">&times;</button>
        </div>
        {{ include('Waad/animal/_form.html.twig', {form: form}) }}
    </div>
</div>

{# EDIT & DELETE MODALS #}
{% for animal in animals %}
<div id="modalEdit{{ animal.id }}" style="display:none; position:fixed; inset:0; background:rgba(0,0,0,0.75); z-index:1000; align-items:center; justify-content:center;">
    <div style="background:#1C2D21; border:1px solid rgba(255,255,255,0.1); border-radius:12px; padding:2rem; width:620px; max-height:90vh; overflow-y:auto;">
        <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:1.5rem;">
            <h3 style="margin:0;"><i class="fa-solid fa-pen" style="color:#198B61;"></i> Modifier {{ animal.name }}</h3>
            <button onclick="document.getElementById('modalEdit{{ animal.id }}').style.display='none'" style="background:none;border:none;color:white;font-size:1.5rem;cursor:pointer;">&times;</button>
        </div>
        {{ include('Waad/animal/_form.html.twig', {form: editForms[animal.id]}) }}
    </div>
</div>

<div id="modalDelete{{ animal.id }}" style="display:none; position:fixed; inset:0; background:rgba(0,0,0,0.75); z-index:1000; align-items:center; justify-content:center;">
    <div style="background:#1C2D21; border:1px solid rgba(255,255,255,0.1); border-radius:12px; padding:2rem; width:420px;">
        <h3 style="margin-bottom:1rem;"><i class="fa-solid fa-triangle-exclamation" style="color:#e74c3c;"></i> Confirmer la suppression</h3>
        <p style="color:rgba(255,255,255,0.7); margin-bottom:1.5rem;">Voulez-vous vraiment supprimer <strong>{{ animal.name }}</strong> ? Cette action est irréversible.</p>
        <div style="display:flex; gap:1rem; justify-content:flex-end;">
            <button onclick="document.getElementById('modalDelete{{ animal.id }}').style.display='none'" class="btn btn-secondary">Annuler</button>
            <form action="{{ path('waad_animal_delete', {id: animal.id}) }}" method="POST" style="display:inline;">
                <button type="submit" class="btn" style="background:#e74c3c;color:white;">Supprimer</button>
            </form>
        </div>
    </div>
</div>
{% endfor %}
{% endblock %}
