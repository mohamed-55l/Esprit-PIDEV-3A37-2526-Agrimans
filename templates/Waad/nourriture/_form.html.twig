{{ form_start(form) }}
<div style="display:grid; grid-template-columns:1fr 1fr; gap:1rem;">
    <div>{{ form_row(form.name) }}</div>
    <div>{{ form_row(form.type) }}</div>
    <div>{{ form_row(form.quantity) }}</div>
    <div>{{ form_row(form.unit) }}</div>
    <div>{{ form_row(form.cost) }}</div>
    <div>{{ form_row(form.supplier) }}</div>
    <div>{{ form_row(form.expiryDate) }}</div>
    <div>{{ form_row(form.isActive) }}</div>
</div>
<div style="margin-top:0.5rem;">{{ form_row(form.nutritionalValue) }}</div>
<div style="margin-top:1rem;">
    <button type="submit" class="hero-btn-primary" style="font-size:0.9rem;">
        <i class="fa-solid fa-floppy-disk"></i> Enregistrer
    </button>
</div>
{{ form_end(form) }}
