{% extends 'base.html.twig' %}

{% block title %}Packs & Réductions - Agrimans{% endblock %}

{% block body %}
    <section class="content-section" style="margin-top: 2rem;">
        <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 2rem;">
            <div>
                <h2 style="font-size: 2rem; margin-bottom: 0.5rem;">
                    <i class="fa-solid fa-gift"></i> Packs & Réductions
                </h2>
                <p style="color: rgba(255,255,255,0.7);">{{ totalBundles }} pack(s) disponible(s)</p>
            </div>
            <a href="{{ path('app_marketplace_index') }}" class="btn btn-secondary">
                <i class="fa-solid fa-arrow-left"></i> Retour à la boutique
            </a>
        </div>

        {# Flash messages #}
        {% for type, messages in app.flashes %}
            {% for message in messages %}
                <div style="padding: 1rem; margin-bottom: 1rem; border-radius: 8px; background: {{ type == 'success' ? 'rgba(125, 191, 108, 0.2)' : 'rgba(231, 76, 60, 0.2)' }}; border: 1px solid {{ type == 'success' ? '#7DBF6C' : '#e74c3c' }};">
                    <i class="fa-solid {{ type == 'success' ? 'fa-check-circle' : 'fa-exclamation-circle' }}"></i> {{ message }}
                </div>
            {% endfor %}
        {% endfor %}

        {% if bundles|length > 0 %}
            <div class="products-grid" style="display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 1.5rem; margin-bottom: 2rem;">
                {% for bundle in bundles %}
                    <a href="{{ path('app_marketplace_bundle_show', {'id': bundle.id}) }}" style="text-decoration: none; color: inherit;">
                        <div class="product-card" style="
                            background: linear-gradient(135deg, rgba(25, 139, 97, 0.15) 0%, rgba(125, 191, 108, 0.05) 100%);
                            border: 1px solid rgba(125, 191, 108, 0.3);
                            border-radius: 12px;
                            padding: 1.5rem;
                            transition: all 0.3s ease;
                            cursor: pointer;
                            position: relative;
                            overflow: hidden;
                            height: 100%;
                            display: flex;
                            flex-direction: column;
                        ">
                            {# Discount Badge #}
                            <div style="
                                position: absolute;
                                top: 10px;
                                right: 10px;
                                background: #e74c3c;
                                color: white;
                                padding: 0.5rem 1rem;
                                border-radius: 20px;
                                font-weight: bold;
                                font-size: 0.9rem;
                            ">
                                -{{ bundle.discountPercentage|round(0) }}%
                            </div>

                            {# Bundle Icon #}
                            <div style="font-size: 2.5rem; margin-bottom: 1rem;">
                                <i class="fa-solid fa-box-open"></i>
                            </div>

                            {# Bundle Name #}
                            <h3 style="font-size: 1.2rem; font-weight: 600; margin-bottom: 0.5rem;">
                                {{ bundle.name }}
                            </h3>

                            {# Description #}
                            {% if bundle.description %}
                                <p style="color: rgba(255,255,255,0.7); font-size: 0.9rem; margin-bottom: 1rem; flex-grow: 1;">
                                    {{ bundle.description|slice(0, 100) }}{% if bundle.description|length > 100 %}...{% endif %}
                                </p>
                            {% endif %}

                            {# Products in Bundle #}
                            <div style="margin-bottom: 1rem; padding-bottom: 1rem; border-bottom: 1px solid rgba(255,255,255,0.1);">
                                <p style="color: rgba(255,255,255,0.6); font-size: 0.85rem; margin-bottom: 0.5rem;">
                                    <strong>{{ bundle.products|length }}</strong> produit(s) dans ce pack
                                </p>
                                {% for product in bundle.products|slice(0, 3) %}
                                    <div style="font-size: 0.8rem; color: rgba(255,255,255,0.5);">
                                        • {{ product.name }}
                                    </div>
                                {% endfor %}
                                {% if bundle.products|length > 3 %}
                                    <div style="font-size: 0.8rem; color: rgba(255,255,255,0.5);">
                                        + {{ bundle.products|length - 3 }} autre(s)
                                    </div>
                                {% endif %}
                            </div>

                            {# Pricing #}
                            <div style="margin-bottom: 1rem;">
                                <div style="color: rgba(255,255,255,0.6); font-size: 0.9rem;">
                                    <s>{{ bundle.originalPrice|number_format(2, ',', '.') }} TND</s>
                                </div>
                                <div style="font-size: 1.5rem; font-weight: bold; color: #7DBF6C;">
                                    {{ bundle.bundlePrice|number_format(2, ',', '.') }} TND
                                </div>
                                <div style="color: #198B61; font-size: 0.85rem; margin-top: 0.5rem;">
                                    ✓ Économies : {{ bundle.savings|number_format(2, ',', '.') }} TND
                                </div>
                            </div>

                            {# View Details Button #}
                            <button type="button" class="btn btn-primary" style="width: 100%; margin-top: auto;">
                                <i class="fa-solid fa-eye"></i> Voir les détails
                            </button>
                        </div>
                    </a>
                {% endfor %}
            </div>

            {# Pagination #}
            {% if totalPages > 1 %}
                <nav style="display: flex; justify-content: center; gap: 0.5rem; margin-top: 2rem;">
                    {% if currentPage > 1 %}
                        <a href="{{ path('app_marketplace_bundles', {'page': 1}) }}" class="btn btn-outline" title="Première page">
                            <i class="fa-solid fa-angles-left"></i>
                        </a>
                        <a href="{{ path('app_marketplace_bundles', {'page': currentPage - 1}) }}" class="btn btn-outline">
                            <i class="fa-solid fa-angle-left"></i> Précédent
                        </a>
                    {% endif %}

                    {% for page in 1..totalPages %}
                        {% if page == currentPage %}
                            <button type="button" class="btn" style="background: #198B61; cursor: default;">
                                {{ page }}
                            </button>
                        {% elseif page >= currentPage - 2 and page <= currentPage + 2 %}
                            <a href="{{ path('app_marketplace_bundles', {'page': page}) }}" class="btn btn-outline">
                                {{ page }}
                            </a>
                        {% endif %}
                    {% endfor %}

                    {% if currentPage < totalPages %}
                        <a href="{{ path('app_marketplace_bundles', {'page': currentPage + 1}) }}" class="btn btn-outline">
                            Suivant <i class="fa-solid fa-angle-right"></i>
                        </a>
                        <a href="{{ path('app_marketplace_bundles', {'page': totalPages}) }}" class="btn btn-outline" title="Dernière page">
                            <i class="fa-solid fa-angles-right"></i>
                        </a>
                    {% endif %}
                </nav>
            {% endif %}
        {% else %}
            <div style="
                text-align: center;
                padding: 3rem;
                background: rgba(255, 255, 255, 0.05);
                border: 1px dashed rgba(255, 255, 255, 0.2);
                border-radius: 12px;
                margin-top: 2rem;
            ">
                <i class="fa-solid fa-box-open" style="font-size: 3rem; color: rgba(255,255,255,0.3); margin-bottom: 1rem; display: block;"></i>
                <h3 style="color: rgba(255,255,255,0.7);">Aucun pack disponible pour le moment</h3>
                <p style="color: rgba(255,255,255,0.5);">Revenez bientôt pour découvrir nos offres spéciales !</p>
            </div>
        {% endif %}
    </section>
{% endblock %}
