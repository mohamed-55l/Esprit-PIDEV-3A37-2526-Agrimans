<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <title>Gestion des Avis | Admin Agrimans</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        :root { --primary:#198B61; --dark:#12181b; --dark-card:#1e2529; --text-main:#f8f9fa; --text-muted:#9ba4b5; --border:rgba(255,255,255,0.08); --danger:#e74c3c; --warning:#f1c40f; --success:#2ecc71; --sidebar-width:280px; }
        * { margin:0; padding:0; box-sizing:border-box; font-family:'Inter',sans-serif; }
        body { background:var(--dark); color:var(--text-main); display:flex; min-height:100vh; }
        .sidebar { width:var(--sidebar-width); background:var(--dark-card); border-right:1px solid var(--border); display:flex; flex-direction:column; position:fixed; height:100vh; }
        .sidebar-header { padding:1.5rem; display:flex; align-items:center; gap:1rem; border-bottom:1px solid var(--border); }
        .sidebar-nav { padding:1.5rem 1rem; flex:1; overflow-y:auto; }
        .nav-section { text-transform:uppercase; font-size:0.72rem; color:var(--text-muted); letter-spacing:1px; margin:1.2rem 0 0.6rem; padding-left:0.5rem; font-weight:600; }
        .nav-item { display:flex; align-items:center; gap:1rem; padding:0.75rem 1rem; color:var(--text-muted); text-decoration:none; border-radius:10px; margin-bottom:0.25rem; transition:all 0.25s; font-weight:500; font-size:0.9rem; }
        .nav-item:hover, .nav-item.active { background:rgba(25,139,97,0.12); color:var(--primary); }
        .nav-item.active-stars { background:rgba(241,196,15,0.1); color:var(--warning); }
        .nav-item i { width:20px; text-align:center; }
        .sidebar-footer { padding:1.5rem; border-top:1px solid var(--border); }
        .main { margin-left:var(--sidebar-width); flex:1; }
        .topbar { height:70px; padding:0 2rem; display:flex; align-items:center; justify-content:space-between; background:var(--dark-card); border-bottom:1px solid var(--border); font-size:1.1rem; font-weight:600; }
        .content { padding:2rem; }

        /* STATS */
        .stats-row { display:grid; grid-template-columns:repeat(auto-fit,minmax(180px,1fr)); gap:1rem; margin-bottom:2rem; }
        .stat-card { background:var(--dark-card); border:1px solid var(--border); border-radius:14px; padding:1.2rem 1.5rem; display:flex; align-items:center; gap:1rem; }
        .stat-icon { width:44px; height:44px; border-radius:10px; display:flex; align-items:center; justify-content:center; font-size:1.3rem; flex-shrink:0; }
        .stat-icon.yellow { background:rgba(241,196,15,0.12); color:var(--warning); }
        .stat-icon.green  { background:rgba(46,204,113,0.12);  color:var(--success); }
        .stat-value { font-size:1.8rem; font-weight:700; line-height:1; }
        .stat-label { font-size:0.8rem; color:var(--text-muted); margin-top:2px; }

        /* TABLE */
        .table-card { background:var(--dark-card); border:1px solid var(--border); border-radius:16px; overflow:hidden; }
        table { width:100%; border-collapse:collapse; }
        thead tr { background:rgba(255,255,255,0.03); }
        th { padding:1rem 1.2rem; text-align:left; font-size:0.78rem; text-transform:uppercase; letter-spacing:.8px; color:var(--text-muted); font-weight:600; border-bottom:1px solid var(--border); }
        td { padding:1rem 1.2rem; border-bottom:1px solid rgba(255,255,255,0.04); font-size:0.9rem; vertical-align:middle; }
        tbody tr:last-child td { border-bottom:none; }
        tbody tr:hover { background:rgba(255,255,255,0.02); }

        /* STARS */
        .stars { display:inline-flex; gap:2px; }
        .star-on  { color:var(--warning); font-size:0.9rem; }
        .star-off { color:rgba(255,255,255,0.15); font-size:0.9rem; }

        /* BTN */
        .btn { display:inline-flex; align-items:center; gap:6px; padding:0.4rem 0.85rem; border-radius:8px; font-size:0.82rem; font-weight:500; text-decoration:none; cursor:pointer; border:none; transition:all .2s; }
        .btn-danger { background:var(--danger); color:#fff; }
        .btn-danger:hover { background:#c0392b; }

        /* FLASH */
        .flash { padding:0.9rem 1.2rem; border-radius:10px; margin-bottom:1.5rem; font-size:0.9rem; }
        .flash-success { background:rgba(46,204,113,0.12); border:1px solid rgba(46,204,113,0.3); color:var(--success); }

        /* COMMENT */
        .comment-text { max-width:280px; overflow:hidden; text-overflow:ellipsis; white-space:nowrap; color:var(--text-muted); font-size:0.85rem; }
        .reviewer-pill { display:inline-flex; align-items:center; gap:5px; padding:0.2rem 0.6rem; background:rgba(255,255,255,0.05); border-radius:20px; font-size:0.82rem; color:var(--text-muted); }
    </style>
</head>
<body>
<aside class="sidebar">
    <div class="sidebar-header">
        <i class="fa-solid fa-shield-halved" style="color:var(--danger);font-size:1.4rem;"></i>
        <span style="font-size:1.1rem;font-weight:700;color:white;">AGRIMANS <span style="color:var(--danger);font-size:0.7rem;vertical-align:top;">ADMIN</span></span>
    </div>
    <div class="sidebar-nav">
        <a href="{{ path('app_admin') }}" class="nav-item"><i class="fa-solid fa-gauge-high"></i> Tableau de Bord</a>
        <div class="nav-section">Gestion</div>
        <a href="{{ path('app_user_management') }}" class="nav-item"><i class="fa-solid fa-users"></i> Utilisateurs</a>
        <a href="{{ path('admin_equipement_index') }}" class="nav-item"><i class="fa-solid fa-tractor"></i> Équipements</a>
        <a href="{{ path('admin_review_index') }}" class="nav-item active-stars active"><i class="fa-solid fa-star"></i> Avis & Reviews</a>
        <div class="nav-section">Boutique</div>
        <a href="{{ path('app_marketplace_index') }}" class="nav-item"><i class="fa-solid fa-store"></i> Marketplace</a>
    </div>
    <div class="sidebar-footer">
        <a href="{{ path('app_home') }}" class="nav-item"><i class="fa-solid fa-arrow-left"></i> Retour au site</a>
    </div>
</aside>

<main class="main">
    <header class="topbar">
        <div><i class="fa-solid fa-star" style="color:var(--warning);margin-right:8px;"></i>Gestion des Avis</div>
    </header>
    <div class="content">
        {% for msg in app.flashes('success') %}
            <div class="flash flash-success"><i class="fa-solid fa-check-circle"></i> {{ msg }}</div>
        {% endfor %}

        <div class="stats-row">
            <div class="stat-card">
                <div class="stat-icon yellow"><i class="fa-solid fa-star"></i></div>
                <div>
                    <div class="stat-value">{{ statistics.total|default(0) }}</div>
                    <div class="stat-label">Total Avis</div>
                </div>
            </div>
            <div class="stat-card">
                <div class="stat-icon green"><i class="fa-solid fa-chart-line"></i></div>
                <div>
                    <div class="stat-value">{{ statistics.average|default('—') }}<span style="font-size:1rem;color:var(--text-muted);font-weight:400;">/5</span></div>
                    <div class="stat-label">Note Moyenne</div>
                </div>
            </div>
        </div>

        <div class="table-card">
            <table>
                <thead>
                    <tr>
                        <th>Note</th>
                        <th>Équipement</th>
                        <th>Auteur</th>
                        <th>Commentaire</th>
                        <th>Date</th>
                        <th style="text-align:right;">Action</th>
                    </tr>
                </thead>
                <tbody>
                {% for review in reviews %}
                    <tr>
                        <td>
                            <div class="stars">
                                {% for i in 1..5 %}
                                    <i class="fa-solid fa-star {% if i <= review.note %}star-on{% else %}star-off{% endif %}"></i>
                                {% endfor %}
                            </div>
                        </td>
                        <td><strong>{{ review.equipement ? review.equipement.nom : '—' }}</strong></td>
                        <td>
                            {% if review.user %}
                                <span class="reviewer-pill"><i class="fa-solid fa-user"></i> {{ review.user.fullName }}</span>
                            {% else %}
                                <span style="color:var(--text-muted);">Anonyme</span>
                            {% endif %}
                        </td>
                        <td><div class="comment-text" title="{{ review.commentaire }}">{{ review.commentaire|default('—') }}</div></td>
                        <td style="color:var(--text-muted);font-size:0.85rem;">
                            {{ review.dateReview ? review.dateReview|date('d/m/Y') : '—' }}
                        </td>
                        <td style="text-align:right;">
                            <form method="post" action="{{ path('admin_review_delete', {id: review.id}) }}"
                                  onsubmit="return confirm('Supprimer définitivement cet avis ?');" style="display:inline;">
                                <input type="hidden" name="_token" value="{{ csrf_token('delete_rev_' ~ review.id) }}">
                                <button class="btn btn-danger"><i class="fa-solid fa-trash"></i> Supprimer</button>
                            </form>
                        </td>
                    </tr>
                {% else %}
                    <tr>
                        <td colspan="6" style="text-align:center;padding:3rem;color:var(--text-muted);">
                            <i class="fa-solid fa-star-half-stroke" style="font-size:2.5rem;margin-bottom:1rem;opacity:0.4;display:block;"></i>
                            Aucun avis enregistré pour le moment.
                        </td>
                    </tr>
                {% endfor %}
                </tbody>
            </table>
        </div>
    </div>
</main>
</body>
</html>
