<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Gestion des Équipements | Admin Agrimans</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        :root {
            --primary: #198B61;
            --secondary: #2C3E50;
            --dark: #12181b;
            --dark-card: #1e2529;
            --text-main: #f8f9fa;
            --text-muted: #9ba4b5;
            --border: rgba(255,255,255,0.08);
            --danger: #e74c3c;
            --success: #2ecc71;
            --warning: #f1c40f;
            --sidebar-width: 280px;
        }
        * { margin:0; padding:0; box-sizing:border-box; font-family:'Inter',sans-serif; }
        body { background:var(--dark); color:var(--text-main); display:flex; min-height:100vh; }

        /* SIDEBAR */
        .sidebar { width:var(--sidebar-width); background:var(--dark-card); border-right:1px solid var(--border); display:flex; flex-direction:column; position:fixed; height:100vh; }
        .sidebar-header { padding:1.5rem; display:flex; align-items:center; gap:1rem; border-bottom:1px solid var(--border); }
        .sidebar-nav { padding:1.5rem 1rem; flex:1; overflow-y:auto; }
        .nav-section { text-transform:uppercase; font-size:0.72rem; color:var(--text-muted); letter-spacing:1px; margin:1.2rem 0 0.6rem; padding-left:0.5rem; font-weight:600; }
        .nav-item { display:flex; align-items:center; gap:1rem; padding:0.75rem 1rem; color:var(--text-muted); text-decoration:none; border-radius:10px; margin-bottom:0.25rem; transition:all 0.25s; font-weight:500; font-size:0.9rem; }
        .nav-item:hover, .nav-item.active { background:rgba(25,139,97,0.12); color:var(--primary); }
        .nav-item.active-danger { background:rgba(231,76,60,0.12); color:var(--danger); }
        .nav-item i { width:20px; text-align:center; }
        .sidebar-footer { padding:1.5rem; border-top:1px solid var(--border); }

        /* MAIN */
        .main { margin-left:var(--sidebar-width); flex:1; }
        .topbar { height:70px; padding:0 2rem; display:flex; align-items:center; justify-content:space-between; background:var(--dark-card); border-bottom:1px solid var(--border); }
        .topbar-title { font-size:1.1rem; font-weight:600; }
        .topbar-actions { display:flex; gap:0.75rem; }

        /* CONTENT */
        .content { padding:2rem; }
        .page-header { display:flex; align-items:center; justify-content:space-between; margin-bottom:2rem; }
        .page-title { font-size:1.7rem; font-weight:700; }
        .page-sub { color:var(--text-muted); margin-top:0.3rem; font-size:0.9rem; }

        /* STATS */
        .stats-row { display:grid; grid-template-columns:repeat(auto-fit, minmax(180px,1fr)); gap:1rem; margin-bottom:2rem; }
        .stat-card { background:var(--dark-card); border:1px solid var(--border); border-radius:14px; padding:1.2rem 1.5rem; display:flex; align-items:center; gap:1rem; }
        .stat-icon { width:44px; height:44px; border-radius:10px; display:flex; align-items:center; justify-content:center; font-size:1.3rem; flex-shrink:0; }
        .stat-icon.green { background:rgba(46,204,113,0.12); color:var(--success); }
        .stat-icon.orange { background:rgba(241,196,15,0.12); color:var(--warning); }
        .stat-value { font-size:1.8rem; font-weight:700; line-height:1; }
        .stat-label { font-size:0.8rem; color:var(--text-muted); margin-top:2px; }

        /* TABLE */
        .table-card { background:var(--dark-card); border:1px solid var(--border); border-radius:16px; overflow:hidden; }
        .table-scroll { overflow-x:auto; }
        table { width:100%; border-collapse:collapse; }
        thead tr { background:rgba(255,255,255,0.03); }
        th { padding:1rem 1.2rem; text-align:left; font-size:0.78rem; text-transform:uppercase; letter-spacing:.8px; color:var(--text-muted); font-weight:600; border-bottom:1px solid var(--border); }
        td { padding:1rem 1.2rem; border-bottom:1px solid rgba(255,255,255,0.04); font-size:0.9rem; vertical-align:middle; }
        tbody tr:last-child td { border-bottom:none; }
        tbody tr:hover { background:rgba(255,255,255,0.02); }

        /* BADGES */
        .badge { display:inline-flex; align-items:center; gap:5px; padding:0.3rem 0.75rem; border-radius:20px; font-size:0.78rem; font-weight:600; }
        .badge-success { background:rgba(46,204,113,0.12); color:var(--success); border:1px solid rgba(46,204,113,0.25); }
        .badge-danger  { background:rgba(231,76,60,0.12);  color:var(--danger);  border:1px solid rgba(231,76,60,0.25); }
        .badge-warning { background:rgba(241,196,15,0.12); color:var(--warning); border:1px solid rgba(241,196,15,0.25); }

        /* BUTTONS */
        .btn { display:inline-flex; align-items:center; gap:6px; padding:0.5rem 1rem; border-radius:8px; font-size:0.85rem; font-weight:500; text-decoration:none; cursor:pointer; border:none; transition:all 0.2s; }
        .btn-primary { background:var(--primary); color:#fff; }
        .btn-primary:hover { background:#147350; transform:translateY(-1px); }
        .btn-warning { background:#e67e22; color:#fff; }
        .btn-warning:hover { background:#d35400; }
        .btn-info    { background:#2980b9; color:#fff; }
        .btn-info:hover { background:#1f6391; }
        .btn-danger  { background:var(--danger); color:#fff; }
        .btn-danger:hover { background:#c0392b; }
        .btn-sm { padding:0.35rem 0.75rem; font-size:0.8rem; }
        .action-group { display:flex; gap:0.4rem; }

        /* FLASH */
        .flash { padding:0.9rem 1.2rem; border-radius:10px; margin-bottom:1.5rem; font-size:0.9rem; }
        .flash-success { background:rgba(46,204,113,0.12); border:1px solid rgba(46,204,113,0.3); color:var(--success); }
        .flash-danger  { background:rgba(231,76,60,0.12);  border:1px solid rgba(231,76,60,0.3);  color:var(--danger); }

        /* ASSIGNED USER */
        .user-pill { display:inline-flex; align-items:center; gap:6px; padding:0.25rem 0.65rem; background:rgba(25,139,97,0.1); border:1px solid rgba(25,139,97,0.25); border-radius:20px; font-size:0.82rem; color:var(--primary); }
        .unassigned { color:var(--text-muted); font-style:italic; font-size:0.85rem; }
    </style>
</head>
<body>

<!-- SIDEBAR -->
<aside class="sidebar">
    <div class="sidebar-header">
        <i class="fa-solid fa-shield-halved" style="color:var(--danger);font-size:1.4rem;"></i>
        <span style="font-size:1.1rem;font-weight:700;color:white;">AGRIMANS <span style="color:var(--danger);font-size:0.7rem;vertical-align:top;">ADMIN</span></span>
    </div>
    <div class="sidebar-nav">
        <a href="{{ path('app_admin') }}" class="nav-item">
            <i class="fa-solid fa-gauge-high"></i> Tableau de Bord
        </a>
        <div class="nav-section">Gestion</div>
        <a href="{{ path('app_user_management') }}" class="nav-item">
            <i class="fa-solid fa-users"></i> Utilisateurs
        </a>
        <a href="{{ path('admin_equipement_index') }}" class="nav-item active">
            <i class="fa-solid fa-tractor"></i> Équipements
        </a>
        <a href="{{ path('admin_review_index') }}" class="nav-item">
            <i class="fa-solid fa-star"></i> Avis & Reviews
        </a>
        <div class="nav-section">Boutique</div>
        <a href="{{ path('app_marketplace_index') }}" class="nav-item">
            <i class="fa-solid fa-store"></i> Marketplace
        </a>
    </div>
    <div class="sidebar-footer">
        <a href="{{ path('app_home') }}" class="nav-item">
            <i class="fa-solid fa-arrow-left"></i> Retour au site
        </a>
    </div>
</aside>

<!-- MAIN -->
<main class="main">
    <header class="topbar">
        <div class="topbar-title">
            <i class="fa-solid fa-tractor" style="color:var(--primary);margin-right:8px;"></i>
            Gestion des Équipements
        </div>
        <div class="topbar-actions">
            <a href="{{ path('admin_equipement_new') }}" class="btn btn-primary">
                <i class="fa-solid fa-plus"></i> Nouvel Équipement
            </a>
        </div>
    </header>

    <div class="content">
        <!-- Flash messages -->
        {% for msg in app.flashes('success') %}
            <div class="flash flash-success"><i class="fa-solid fa-check-circle"></i> {{ msg }}</div>
        {% endfor %}
        {% for msg in app.flashes('danger') %}
            <div class="flash flash-danger"><i class="fa-solid fa-exclamation-triangle"></i> {{ msg }}</div>
        {% endfor %}

        <!-- Stats -->
        <div class="stats-row">
            <div class="stat-card">
                <div class="stat-icon green"><i class="fa-solid fa-tractor"></i></div>
                <div>
                    <div class="stat-value">{{ statistics.total|default(0) }}</div>
                    <div class="stat-label">Total Équipements</div>
                </div>
            </div>
            {% for dispo, count in statistics.repartition|default([]) %}
            <div class="stat-card">
                <div class="stat-icon orange"><i class="fa-solid fa-tag"></i></div>
                <div>
                    <div class="stat-value">{{ count }}</div>
                    <div class="stat-label">{{ dispo }}</div>
                </div>
            </div>
            {% endfor %}
        </div>

        <!-- Table -->
        <div class="table-card">
            <div class="table-scroll">
                <table>
                    <thead>
                        <tr>
                            <th>#</th>
                            <th>Nom</th>
                            <th>Catégorie</th>
                            <th>Prix</th>
                            <th>Statut</th>
                            <th>Assigné à</th>
                            <th style="text-align:right;">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                    {% for eq in equipements %}
                        <tr>
                            <td style="color:var(--text-muted);">{{ eq.id }}</td>
                            <td><strong>{{ eq.nom }}</strong></td>
                            <td>{{ eq.type }}</td>
                            <td style="font-weight:600;">{{ eq.prix|number_format(2, ',', ' ') }} DT</td>
                            <td>
                                {% if eq.disponibilite == 'Disponible' %}
                                    <span class="badge badge-success"><i class="fa-solid fa-check-circle"></i> Disponible</span>
                                {% elseif eq.disponibilite == 'Indisponible' %}
                                    <span class="badge badge-danger"><i class="fa-solid fa-times-circle"></i> Indisponible</span>
                                {% else %}
                                    <span class="badge badge-warning"><i class="fa-solid fa-wrench"></i> {{ eq.disponibilite }}</span>
                                {% endif %}
                            </td>
                            <td>
                                {% if eq.user %}
                                    <span class="user-pill"><i class="fa-solid fa-user"></i> {{ eq.user.fullName }}</span>
                                {% else %}
                                    <span class="unassigned"><i class="fa-solid fa-user-slash"></i> Non assigné</span>
                                {% endif %}
                            </td>
                            <td>
                                <div class="action-group" style="justify-content:flex-end;">
                                    <a href="{{ path('admin_equipement_assign', {id: eq.id}) }}" class="btn btn-info btn-sm" title="Assigner">
                                        <i class="fa-solid fa-user-plus"></i>
                                    </a>
                                    <a href="{{ path('admin_equipement_edit', {id: eq.id}) }}" class="btn btn-warning btn-sm" title="Modifier">
                                        <i class="fa-solid fa-pen"></i>
                                    </a>
                                    <form method="post" action="{{ path('admin_equipement_delete', {id: eq.id}) }}" onsubmit="return confirm('Supprimer cet équipement ?');" style="display:inline;">
                                        <input type="hidden" name="_token" value="{{ csrf_token('delete_eq_' ~ eq.id) }}">
                                        <button class="btn btn-danger btn-sm" title="Supprimer"><i class="fa-solid fa-trash"></i></button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    {% else %}
                        <tr>
                            <td colspan="7" style="text-align:center;padding:3rem;color:var(--text-muted);">
                                <i class="fa-solid fa-box-open" style="font-size:2.5rem;margin-bottom:1rem;opacity:0.4;display:block;"></i>
                                Aucun équipement enregistré.
                            </td>
                        </tr>
                    {% endfor %}
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</main>

</body>
</html>
