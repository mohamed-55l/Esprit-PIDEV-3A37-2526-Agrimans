<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <title>Assigner Équipement | Admin Agrimans</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        :root { --primary:#198B61; --secondary:#2C3E50; --dark:#12181b; --dark-card:#1e2529; --text-main:#f8f9fa; --text-muted:#9ba4b5; --border:rgba(255,255,255,0.08); --danger:#e74c3c; --info:#2980b9; --sidebar-width:260px; }
        * { margin:0; padding:0; box-sizing:border-box; font-family:'Inter',sans-serif; }
        body { background:var(--dark); color:var(--text-main); display:flex; min-height:100vh; }
        
        /* SIDEBAR (from index) */
        .sidebar { width:var(--sidebar-width); background:var(--dark-card); border-right:1px solid var(--border); display:flex; flex-direction:column; position:fixed; height:100vh; }
        .sidebar-header { padding:1.5rem; display:flex; align-items:center; gap:1rem; border-bottom:1px solid var(--border); }
        .sidebar-nav { padding:1.5rem 1rem; flex:1; overflow-y:auto; }
        .nav-section { text-transform:uppercase; font-size:0.72rem; color:var(--text-muted); letter-spacing:1px; margin:1.2rem 0 0.6rem; padding-left:0.5rem; font-weight:600; }
        .nav-item { display:flex; align-items:center; gap:1rem; padding:0.75rem 1rem; color:var(--text-muted); text-decoration:none; border-radius:10px; margin-bottom:0.25rem; transition:all 0.25s; font-weight:500; font-size:0.9rem; }
        .nav-item:hover, .nav-item.active { background:rgba(25,139,97,0.12); color:var(--primary); }
        .nav-item i { width:20px; text-align:center; }
        .sidebar-footer { padding:1.5rem; border-top:1px solid var(--border); }

        /* MAIN & TOPBAR */
        .main { margin-left:var(--sidebar-width); flex:1; }
        .topbar { height:70px; padding:0 2rem; display:flex; align-items:center; background:var(--dark-card); border-bottom:1px solid var(--border); }
        
        /* CONTENT */
        .content { padding:2rem; max-width: 800px; }
        .page-title { font-size:1.7rem; font-weight:700; margin-bottom:0.3rem; }
        .page-sub { color:var(--text-muted); font-size:0.95rem; margin-bottom:2rem; }

        /* EQUIPMENT INFO CARD */
        .eq-info-card { background:rgba(255,255,255,0.03); border:1px solid var(--border); border-radius:12px; padding:1.5rem; margin-bottom:1.5rem; display:grid; grid-template-columns:1fr 1fr; gap:1rem; }
        .eq-info-card-title { grid-column: 1 / -1; font-size:1.1rem; font-weight:600; color:var(--primary); border-bottom:1px solid var(--border); padding-bottom:0.8rem; margin-bottom:0.5rem; display:flex; align-items:center; gap:8px; }
        .eq-info-label { font-size:0.8rem; color:var(--text-muted); text-transform:uppercase; letter-spacing:0.5px; margin-bottom:0.2rem; }
        .eq-info-value { font-size:1rem; font-weight:500; color:white; }

        /* CURRENT ASSIGNMENT */
        .current-assign { background:rgba(25,139,97,0.1); border:1px solid rgba(25,139,97,0.3); padding:1rem 1.5rem; border-radius:10px; margin-bottom:2rem; display:flex; align-items:center; gap:10px; }
        .current-assign .label { font-weight:500; color:var(--text-muted); }
        .current-assign .value { font-weight:600; color:var(--primary); }
        .current-assign .not-assigned { font-weight:500; color:#e67e22; font-style:italic; }

        /* FORM CARD */
        .form-card { background:var(--dark-card); border:1px solid var(--border); border-radius:12px; padding:2rem; }
        .form-group { margin-bottom:1.5rem; }
        .form-group label { display:block; font-weight:500; margin-bottom:0.6rem; color:var(--text-muted); }
        .form-group select, .form-group input { width:100%; padding:0.8rem 1rem; background:rgba(0,0,0,0.2); border:1px solid var(--border); border-radius:8px; color:white; font-size:0.95rem; transition:border 0.3s; }
        .form-group select:focus, .form-group input:focus { border-color:var(--primary); outline:none; }
        .form-group select option { background:var(--dark-card); color:white; }
        
        /* BUTTONS */
        .form-actions { display:flex; gap:1rem; margin-top:2rem; padding-top:1.5rem; border-top:1px solid var(--border); }
        .btn { display:inline-flex; align-items:center; gap:8px; padding:0.7rem 1.2rem; border-radius:8px; font-size:0.95rem; font-weight:500; text-decoration:none; cursor:pointer; border:none; transition:all 0.2s; }
        .btn-info { background:var(--info); color:white; }
        .btn-info:hover { background:#1f6391; transform:translateY(-1px); }
        .btn-secondary { background:rgba(255,255,255,0.1); color:white; }
        .btn-secondary:hover { background:rgba(255,255,255,0.15); }
    </style>
</head>
<body>
{% include 'admin/_sidebar.html.twig' with {active: 'equipements'} %}
<main class="main">
    <header class="topbar">
        <div style="font-size:1rem;font-weight:600;">
            <a href="{{ path('admin_equipement_index') }}" style="color:var(--text-muted);text-decoration:none;">Équipements</a>
            <span style="color:var(--text-muted);margin:0 0.5rem;">/</span>
            <span style="color:white;">Assigner — {{ equipement.nom }}</span>
        </div>
    </header>
    <div class="content">
        <h1 class="page-title"><i class="fa-solid fa-user-plus" style="color:#5dade2;margin-right:8px;"></i>Assigner l'Équipement</h1>
        <p class="page-sub">Assignez <strong>{{ equipement.nom }}</strong> à un utilisateur spécifique.</p>

        <!-- Equipment info -->
        <div class="eq-info-card">
            <div class="eq-info-card-title"><i class="fa-solid fa-tractor"></i> Détails de l'équipement</div>
            <div>
                <div class="eq-info-label">Nom</div>
                <div class="eq-info-value">{{ equipement.nom }}</div>
            </div>
            <div>
                <div class="eq-info-label">Type</div>
                <div class="eq-info-value">{{ equipement.type }}</div>
            </div>
            <div>
                <div class="eq-info-label">Prix</div>
                <div class="eq-info-value">{{ equipement.prix|number_format(2, ',', ' ') }} DT</div>
            </div>
            <div>
                <div class="eq-info-label">Disponibilité</div>
                <div class="eq-info-value">{{ equipement.disponibilite }}</div>
            </div>
        </div>

        <!-- Current assignment -->
        <div class="current-assign">
            <i class="fa-solid fa-user" style="color:var(--primary);font-size:1.1rem;"></i>
            <span class="label">Assigné actuellement :</span>
            {% if equipement.user %}
                <span class="value">{{ equipement.user.fullName }} &lt;{{ equipement.user.email }}&gt;</span>
            {% else %}
                <span class="not-assigned">Non assigné</span>
            {% endif %}
        </div>

        <!-- Assignment form -->
        <div class="form-card">
            {{ form_start(form) }}
                <div class="form-group">
                    {{ form_label(form.user) }}
                    {{ form_widget(form.user) }}
                    {{ form_errors(form.user) }}
                    <small style="color:var(--text-muted);font-size:0.8rem;margin-top:5px;display:block;">
                        <i class="fa-solid fa-info-circle"></i> Sélectionnez "Aucun utilisateur" pour désassigner l'équipement.
                    </small>
                </div>
                <div class="form-actions">
                    <button type="submit" class="btn btn-info"><i class="fa-solid fa-user-check"></i> Confirmer l'assignation</button>
                    <a href="{{ path('admin_equipement_index') }}" class="btn btn-secondary"><i class="fa-solid fa-times"></i> Annuler</a>
                </div>
            {{ form_end(form) }}
        </div>
    </div>
</main>
</body>
</html>
