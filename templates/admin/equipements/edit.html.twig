<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Modifier Équipement | Admin Agrimans</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        :root {
            --primary: #198B61;
            --dark: #12181b;
            --dark-card: #1e2529;
            --text-main: #f8f9fa;
            --text-muted: #9ba4b5;
            --border: rgba(255,255,255,0.08);
            --danger: #e74c3c;
            --success: #2ecc71;
            --warning: #f1c40f;
            --sidebar-width: 260px;
        }
        * { margin:0; padding:0; box-sizing:border-box; font-family:'Inter',sans-serif; }
        body { background:var(--dark); color:var(--text-main); display:flex; min-height:100vh; }

        .sidebar { width:var(--sidebar-width); background:var(--dark-card); border-right:1px solid var(--border); display:flex; flex-direction:column; position:fixed; height:100vh; }
        .sidebar-header { padding:1.5rem; display:flex; align-items:center; gap:1rem; border-bottom:1px solid var(--border); }
        .sidebar-nav { padding:1.5rem 1rem; flex:1; overflow-y:auto; }
        .nav-section { text-transform:uppercase; font-size:0.72rem; color:var(--text-muted); letter-spacing:1px; margin:1.2rem 0 0.6rem; padding-left:0.5rem; font-weight:600; }
        .nav-item { display:flex; align-items:center; gap:1rem; padding:0.75rem 1rem; color:var(--text-muted); text-decoration:none; border-radius:10px; margin-bottom:0.25rem; transition:all 0.25s; font-weight:500; font-size:0.9rem; }
        .nav-item:hover, .nav-item.active { background:rgba(25,139,97,0.12); color:var(--primary); }
        .nav-item.active-danger { background:rgba(231,76,60,0.12); color:var(--danger); }
        .nav-item i { width:20px; text-align:center; }
        .sidebar-footer { padding:1.5rem; border-top:1px solid var(--border); }

        .main { margin-left:var(--sidebar-width); flex:1; }
        .topbar { height:70px; padding:0 2rem; display:flex; align-items:center; justify-content:space-between; background:var(--dark-card); border-bottom:1px solid var(--border); }
        .topbar-title { font-size:1.1rem; font-weight:600; }

        .content { padding:2rem; max-width:900px; }
        .page-title { font-size:1.7rem; font-weight:700; margin-bottom:0.3rem; }
        .page-sub { color:var(--text-muted); font-size:0.9rem; margin-bottom:2rem; }

        .edit-banner {
            display: flex;
            align-items: center;
            gap: 0.7rem;
            background: rgba(230,126,34,0.1);
            border: 1px solid rgba(230,126,34,0.3);
            border-radius: 10px;
            padding: 0.9rem 1.2rem;
            margin-bottom: 1.8rem;
            font-size: 0.9rem;
            color: #e67e22;
        }

        .form-card {
            background: var(--dark-card);
            border: 1px solid var(--border);
            border-radius: 16px;
            padding: 2rem;
        }

        .form-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 1.5rem;
        }

        .form-group {
            display: flex;
            flex-direction: column;
            gap: 0.5rem;
        }

        .form-group.full-width {
            grid-column: span 2;
        }

        .form-group label {
            font-size: 0.85rem;
            font-weight: 600;
            color: var(--text-muted);
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }

        .form-group input,
        .form-group select {
            background: var(--dark);
            border: 1px solid var(--border);
            border-radius: 10px;
            padding: 0.75rem 1rem;
            color: var(--text-main);
            font-size: 0.9rem;
            font-family: 'Inter', sans-serif;
            transition: border-color 0.2s, box-shadow 0.2s;
            width: 100%;
        }

        .form-group input:focus,
        .form-group select:focus {
            outline: none;
            border-color: var(--primary);
            box-shadow: 0 0 0 3px rgba(25,139,97,0.15);
        }

        .form-group input::placeholder { color: var(--text-muted); }

        select option { background: #1e2529; color: #f8f9fa; }

        .form-help { font-size: 0.78rem; color: var(--text-muted); margin-top: 0.2rem; }
        .form-error { font-size: 0.8rem; color: var(--danger); margin-top: 0.2rem; }

        .form-group.highlight-matching label { color: #667eea; }
        .form-group.highlight-matching input {
            border-color: rgba(102,126,234,0.4);
            background: rgba(102,126,234,0.05);
        }
        .form-group.highlight-matching input:focus {
            border-color: #667eea;
            box-shadow: 0 0 0 3px rgba(102,126,234,0.15);
        }
        .form-help.highlight { color: #667eea; }

        .btn { display:inline-flex; align-items:center; gap:6px; padding:0.6rem 1.2rem; border-radius:10px; font-size:0.9rem; font-weight:500; text-decoration:none; cursor:pointer; border:none; transition:all 0.2s; font-family:'Inter',sans-serif; }
        .btn-primary { background:#e67e22; color:#fff; }
        .btn-primary:hover { background:#d35400; transform:translateY(-1px); }
        .btn-secondary { background:rgba(255,255,255,0.08); color:var(--text-main); }
        .btn-secondary:hover { background:rgba(255,255,255,0.12); }

        .form-actions {
            display: flex;
            gap: 1rem;
            justify-content: flex-end;
            margin-top: 2rem;
            padding-top: 1.5rem;
            border-top: 1px solid var(--border);
        }

        .section-divider { grid-column: span 2; border: none; border-top: 1px solid var(--border); margin: 0.5rem 0; }
        .section-label { grid-column: span 2; font-size: 0.78rem; text-transform: uppercase; letter-spacing: 1px; color: var(--text-muted); font-weight: 600; padding-top: 0.5rem; }
    </style>
</head>
<body>
{% include 'admin/_sidebar.html.twig' with {active: 'equipements'} %}

<main class="main">
    <header class="topbar">
        <div class="topbar-title">
            <a href="{{ path('admin_equipement_index') }}" style="color:var(--text-muted);text-decoration:none;">
                <i class="fa-solid fa-tractor" style="margin-right:6px;"></i>Équipements
            </a>
            <span style="color:var(--text-muted);margin:0 0.5rem;">/</span>
            <span style="color:white;">Modifier — {{ equipement.nom }}</span>
        </div>
    </header>

    <div class="content">
        <h1 class="page-title">
            <i class="fa-solid fa-pen" style="color:#e67e22;margin-right:10px;"></i>Modifier l'Équipement
        </h1>
        <p class="page-sub">Modifiez les informations de <strong style="color:white;">{{ equipement.nom }}</strong>.</p>

        <div class="form-card">
            <div class="edit-banner">
                <i class="fa-solid fa-pen-to-square"></i>
                Vous modifiez l'équipement <strong>{{ equipement.nom }}</strong> (ID: {{ equipement.id }})
            </div>

            {{ form_start(form, {attr: {novalidate: 'novalidate'}}) }}
                <div class="form-grid">

                    <div class="form-group">
                        {{ form_label(form.nom) }}
                        {{ form_widget(form.nom) }}
                        <div class="form-error">{{ form_errors(form.nom) }}</div>
                    </div>

                    <div class="form-group">
                        {{ form_label(form.type) }}
                        {{ form_widget(form.type) }}
                        <div class="form-error">{{ form_errors(form.type) }}</div>
                    </div>

                    <div class="form-group">
                        {{ form_label(form.prix) }}
                        {{ form_widget(form.prix) }}
                        <div class="form-error">{{ form_errors(form.prix) }}</div>
                    </div>

                    <div class="form-group">
                        {{ form_label(form.disponibilite) }}
                        {{ form_widget(form.disponibilite) }}
                        <div class="form-error">{{ form_errors(form.disponibilite) }}</div>
                    </div>

                    <!-- Capacité de Rendement (champ unique pour Matching Intelligent) -->
                    <div class="form-group highlight-matching full-width">
                        {{ form_label(form.capaciteRendement) }}
                        {{ form_widget(form.capaciteRendement) }}
                        <div class="form-help highlight">
                            <i class="fa-solid fa-magnifying-glass-chart" style="margin-right:4px;"></i>{{ form_help(form.capaciteRendement) }}
                        </div>
                        <div class="form-error">{{ form_errors(form.capaciteRendement) }}</div>
                    </div>

                </div>

                <div class="form-actions">
                    <a href="{{ path('admin_equipement_index') }}" class="btn btn-secondary">
                        <i class="fa-solid fa-times"></i> Annuler
                    </a>
                    <button type="submit" class="btn btn-primary">
                        <i class="fa-solid fa-save"></i> Enregistrer les modifications
                    </button>
                </div>
            {{ form_end(form) }}
        </div>
    </div>
</main>
</body>
</html>
