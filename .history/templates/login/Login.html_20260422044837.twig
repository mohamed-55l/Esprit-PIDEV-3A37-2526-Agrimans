<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <title>AGRI Samir - Login</title>
    <link rel="stylesheet" href="{{ asset('styles/login.css') }}">
    <script src="https://www.google.com/recaptcha/api.js" async defer></script>
</head>
<body>

<div class="app-container">
    <div class="main-card">
        <div class="login-box">
            <p class="welcome">Bienvenue</p>
            <h1>Se connecter</h1>

            <div class="face-auth-box" style="text-align: center; margin-bottom: 20px; background: #f8fafc; padding: 15px; border-radius: 12px; border: 1px solid #e2e8f0;">
                <video id="video" width="220" height="165" autoplay muted style="transform: scaleX(-1); border-radius: 8px; background: #000;"></video>
                <div id="face-status" style="font-size: 12px; color: #718096; margin-top: 5px;">Initialisation caméra...</div>
                <button type="button" id="btn-face-login" class="btn-login" style="background: #1a6f44; margin-top: 10px; display: none;">
                    🚀 Se connecter par Visage
                </button>
            </div>

            <div style="text-align: center; color: #cbd5e0; margin-bottom: 15px;">— OU —</div>

            <form method="post">
                <label>Adresse email</label>
                <input type="email" name="email" placeholder="Votre email" required>

                <label>Mot de passe</label>
                <input type="password" name="password" placeholder="Mot de passe" required>

                <div class="g-recaptcha" data-sitekey="{{ recaptcha_site_key }}"></div>

                {% if error %}<p class="error">{{ error }}</p>{% endif %}

                <button type="submit" class="btn-login" style="background: #4a5568;">Se connecter par Email</button>
            </form>

            <p class="register">Pas de compte ? <a href="{{ path('app_register') }}">S'inscrire</a></p>
        </div>

        <div class="image-box">
            <img src="{{ asset('images/login.png') }}" alt="login image">
        </div>
    </div>
</div>

<script src="{{ asset('js/face-api.min.js') }}"></script>
<script>
    const video = document.getElementById('video');
    const status = document.getElementById('face-status');
    const btnFace = document.getElementById('btn-face-login');

    async function initFaceAuth() {
        try {
            const MODEL_PATH = '/js/models';
            await Promise.all([
                faceapi.nets.ssdMobilenetv1.loadFromUri(MODEL_PATH),
                faceapi.nets.faceLandmark68Net.loadFromUri(MODEL_PATH),
                faceapi.nets.faceRecognitionNet.loadFromUri(MODEL_PATH)
            ]);
            const stream = await navigator.mediaDevices.getUserMedia({ video: {} });
            video.srcObject = stream;
            status.innerText = "Reconnaissance prête ✅";
            btnFace.style.display = "block";
        } catch (e) {
            status.innerText = "Caméra non accessible ❌";
        }
    }

    btnFace.addEventListener('click', async () => {
        status.innerText = "Analyse de votre visage... ⏳";
        const detection = await faceapi.detectSingleFace(video).withFaceLandmarks().withFaceDescriptor();
        
        if (detection) {
            const response = await fetch('{{ path('app_login_face') }}', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ descriptor: Array.from(detection.descriptor) })
            });
            const res = await response.json();
            if (res.success) window.location.href = res.redirect;
            else status.innerText = res.message + " ❌";
        } else {
            status.innerText = "Visage non reconnu ❌";
        }
    });

    window.addEventListener('DOMContentLoaded', initFaceAuth);
</script>
</body>
</html>