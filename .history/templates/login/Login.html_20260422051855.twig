<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Agrimans - Connexion Biométrique</title>
    
    <script src="https://www.google.com/recaptcha/api.js" async defer></script>
    
    <style>
        :root {
            --primary-color: #0f6b3b;
            --dark-color: #1a1a1a;
            --bg-color: #0f6b3b;
            --text-gray: #718096;
        }

        * { box-sizing: border-box; margin: 0; padding: 0; }

        body {
            font-family: 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;
            background-color: var(--bg-color);
            display: flex;
            justify-content: center;
            align-items: center;
            min-height: 100vh;
        }

        .app-container {
            display: flex;
            justify-content: center;
            align-items: center;
            width: 100%;
            padding: 20px;
        }

        /* The Main Card */
        .main-card {
            width: 1000px;
            max-width: 100%;
            height: 700px;
            background: white;
            border-radius: 30px;
            display: flex;
            box-shadow: 0 25px 50px rgba(0,0,0,0.3);
            overflow: hidden; /* Important: keeps the image inside */
            position: relative;
        }

        /* Left Side: Login Form */
        .login-box {
            flex: 1.1;
            padding: 40px 60px;
            display: flex;
            flex-direction: column;
            justify-content: center;
            z-index: 2;
            background: white;
        }

        .login-box h1 {
            font-size: 32px;
            color: var(--dark-color);
            margin-bottom: 5px;
        }

        .subtitle {
            font-size: 13px;
            color: var(--text-gray);
            margin-bottom: 25px;
        }

        /* Face Auth UI */
        .face-auth-section {
            background: #f8fafc;
            border: 1px solid #e2e8f0;
            border-radius: 20px;
            padding: 20px;
            text-align: center;
            margin-bottom: 20px;
        }

        .video-wrapper {
            position: relative;
            width: 240px;
            height: 180px;
            margin: 0 auto;
            border-radius: 12px;
            overflow: hidden;
            background: #000;
            border: 3px solid var(--primary-color);
        }

        #video {
            width: 100%;
            height: 100%;
            object-fit: cover;
            transform: scaleX(-1); /* Mirror effect */
        }

        .status-msg {
            font-size: 12px;
            font-weight: 600;
            margin-top: 10px;
            color: var(--text-gray);
        }

        /* Inputs & Buttons */
        .separator {
            text-align: center;
            margin: 15px 0;
            color: #cbd5e0;
            font-size: 12px;
            position: relative;
        }

        .form-group { margin-bottom: 15px; }

        label {
            display: block;
            font-size: 13px;
            font-weight: 600;
            margin-bottom: 5px;
            color: #4a5568;
        }

        input {
            width: 100%;
            padding: 12px;
            border-radius: 10px;
            border: 1px solid #e2e8f0;
            background: #edf2f7;
            font-size: 14px;
            transition: all 0.3s ease;
        }

        input:focus {
            outline: none;
            border-color: var(--primary-color);
            background: white;
            box-shadow: 0 0 0 3px rgba(15, 107, 59, 0.1);
        }

        .btn {
            width: 100%;
            padding: 14px;
            border-radius: 12px;
            border: none;
            font-weight: bold;
            cursor: pointer;
            transition: transform 0.2s, background 0.3s;
            font-size: 15px;
        }

        .btn-primary {
            background: var(--primary-color);
            color: white;
            margin-top: 10px;
        }

        .btn-face {
            background: var(--dark-color);
            color: white;
            margin-top: 10px;
        }

        .btn:hover {
            transform: translateY(-2px);
            opacity: 0.9;
        }

        .error-alert {
            background: #fff5f5;
            color: #c53030;
            padding: 10px;
            border-radius: 8px;
            font-size: 13px;
            margin-bottom: 15px;
            text-align: center;
            border: 1px solid #feb2b2;
        }

        /* Right Side: Visual Image */
        .image-box {
            flex: 0.9;
            background: var(--primary-color);
            display: flex;
            align-items: center;
            justify-content: center;
            position: relative;
        }

        .image-box img {
            width: 100%;
            height: 100%;
            object-fit: cover; /* Fixed the overlap issue */
        }

        .register-link {
            text-align: center;
            margin-top: 20px;
            font-size: 14px;
            color: var(--text-gray);
        }

        .register-link a {
            color: var(--primary-color);
            text-decoration: none;
            font-weight: bold;
        }

        /* Recaptcha Scaling */
        .g-recaptcha {
            display: flex;
            justify-content: center;
            margin-bottom: 10px;
            transform: scale(0.85);
            transform-origin: center;
        }
    </style>
</head>
<body>

<div class="app-container">
    <div class="main-card">
        
        <div class="login-box">
            <p class="subtitle">PLATEFORME AGRIMANS</p>
            <h1>Se connecter</h1>

            {# Handle Errors from Controller #}
            {% if error %}
                <div class="error-alert">{{ error }}</div>
            {% endif %}

            <div class="face-auth-section">
                <div class="video-wrapper">
                    <video id="video" autoplay muted></video>
                </div>
                <p id="face-status" class="status-msg">Chargement des modèles AI...</p>
                <button type="button" id="btn-face-login" class="btn btn-face" style="display: none;">
                    🚀 Scanner mon visage
                </button>
            </div>

            <div class="separator"><span>OU</span></div>

            <form method="post" id="classic-form">
                <div class="form-group">
                    <label>Adresse email</label>
                    <input type="email" name="email" placeholder="votre@email.com" required>
                </div>

                <div class="form-group">
                    <label>Mot de passe</label>
                    <input type="password" name="password" placeholder="••••••••" required>
                </div>

                <div class="g-recaptcha" data-sitekey="{{ recaptcha_site_key }}"></div>

                <button type="submit" class="btn btn-primary">Se connecter par Email</button>
            </form>

            <p class="register-link">
                Nouveau ici ? <a href="{{ path('app_register') }}">Créer un compte</a>
            </p>
        </div>

        <div class="image-box">
            <img src="{{ asset('images/login.png') }}" alt="Agrimans Farmers">
        </div>
        
    </div>
</div>

<script src="{{ asset('js/face-api.min.js') }}"></script>
<script>
    const video = document.getElementById('video');
    const status = document.getElementById('face-status');
    const btnFace = document.getElementById('btn-face-login');

    // Initialize Models and Webcam
    async function initBiometrics() {
        try {
            const MODEL_PATH = '/js/models';
            
            // Load high-precision models (SSD Mobilenet)
            await Promise.all([
                faceapi.nets.ssdMobilenetv1.loadFromUri(MODEL_PATH),
                faceapi.nets.faceLandmark68Net.loadFromUri(MODEL_PATH),
                faceapi.nets.faceRecognitionNet.loadFromUri(MODEL_PATH)
            ]);

            const stream = await navigator.mediaDevices.getUserMedia({ video: {} });
            video.srcObject = stream;
            
            status.innerText = "Identification prête ✅";
            status.style.color = "#0f6b3b";
            btnFace.style.display = "block";
            
        } catch (err) {
            console.error(err);
            status.innerText = "Caméra non accessible ou modèles manquants ❌";
            status.style.color = "#c53030";
        }
    }

    // Handle AJAX Face ID Login
    btnFace.addEventListener('click', async () => {
        status.innerText = "Analyse biométrique en cours... ⏳";
        
        // Use high-precision detection
        const detection = await faceapi.detectSingleFace(video, new faceapi.SsdMobilenetv1Options())
            .withFaceLandmarks()
            .withFaceDescriptor();

        if (detection) {
            const descriptor = Array.from(detection.descriptor);

            // Send to Symfony Controller
            try {
                const response = await fetch('{{ path('app_login_face') }}', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ descriptor: descriptor })
                });

                const result = await response.json();

                if (result.success) {
                    status.innerText = "Authentifié ! Redirection... 🎉";
                    window.location.href = result.redirect;
                } else {
                    status.innerText = result.message + " ❌";
                }
            } catch (err) {
                status.innerText = "Erreur de communication avec le serveur ❌";
            }
        } else {
            status.innerText = "Visage non détecté. Cadrez bien votre visage ❌";
        }
    });

    window.addEventListener('DOMContentLoaded', initBiometrics);
</script>

</body>
</html>